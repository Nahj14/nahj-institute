---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Events & Lectures — Nahj Institute</title>
    <meta name="description" content="Upcoming and past lectures, seminars, and public discussions hosted by Nahj Institute. Sign up to be notified of new events." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <style is:global>
      :root {
        --navy:       #0C1B2E;
        --teal:       #1B5E6F;
        --teal-light: #246E82;
        --gold:       #C8A252;
        --gold-light: #E2BC75;
        --cream:      #F7F2E8;
        --cream-dark: #EDE6D5;
        --charcoal:   #2B2B2B;
        --muted:      #6B6B6B;
        --white:      #FFFFFF;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: var(--cream);
        color: var(--charcoal);
        font-family: 'Crimson Pro', Georgia, serif;
        font-size: 18px;
        line-height: 1.78;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .section-label {
        font-family: 'Crimson Pro', serif;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
      }

      .divider-gold {
        width: 3.5rem;
        height: 2px;
        background: var(--gold);
        margin: 0.9rem 0 1.5rem;
      }

      .divider-gold.center { margin: 0.9rem auto 1.5rem; }

      /* ─── PAGE HERO ───────────────────────────────────────── */
      .page-hero {
        background-color: var(--navy);
        color: var(--white);
        padding: 5.5rem 2rem 4.5rem;
        position: relative;
        overflow: hidden;
      }

      .page-hero::before {
        content: 'نهج';
        font-family: 'Amiri', serif;
        font-size: clamp(192px, 24vw, 352px);
        font-weight: 700;
        color: rgba(255,255,255,0.032);
        position: absolute;
        right: -1.5rem;
        top: 50%;
        transform: translateY(-50%);
        line-height: 1;
        pointer-events: none;
        user-select: none;
      }

      .page-hero-inner {
        max-width: 1120px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .breadcrumb {
        font-size: 13px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.4);
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .breadcrumb a {
        color: rgba(255,255,255,0.4);
        text-decoration: none;
        transition: color 0.2s;
      }

      .breadcrumb a:hover { color: var(--gold); }
      .breadcrumb span { color: rgba(255,255,255,0.2); }

      .page-hero h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(26px, 2.8vw, 36px);
        font-weight: 600;
        line-height: 1.07;
        color: var(--white);
        max-width: 780px;
        margin-bottom: 1.5rem;
      }

      .page-hero h1 em {
        font-style: italic;
        color: var(--gold-light);
      }

      .page-hero-sub {
        font-size: 21px;
        color: rgba(255,255,255,0.62);
        max-width: 580px;
        font-weight: 300;
        line-height: 1.78;
      }

      /* ─── EVENT TYPES BAR ─────────────────────────────────── */
      .types-bar {
        background: var(--cream-dark);
        border-bottom: 1px solid var(--cream-dark);
      }

      .types-bar-inner {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
      }

      .type-item {
        padding: 1.5rem 2rem 1.5rem 0;
        margin-right: 2.5rem;
        border-bottom: 2px solid transparent;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        cursor: pointer;
        transition: color 0.2s, border-color 0.2s;
        white-space: nowrap;
        user-select: none;
      }

      .type-item:hover { color: var(--navy); }

      .type-item.active {
        color: var(--navy);
        border-bottom-color: var(--gold);
      }

      /* ─── UPCOMING EVENTS ─────────────────────────────────── */
      .section-upcoming {
        padding: 5rem 2rem;
        background: var(--cream);
      }

      .section-header {
        margin-bottom: 3rem;
      }

      .section-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(22px, 2.2vw, 28px);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
      }

      /* Empty state for upcoming */
      .empty-state {
        border: 1px dashed var(--cream-dark);
        padding: 4rem 2rem;
        text-align: center;
        background: var(--white);
        max-width: 1120px;
        margin: 0 auto;
      }

      .empty-state .empty-icon {
        font-family: 'Amiri', serif;
        font-size: 38px;
        color: var(--cream-dark);
        margin-bottom: 1.25rem;
        display: block;
      }

      .empty-state h3 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 26px;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.75rem;
      }

      .empty-state p {
        font-size: 18px;
        color: var(--muted);
        max-width: 420px;
        margin: 0 auto 1.75rem;
        font-weight: 300;
        line-height: 1.78;
      }

      /* Upcoming event card, for when events exist */
      .events-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
        background: var(--cream-dark);
        max-width: 1120px;
        margin: 0 auto;
      }

      .event-row {
        background: var(--cream);
        display: grid;
        grid-template-columns: 110px 1fr auto;
        gap: 2.5rem;
        align-items: center;
        padding: 2rem 2.25rem;
        transition: background 0.2s;
        text-decoration: none;
        color: inherit;
      }

      .event-row:hover { background: var(--white); }

      .event-date-block {
        text-align: center;
        border-right: 1px solid var(--cream-dark);
        padding-right: 2.5rem;
      }

      .event-day {
        font-family: 'Cormorant Garamond', serif;
        font-size: 38px;
        font-weight: 600;
        color: var(--navy);
        line-height: 1;
        display: block;
      }

      .event-month {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
        margin-top: 0.2rem;
      }

      .event-year {
        font-size: 13px;
        color: var(--muted);
        display: block;
      }

      .event-info {}

      .event-type-tag {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--teal);
        margin-bottom: 0.5rem;
        display: block;
      }

      .event-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 22px;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.2;
        margin-bottom: 0.5rem;
      }

      .event-speaker {
        font-size: 15px;
        color: var(--muted);
      }

      .event-meta-right {
        text-align: right;
        flex-shrink: 0;
      }

      .event-time {
        font-size: 19px;
        color: var(--charcoal);
        margin-bottom: 0.3rem;
      }

      .event-location {
        font-size: 13px;
        color: var(--muted);
        margin-bottom: 1rem;
      }

      .event-badge {
        display: inline-block;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 0.3rem 0.75rem;
        border: 1px solid;
      }

      .event-badge.open {
        color: var(--teal);
        border-color: rgba(27,94,111,0.35);
        background: rgba(27,94,111,0.05);
      }

      .event-badge.online {
        color: var(--gold);
        border-color: rgba(200,162,82,0.35);
        background: rgba(200,162,82,0.05);
      }

      .event-badge.full {
        color: var(--muted);
        border-color: var(--cream-dark);
      }

      /* ─── PAST EVENTS ─────────────────────────────────────── */
      .section-past {
        padding: 5rem 2rem;
        background: var(--cream-dark);
      }

      .past-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2px;
        background: var(--cream-dark);
        max-width: 1120px;
        margin: 0 auto;
      }

      .past-card {
        background: var(--cream);
        padding: 2rem 1.75rem;
        transition: background 0.2s;
      }

      .past-card:hover { background: var(--white); }

      .past-card-date {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.6rem;
        display: block;
      }

      .past-card-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 21px;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.25;
        margin-bottom: 0.5rem;
      }

      .past-card-speaker {
        font-size: 15px;
        color: var(--muted);
        margin-bottom: 1.25rem;
      }

      .past-card-footer {
        padding-top: 1rem;
        border-top: 1px solid var(--cream-dark);
        display: flex;
        gap: 1rem;
        align-items: center;
      }

      .past-card-link {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--teal);
        text-decoration: none;
        transition: color 0.2s;
      }

      .past-card-link:hover { color: var(--gold); }

      .past-card-tag {
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        border: 1px solid var(--cream-dark);
        padding: 0.2rem 0.5rem;
      }

      /* ─── NOTIFY SECTION ──────────────────────────────────── */
      .section-notify {
        background: var(--navy);
        padding: 5rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      .section-notify::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 60% 80% at 70% 50%, rgba(27,94,111,0.3) 0%, transparent 70%);
        pointer-events: none;
      }

      .notify-inner {
        max-width: 560px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .notify-inner h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(22px, 2.2vw, 28px);
        font-weight: 600;
        color: var(--white);
        margin-top: 0.5rem;
        margin-bottom: 1rem;
        line-height: 1.15;
      }

      .notify-inner p {
        font-size: 19px;
        color: rgba(255,255,255,0.6);
        font-weight: 300;
        line-height: 1.78;
        margin-bottom: 2.25rem;
      }

      .notify-form {
        display: flex;
        gap: 0;
        max-width: 440px;
        margin: 0 auto 1.25rem;
      }

      .notify-form input {
        flex: 1;
        padding: 0.9rem 1.25rem;
        border: 1px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.07);
        font-family: 'Crimson Pro', serif;
        font-size: 18px;
        color: var(--white);
        outline: none;
        transition: border-color 0.2s;
      }

      .notify-form input::placeholder { color: rgba(255,255,255,0.3); }
      .notify-form input:focus { border-color: var(--gold); }

      .notify-form button {
        background: var(--gold);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.9rem 1.5rem;
        border: none;
        cursor: pointer;
        transition: background 0.2s;
        white-space: nowrap;
      }

      .notify-form button:hover { background: var(--gold-light); }

      .notify-note {
        font-size: 13px;
        color: rgba(255,255,255,0.3);
      }

      /* ─── PROPOSE EVENT ───────────────────────────────────── */
      .section-propose {
        padding: 4.5rem 2rem;
        background: var(--cream);
        border-top: 1px solid var(--cream-dark);
      }

      .propose-inner {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
      }

      .propose-text h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(22px, 2.2vw, 28px);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
        margin-bottom: 1rem;
        line-height: 1.15;
      }

      .propose-text p {
        font-size: 18px;
        color: var(--muted);
        line-height: 1.78;
        font-weight: 300;
        margin-bottom: 0;
      }

      .propose-details {
        display: flex;
        flex-direction: column;
        gap: 0;
        border: 1px solid var(--cream-dark);
      }

      .propose-row {
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--cream-dark);
        display: flex;
        gap: 1.5rem;
        align-items: baseline;
      }

      .propose-row:last-child { border-bottom: none; }

      .propose-row-label {
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--gold);
        flex-shrink: 0;
        width: 110px;
      }

      .propose-row-val {
        font-size: 19px;
        color: var(--charcoal);
        line-height: 1.6;
      }

      .btn-outline-dark {
        display: inline-block;
        border: 1px solid var(--navy);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.82rem 1.75rem;
        text-decoration: none;
        margin-top: 1.75rem;
        transition: background 0.2s, color 0.2s;
      }

      .btn-outline-dark:hover {
        background: var(--navy);
        color: var(--gold);
      }

      .btn-primary {
        display: inline-block;
        background: var(--gold);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.82rem 1.75rem;
        text-decoration: none;
        transition: background 0.2s, transform 0.15s;
      }

      .btn-primary:hover {
        background: var(--gold-light);
        transform: translateY(-1px);
      }

      /* ─── RESPONSIVE ──────────────────────────────────────── */
      @media (max-width: 768px) {
        .event-row { grid-template-columns: 90px 1fr; gap: 1.5rem; }
        .event-meta-right { display: none; }
        .propose-inner { grid-template-columns: 1fr; gap: 2.5rem; }
        .types-bar-inner { overflow-x: auto; padding-bottom: 0; }
        .page-hero { padding: 4rem 1.5rem 3rem; }
        .page-hero::before { font-size: 128px; }
      }
    </style>
  </head>

  <body>
    <Header />

    <!-- ══════════════════════════════════════════════ PAGE HERO -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <nav class="breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <span style="color: rgba(255,255,255,0.65);">Events & Lectures</span>
        </nav>
        <h1>Lectures, Seminars,<br />and <em>Public Discussions</em></h1>
        <p class="page-hero-sub">
          Nahj Institute convenes scholars, practitioners, and public thinkers for substantive in-person and online events. All events are free to attend unless otherwise noted.
        </p>
      </div>
    </section>

    <main>

      <!-- ══════════════════════════════════════════ TYPES BAR -->
      <div class="types-bar">
        <div class="types-bar-inner">
          <span class="type-item active">All Events</span>
          <span class="type-item">Lectures</span>
          <span class="type-item">Seminars</span>
          <span class="type-item">Workshops</span>
          <span class="type-item">Panels</span>
          <span class="type-item">Online</span>
        </div>
      </div>

      <!-- ══════════════════════════════════════ UPCOMING EVENTS -->
      <section class="section-upcoming">
        <div class="container">
          <div class="section-header">
            <span class="section-label">On the Calendar</span>
            <div class="divider-gold"></div>
            <h2>Upcoming Events</h2>
          </div>
        </div>

        <!-- SWAP THIS BLOCK WITH .events-list ONCE YOU HAVE REAL EVENTS -->
        <div class="empty-state">
          <span class="empty-icon">◈</span>
          <h3>New Events Coming Soon</h3>
          <p>
            We are in the process of scheduling our next programme of lectures and seminars. Sign up below and we will notify you when dates are confirmed.
          </p>
          <a href="#notify" class="btn-primary">Notify Me of New Events</a>
        </div>

        <!--
          WHEN YOU HAVE EVENTS, DELETE THE empty-state BLOCK ABOVE
          AND UNCOMMENT THE FOLLOWING:

        <div class="events-list container">
          <a href="/events/example-event" class="event-row">
            <div class="event-date-block">
              <span class="event-day">14</span>
              <span class="event-month">June</span>
              <span class="event-year">2025</span>
            </div>
            <div class="event-info">
              <span class="event-type-tag">Annual Lecture</span>
              <div class="event-title">Islam, Democracy, and the Problem of Sovereignty</div>
              <div class="event-speaker">Professor Abdullahi Ahmed An-Na'im · Emory University School of Law</div>
            </div>
            <div class="event-meta-right">
              <div class="event-time">6:30 PM</div>
              <div class="event-location">London · Venue TBC</div>
              <span class="event-badge open">Registration Open</span>
            </div>
          </a>
        </div>
        -->
      </section>

      <!-- ════════════════════════════════════════ PAST EVENTS -->
      <section class="section-past">
        <div class="container">
          <div class="section-header">
            <span class="section-label">Archive</span>
            <div class="divider-gold"></div>
            <h2>Past Events</h2>
          </div>
        </div>

        <div class="past-grid container">

          <div class="past-card">
            <span class="past-card-date">February 2025</span>
            <h3 class="past-card-title">Nahj Institute Inaugural Lecture: Scholarship in an Age of Noise</h3>
            <p class="past-card-speaker">Founding Director, Nahj Institute</p>
            <div class="past-card-footer">
              <span class="past-card-tag">Inaugural Lecture</span>
              <a href="#" class="past-card-link">Watch Recording →</a>
            </div>
          </div>

          <div class="past-card">
            <span class="past-card-date">March 2025</span>
            <h3 class="past-card-title">Reading Nahj al-Balagha in the Twenty-First Century</h3>
            <p class="past-card-speaker">Panel Discussion · Nahj Institute Contributors</p>
            <div class="past-card-footer">
              <span class="past-card-tag">Panel</span>
              <a href="#" class="past-card-link">Watch Recording →</a>
            </div>
          </div>

          <div class="past-card">
            <span class="past-card-date">April 2025</span>
            <h3 class="past-card-title">Political Islam After the Arab Spring: What Remains?</h3>
            <p class="past-card-speaker">Seminar · Guest Speaker TBC</p>
            <div class="past-card-footer">
              <span class="past-card-tag">Seminar</span>
              <a href="#" class="past-card-link">Event Summary →</a>
            </div>
          </div>

        </div>
      </section>

      <!-- ════════════════════════════════════════════ NOTIFY -->
      <section class="section-notify" id="notify">
        <div class="notify-inner">
          <span class="section-label" style="color: var(--gold);">Stay Informed</span>
          <div class="divider-gold center"></div>
          <h2>Be the First to Know</h2>
          <p>
            Enter your email address and we will notify you when new events are announced. We send one short message per event, nothing more.
          </p>
          <form class="notify-form" action="https://formspree.io/f/YOUR_EVENTS_FORM_ID" method="POST">
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="email" name="email" placeholder="your@email.com" required />
            <button type="submit">Notify Me</button>
          </form>
          <p class="notify-note">No newsletters. No marketing. Events only.</p>
        </div>
      </section>

      <!-- ══════════════════════════════════════════ PROPOSE -->
      <section class="section-propose">
        <div class="propose-inner">
          <div class="propose-text">
            <span class="section-label">Collaborate</span>
            <div class="divider-gold"></div>
            <h2>Propose an Event or Speaker</h2>
            <p>
              We welcome suggestions from researchers, students, and institutions. If you would like to propose a speaker, co-host a seminar, or discuss a partnership around a particular topic, please get in touch with our programmes team.
            </p>
            <a href="/contact" class="btn-outline-dark">Contact the Programmes Team</a>
          </div>

          <div class="propose-details">
            <div class="propose-row">
              <span class="propose-row-label">Format</span>
              <span class="propose-row-val">Public lecture, seminar, panel discussion, or workshop</span>
            </div>
            <div class="propose-row">
              <span class="propose-row-label">Location</span>
              <span class="propose-row-val">In-person, online, or hybrid</span>
            </div>
            <div class="propose-row">
              <span class="propose-row-label">Lead Time</span>
              <span class="propose-row-val">We ask for at least six weeks notice for new events</span>
            </div>
            <div class="propose-row">
              <span class="propose-row-label">Costs</span>
              <span class="propose-row-val">Discussed on a case-by-case basis</span>
            </div>
            <div class="propose-row">
              <span class="propose-row-label">Recording</span>
              <span class="propose-row-val">All events are recorded and made available online with speaker consent</span>
            </div>
          </div>
        </div>
      </section>

    </main>

    <Footer />

    <script>
      const typeItems = document.querySelectorAll('.type-item');
      typeItems.forEach(item => {
        item.addEventListener('click', () => {
          typeItems.forEach(i => i.classList.remove('active'));
          item.classList.add('active');
        });
      });
    </script>

