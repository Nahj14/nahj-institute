---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatShortDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Nahj Institute — Charting the Path. Shaping the Discourse."
  description="Nahj Institute is an independent research centre and think tank producing scholarship at the intersection of Islamic thought, politics, society, and contemporary global affairs."
>

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-logo-mark">
        <span class="en">Nahj Institute</span>
      </div>

      <h1>
        Scholarship at the<br />
        <em>Intersection</em> of Ideas<br />
        and the World
      </h1>

      <p class="hero-tagline">Charting the Path · Shaping the Discourse</p>

      <p class="hero-desc">
        Nahj Institute is an independent research centre and public forum dedicated to serious scholarship on the Muslim world, the Global South, and the ideas that shape them, on their own terms.
      </p>
      <p class="hero-desc">
        The dominant publishing infrastructure of the English-speaking world brings genuine expertise to these questions. It also brings frameworks, assumptions, and priorities that are not universal. Scholars, writers, and practitioners whose perspective is shaped by the Muslim world or the Global South often find that their most serious work fits poorly into spaces not built for it.
      </p>
      <p class="hero-desc">
        Nahj exists to be one such space. The argument we are making is not that the bar should be lower. It is that the door should be wider.
      </p>

      <div class="hero-ctas">
        <a href="/research" class="btn-primary">Read Our Research</a>
        <a href="/about" class="btn-outline">About the Institute</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ HIGHLIGHT BAR -->
  <div class="highlight-bar">
    <span class="bar-label">Latest</span>
    <div class="bar-track">
      <div class="bar-items">
        <a href="/research/submit" class="bar-item">Nahj Journal: Submissions Now Open for Volume I</a>
        <a href="/community#competitions" class="bar-item">Writing Competition Open</a>
        <a href="/events" class="bar-item">Upcoming Lecture: Geopolitics of the Muslim World</a>
        <a href="/community#student" class="bar-item">Student Mentorship Applications Open</a>
        <a href="/research/submit" class="bar-item" aria-hidden="true">Nahj Journal: Submissions Now Open for Volume I</a>
        <a href="/community#competitions" class="bar-item" aria-hidden="true">Writing Competition Open</a>
        <a href="/events" class="bar-item" aria-hidden="true">Upcoming Lecture: Geopolitics of the Muslim World</a>
        <a href="/community#student" class="bar-item" aria-hidden="true">Student Mentorship Applications Open</a>
      </div>
    </div>
  </div>

  <main id="main-content">

    <!-- ════════════════════════════════════════════ PILLARS -->
    <section class="section-pillars">
      <div class="container">
        <div class="section-header-center">
          <span class="section-label">What We Do</span>
          <div class="divider-gold center"></div>
          <p class="section-sub">Nahj operates across research, public events, academic publishing, student programmes, and community engagement.</p>
        </div>

        <div class="pillars-grid">
          <a href="/research" class="pillar-card">
            <span class="pillar-icon" aria-hidden="true">✦</span>
            <h3 class="pillar-title">Research & Publications</h3>
            <p class="pillar-body">Essays, policy briefs, commentary, and long-form analysis on the Muslim world, global politics, society, and ethics. We hold our publications to the standards of serious academic and public-intellectual work.</p>
          </a>

          <a href="/events" class="pillar-card">
            <span class="pillar-icon" aria-hidden="true">◉</span>
            <h3 class="pillar-title">Lectures & Seminars</h3>
            <p class="pillar-body">Public lectures, panel discussions, and closed seminars bringing together scholars and practitioners. Most events are free and open to all.</p>
          </a>

          <a href="/community#competitions" class="pillar-card">
            <span class="pillar-icon" aria-hidden="true">◈</span>
            <h3 class="pillar-title">Writing Competitions</h3>
            <p class="pillar-body">Annual prize competitions open to students and emerging writers, with rigorous editorial feedback and publication opportunities for the strongest entries.</p>
          </a>

          <a href="/community#student" class="pillar-card">
            <span class="pillar-icon" aria-hidden="true">◇</span>
            <h3 class="pillar-title">Student Programmes</h3>
            <p class="pillar-body">Workshops, research skills training, one-on-one mentorship, and career guidance for students and early-career researchers across our focus areas.</p>
          </a>

          <a href="/community#charity" class="pillar-card">
            <span class="pillar-icon" aria-hidden="true">✧</span>
            <h3 class="pillar-title">Community & Charity</h3>
            <p class="pillar-body">Nahj supports charitable initiatives and grounds its work in practical concern for the communities it serves. Scholarship is one part of that commitment.</p>
          </a>

          <a href="/contact" class="pillar-card" style="background: var(--teal); border-color: var(--teal);">
            <span class="section-label" style="margin-bottom: 1.1rem;">Get Involved</span>
            <h3 class="pillar-title" style="color: var(--white); font-size: 24px;">Contribute to Nahj</h3>
            <p class="pillar-body" style="color: rgba(255,255,255,0.7); margin-bottom: 1.5rem;">Submit a research piece, propose an event, apply to a programme, or simply reach out.</p>
            <span style="font-size: 13px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold-light);">Contact Us →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════ FEATURED INSIGHTS -->
    <section class="section-insights">
      <div class="container">
        <div class="section-header-split">
          <div>
            <span class="section-label">Featured Reading</span>
            <div class="divider-gold"></div>
            <h2>Recent Publications</h2>
          </div>
          <a href="/research" class="link-all">All Publications →</a>
        </div>

        <div class="insights-grid" id="insights-grid">
          {allArticles.map((article, i) => {
            const slug = article.id.replace(/\.mdx?$/, '').toLowerCase();
            return (
              <a
                href={`/articles/${slug}`}
                class="insight-card"
                data-article-index={i}
                style={i >= 3 ? 'display:none;opacity:0;' : ''}
              >
                <div class="insight-card-body">
                  <span class="insight-tag">{article.data.category}</span>
                  <h3 class="insight-title">{article.data.title}</h3>
                  <p class="insight-excerpt">{article.data.excerpt}</p>
                  <div class="insight-meta">
                    {article.data.author} · {formatShortDate(new Date(article.data.date))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        {allArticles.length > 3 && (
          <div class="insights-nav" id="insights-nav" aria-label="Publication navigation">
            {allArticles.map((_, i) => (
              <button
                class={`insights-dot${i === 0 ? ' active' : ''}`}
                data-dot={i}
                aria-label={`Go to article set ${i + 1}`}
              />
            ))}
          </div>
        )}
      </div>
    </section>

    <script>
      (function () {
        const grid = document.getElementById('insights-grid');
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll<HTMLElement>('.insight-card'));
        const n = cards.length;
        if (n <= 3) return;

        const PER_VIEW = 3;
        let offset = 0;
        let timer: ReturnType<typeof setInterval>;

        function showOffset(next: number, animate: boolean) {
          offset = ((next % n) + n) % n;
          cards.forEach((card, i) => {
            const pos = ((i - offset + n) % n);
            const visible = pos < PER_VIEW;
            if (animate) {
              card.style.transition = 'opacity 0.45s ease';
              if (!visible) {
                card.style.opacity = '0';
                setTimeout(() => { card.style.display = 'none'; }, 460);
              } else {
                card.style.display = '';
                requestAnimationFrame(() =>
                  requestAnimationFrame(() => { card.style.opacity = '1'; })
                );
              }
            } else {
              card.style.transition = 'none';
              card.style.display = visible ? '' : 'none';
              card.style.opacity = visible ? '1' : '0';
            }
          });

          // Update dots to reflect lead card
          const nav = document.getElementById('insights-nav');
          if (nav) {
            nav.querySelectorAll<HTMLElement>('.insights-dot').forEach((dot, i) => {
              dot.classList.toggle('active', i === offset);
            });
          }
        }

        function advance() {
          showOffset(offset + 1, true);
        }

        function startTimer() {
          clearInterval(timer);
          timer = setInterval(advance, 6000);
        }

        // Dot clicks
        const nav = document.getElementById('insights-nav');
        if (nav) {
          nav.querySelectorAll<HTMLButtonElement>('.insights-dot').forEach((dot, i) => {
            dot.addEventListener('click', () => {
              showOffset(i, true);
              startTimer();
            });
          });
        }

        // Pause on hover
        grid.addEventListener('mouseenter', () => clearInterval(timer));
        grid.addEventListener('mouseleave', startTimer);

        showOffset(0, false);
        startTimer();
      })();
    </script>

    <!-- ════════════════════════════════════════ EVENTS STRIP -->
    <section class="section-events">
      <div class="container">
        <div class="section-header-split">
          <div>
            <span class="section-label">On the Calendar</span>
            <div class="divider-gold"></div>
            <h2>Events & Lectures</h2>
          </div>
          <a href="/events" class="link-all">All Events →</a>
        </div>

        <div class="events-empty">
          <p>Our next programme of lectures and seminars is being scheduled. Sign up to be notified when new events are announced, or visit the events page for recordings of past sessions.</p>
          <div class="events-ctas">
            <a href="/events#notify" class="btn-primary">Notify Me of New Events</a>
            <a href="/events" class="btn-outline-dark">View Past Events</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════ JOURNAL STRIP -->
    <section class="section-journal-strip">
      <div class="journal-strip-inner">
        <div class="journal-strip-text">
          <span class="section-label">Academic Journal</span>
          <div class="divider-gold"></div>
          <h2>The <em>Nahj Journal</em></h2>
          <p>A peer-reviewed, open-access publication appearing twice yearly. Volume I is now open for submissions, carrying original research across the humanities, social sciences, and Islamic intellectual history.</p>
          <div class="journal-ctas">
            <a href="/research/submit" class="btn-primary">Submit an Article</a>
            <a href="/research/submit" class="btn-outline-light">Learn More</a>
          </div>
        </div>

        <div class="journal-strip-meta">
          <div class="jmeta">
            <span class="jmeta-label">Frequency</span>
            <span class="jmeta-value">Twice yearly</span>
          </div>
          <div class="jmeta">
            <span class="jmeta-label">Review</span>
            <span class="jmeta-value">Double-blind peer review</span>
          </div>
          <div class="jmeta">
            <span class="jmeta-label">Access</span>
            <span class="jmeta-value">Fully open access</span>
          </div>
          <div class="jmeta">
            <span class="jmeta-label">Inaugural Issue</span>
            <span class="jmeta-value">Vol. I, Winter 2026</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════ ABOUT STRIP -->
    <section class="section-about">
      <div class="about-grid">
        <div class="about-text">
          <span class="section-label">About the Institute</span>
          <div class="divider-gold"></div>
          <h2>Rooted in Tradition.<br /><em>Speaking to the Present.</em></h2>
          <p>Nahj takes its name from the Arabic word for path or method, and its spirit from the great intellectual traditions of Islamic civilisation. We are a research institute, a think tank, and a community of scholars and students who believe that rigorous engagement with ideas and rigorous engagement with the world are inseparable.</p>
          <p>We are independent, self-funded, and governed by our founding principles. That independence shapes everything we publish and everything we say.</p>
          <a href="/about" class="btn-outline-dark" style="margin-top: 0.5rem;">Our Story and Mission</a>
        </div>

        <div class="about-stats">
          <div class="stat-block">
            <div class="stat-number">10+</div>
            <div class="stat-label">Published essays and papers</div>
          </div>
          <div class="stat-block">
            <div class="stat-number">12</div>
            <div class="stat-label">Distinguished speakers hosted</div>
          </div>
          <div class="stat-block">
            <div class="stat-number">1</div>
            <div class="stat-label">Annual writing competition</div>
          </div>
          <div class="stat-block">
            <div class="stat-number">50+</div>
            <div class="stat-label">Students mentored and supported</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═════════════════════════════════════════ NEWSLETTER -->
    <section class="section-newsletter">
      <div class="container">
        <span class="section-label">Stay Connected</span>
        <div class="divider-gold center"></div>
        <h2>Receive Our Work by Email</h2>
        <p>New essays, event announcements, and competition notices. Published when there is something worth saying.</p>
        <form class="newsletter-form" action="https://formspree.io/f/mnjgboyw" method="POST">
          <input type="text" name="_gotcha" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;overflow:hidden" tabindex="-1" autocomplete="off" />
          <input type="email" name="email" placeholder="Your email address" required />
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </section>

  </main>

  <style>
    /* ─── HERO ────────────────────────────────────────────── */
    .hero {
      background-color: var(--navy);
      color: var(--white);
      padding: 6rem 2rem 5rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: 'نهج';
      font-family: 'Amiri', serif;
      font-size: clamp(224px, 28vw, 416px);
      font-weight: 700;
      color: rgba(255,255,255,0.035);
      position: absolute;
      right: -2rem;
      top: 50%;
      transform: translateY(-50%);
      line-height: 1;
      pointer-events: none;
      user-select: none;
    }

    .hero-inner {
      max-width: 1120px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .hero-logo-mark {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 2.5rem;
    }

    .hero-logo-mark .en {
      font-family: 'Cormorant Garamond', serif;
      font-size: 19px;
      font-weight: 500;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .hero-logo-mark .ar {
      font-family: 'Amiri', serif;
      font-size: 21px;
      color: rgba(255,255,255,0.72);
      font-weight: 400;
    }

    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(26px, 2.8vw, 36px);
      font-weight: 600;
      line-height: 1.08;
      letter-spacing: -0.01em;
      color: var(--white);
      max-width: 820px;
      margin-bottom: 1.25rem;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--gold-light);
    }

    .hero-tagline {
      font-family: 'Cormorant Garamond', serif;
      font-size: 15px;
      font-weight: 300;
      letter-spacing: 0.15em;
      color: rgba(255,255,255,0.72);
      text-transform: uppercase;
      margin-bottom: 2rem;
    }

    .hero-desc {
      font-size: 19px;
      color: rgba(255,255,255,0.7);
      max-width: 580px;
      line-height: 1.78;
      margin-bottom: 2.8rem;
      font-weight: 300;
    }

    .hero-ctas {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    /* ─── HIGHLIGHT BAR ───────────────────────────────────── */
    .highlight-bar {
      background: var(--teal);
      padding: 0.65rem 0;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .bar-label {
      font-family: 'Crimson Pro', serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      white-space: nowrap;
      flex-shrink: 0;
      padding: 0 1.5rem;
      border-right: 1px solid rgba(255,255,255,0.18);
      z-index: 1;
    }

    .bar-track {
      flex: 1;
      overflow: hidden;
      position: relative;
    }

    .bar-items {
      display: flex;
      gap: 0;
      width: max-content;
      animation: ticker 28s linear infinite;
    }

    .bar-items:hover { animation-play-state: paused; }

    @keyframes ticker {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .bar-item {
      font-size: 13px;
      color: rgba(255,255,255,0.78);
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      transition: color 0.2s;
      padding: 0 2.5rem;
    }

    .bar-item:hover { color: var(--white); }

    .bar-item::before {
      content: '◆';
      font-size: 6px;
      color: var(--gold);
      flex-shrink: 0;
    }

    /* ─── PILLARS ─────────────────────────────────────────── */
    .section-pillars {
      padding: 6rem 2rem;
      background: var(--cream);
    }

    .section-header-center {
      text-align: center;
      margin-bottom: 4rem;
    }

    .section-header-center h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(22px, 2.2vw, 28px);
      font-weight: 600;
      color: var(--navy);
      margin-top: 0.5rem;
    }

    .section-sub {
      font-size: 18px;
      color: var(--muted);
      max-width: 520px;
      margin: 0.75rem auto 0;
      font-weight: 300;
      line-height: 1.78;
    }

    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 0;
      border: 1px solid var(--cream-dark);
    }

    .pillar-card {
      padding: 2.5rem 2rem;
      border: 1px solid var(--cream-dark);
      transition: background 0.25s ease;
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .pillar-card:hover { background: var(--navy); }
    .pillar-card:hover .pillar-title,
    .pillar-card:hover .pillar-body { color: rgba(255,255,255,0.88); }
    .pillar-card:hover .pillar-icon { color: var(--gold); }

    .pillar-icon {
      font-size: 24px;
      margin-bottom: 1.25rem;
      color: var(--teal);
      display: block;
      transition: color 0.25s;
    }

    .pillar-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 0.6rem;
      transition: color 0.25s;
    }

    .pillar-body {
      font-size: 18px;
      color: var(--muted);
      line-height: 1.72;
      transition: color 0.25s;
    }

    /* ─── INSIGHTS ────────────────────────────────────────── */
    .section-insights {
      padding: 6rem 2rem;
      background: var(--cream-dark);
    }

    .section-header-split {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .section-header-split h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(22px, 2.2vw, 28px);
      font-weight: 600;
      color: var(--navy);
      margin-top: 0.5rem;
    }

    .link-all {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--teal);
      text-decoration: none;
      transition: color 0.2s;
      white-space: nowrap;
    }

    .link-all:hover { color: var(--gold); }

    .insights-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2px;
      background: var(--cream-dark);
    }

    .insight-card {
      background: var(--cream);
      display: flex;
      flex-direction: column;
      border-top: 3px solid transparent;
      transition: border-color 0.25s, background 0.2s;
      text-decoration: none;
      color: inherit;
    }

    .insight-card:hover {
      border-color: var(--gold);
      background: var(--white);
    }

    .insight-card-body {
      padding: 1.75rem 1.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .insight-tag {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 0.75rem;
      display: block;
    }

    .insight-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--navy);
      line-height: 1.25;
      margin-bottom: 0.75rem;
      flex: 1;
    }

    .insight-excerpt {
      font-size: 18px;
      color: var(--muted);
      line-height: 1.80;
      margin-bottom: 1.25rem;
      font-weight: 300;
    }

    .insight-meta {
      font-size: 13px;
      color: var(--muted);
      padding-top: 1rem;
      border-top: 1px solid var(--cream-dark);
    }

    /* ─── INSIGHTS NAV DOTS ───────────────────────────────── */
    .insights-nav {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 2rem;
    }

    .insights-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      border: none;
      background: var(--cream-dark);
      cursor: pointer;
      padding: 0;
      transition: background 0.25s, transform 0.25s;
    }

    .insights-dot.active {
      background: var(--gold);
      transform: scale(1.35);
    }

    .insights-dot:hover:not(.active) {
      background: var(--teal);
    }

    /* ─── EVENTS STRIP ────────────────────────────────────── */
    .section-events {
      padding: 6rem 2rem;
      background: var(--cream);
    }

    .events-empty {
      border: 1px dashed var(--cream-dark);
      background: var(--white);
      padding: 3.5rem 2rem;
      text-align: center;
      max-width: 1120px;
      margin: 0 auto;
    }

    .events-empty p {
      font-size: 18px;
      color: var(--muted);
      font-weight: 300;
      margin-bottom: 1.75rem;
      line-height: 1.78;
      max-width: 520px;
      margin-left: auto;
      margin-right: auto;
    }

    .events-ctas {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ─── JOURNAL STRIP ───────────────────────────────────── */
    .section-journal-strip {
      background: var(--navy);
      padding: 5.5rem 2rem;
      position: relative;
      overflow: hidden;
    }

    .section-journal-strip::before {
      content: '';
      position: absolute;
