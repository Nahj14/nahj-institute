---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>NAHJ: The Journal of Transdisciplinary Theory | Nahj Institute</title>
    <meta name="description" content="NAHJ is an international, peer-reviewed, Diamond Open Access journal dedicated to rigorous investigation of the human condition through transdisciplinary theory." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <style is:global>
      /*
        JOURNAL PAGE — ALL SIZES IN px.
        Design reference: Nature.com, Cell.com
        Single font system: Crimson Pro for all UI / body text
                            Cormorant Garamond for headings only
        Body: 18px / line-height 1.82
        NO rem anywhere — prevents html-root cascade inconsistency.
      */
      :root {
        --navy:       #0C1B2E;
        --teal:       #1B5E6F;
        --gold:       #C8A252;
        --gold-light: #E2BC75;
        --cream:      #F7F2E8;
        --cream-dark: #EDE6D5;
        --charcoal:   #2B2B2B;
        --muted:      #6B6B6B;
        --white:      #FFFFFF;
      }
      html { font-size: 16px; }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: var(--cream);
        color: var(--charcoal);
        font-family: 'Crimson Pro', Georgia, serif;
        font-size: 18px;
        line-height: 1.82;
        -webkit-font-smoothing: antialiased;
      }

      main { width: 100%; max-width: 100%; margin: 0; padding: 0; }
      .container { max-width: 1120px; margin: 0 auto; padding: 0 2rem; }

      /* ── SHARED UTILITIES ──────────────────────────────── */
      .section-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
        font-family: 'Crimson Pro', serif;
      }
      .gold-rule { width: 3.5rem; height: 2px; background: var(--gold); margin: 0.75rem 0 1.4rem; }
      .gold-rule.c { margin: 0.75rem auto 1.4rem; }

      /* ── BUTTONS ───────────────────────────────────────── */
      .btn-gold {
        display: inline-block; background: var(--gold); color: var(--navy);
        font-family: 'Crimson Pro', serif; font-size: 13px; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        padding: 0.82rem 1.9rem; text-decoration: none;
        transition: background 0.2s, transform 0.15s; border: none; cursor: pointer;
      }
      .btn-gold:hover { background: var(--gold-light); transform: translateY(-1px); }
      .btn-navy {
        display: inline-block; background: var(--navy); color: var(--gold);
        font-family: 'Crimson Pro', serif; font-size: 13px; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        padding: 0.82rem 1.9rem; text-decoration: none; transition: background 0.2s;
        border: none; cursor: pointer;
      }
      .btn-navy:hover { background: var(--teal); }
      .btn-outline {
        display: inline-block; border: 1px solid var(--navy); color: var(--navy);
        font-family: 'Crimson Pro', serif; font-size: 13px; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        padding: 0.82rem 1.9rem; text-decoration: none; transition: background 0.2s, color 0.2s;
      }
      .btn-outline:hover { background: var(--navy); color: var(--gold); }
      .btn-outline-lt {
        display: inline-block; border: 1px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.72);
        font-family: 'Crimson Pro', serif; font-size: 13px; font-weight: 600;
        letter-spacing: 0.1em; text-transform: uppercase;
        padding: 0.82rem 1.9rem; text-decoration: none; transition: border-color 0.2s, color 0.2s;
      }
      .btn-outline-lt:hover { border-color: var(--gold); color: var(--gold-light); }

      /* ── ANNOUNCEMENT BANNER ───────────────────────────── */
      .cs-banner {
        background: var(--gold); padding: 0.75rem 2rem;
        text-align: center; position: sticky; top: 68px; z-index: 90;
      }
      .cs-banner p {
        font-family: 'Crimson Pro', serif; font-size: 13px; font-weight: 700;
        letter-spacing: 0.18em; text-transform: uppercase; color: var(--navy);
        display: flex; align-items: center; justify-content: center; gap: 0.8rem;
      }
      .cs-banner p::before, .cs-banner p::after { content: '·'; font-size: 18px; opacity: 0.5; }

      /* ── HERO ──────────────────────────────────────────── */
      .hero {
        background: var(--navy);
        padding: 6rem 2rem 5rem;
        position: relative; overflow: hidden;
      }
      .hero::before {
        content: 'نهج'; font-family: 'Amiri', serif;
        font-size: clamp(120px, 22vw, 220px); font-weight: 700;
        color: rgba(255,255,255,0.03);
        position: absolute; right: -1rem; top: 50%;
        transform: translateY(-50%);
        line-height: 1; pointer-events: none; user-select: none;
      }
      .hero-inner {
        max-width: 1120px; margin: 0 auto;
        position: relative; z-index: 1;
        display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 5rem; align-items: end;
      }

      /* Breadcrumb */
      .bc {
        font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
        color: rgba(255,255,255,0.32); margin-bottom: 2rem;
        display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
      }
      .bc a { color: rgba(255,255,255,0.32); text-decoration: none; transition: color 0.2s; }
      .bc a:hover { color: var(--gold); }
      .bc span { color: rgba(255,255,255,0.14); }

      /* Journal title block */
      .jm-pre {
        font-size: 11px; font-weight: 700; letter-spacing: 0.26em;
        text-transform: uppercase; color: var(--gold);
        display: block; margin-bottom: 0.5rem;
        font-family: 'Crimson Pro', serif;
      }
      .journal-mark h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(52px, 6vw, 72px);
        font-weight: 600; color: var(--white); line-height: 1.0; letter-spacing: -0.01em;
      }
      .journal-mark h1 em { font-style: italic; color: var(--gold-light); }
      .jm-full {
        font-family: 'Cormorant Garamond', serif;
        font-size: 20px; font-weight: 300; font-style: italic;
        color: rgba(255,255,255,0.45); margin-top: 0.6rem; display: block;
      }
      .jm-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.25rem; }
      .jtag {
        font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
        border: 1px solid rgba(200,162,82,0.35); color: rgba(200,162,82,0.78);
        padding: 0.28rem 0.65rem;
      }

      /* Hero right column */
      .hero-desc {
        font-size: 17px; color: rgba(255,255,255,0.62);
        line-height: 1.82; font-weight: 300; margin-bottom: 2rem;
      }

      /* Key facts table */
      .spec-list { border-top: 1px solid rgba(255,255,255,0.08); }
      .spec-item {
        display: flex; justify-content: space-between;
        align-items: baseline; padding: 0.65rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.06); gap: 1rem;
      }
      .sk { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.30); flex-shrink: 0; }
      .sv { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 500; color: var(--gold-light); text-align: right; line-height: 1.35; }
      .hero-btns { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 2rem; }

      /* ── SECTION NAV ───────────────────────────────────── */
      .snav { background: var(--navy); border-top: 1px solid rgba(255,255,255,0.06); }
      .snav-inner { max-width: 1120px; margin: 0 auto; display: flex; overflow-x: auto; scrollbar-width: none; }
      .snav-inner::-webkit-scrollbar { display: none; }
      .snav-a {
        font-family: 'Crimson Pro', serif; font-size: 12px; font-weight: 700;
        letter-spacing: 0.14em; text-transform: uppercase;
        color: rgba(255,255,255,0.42); padding: 1.1rem 1.35rem;
        text-decoration: none; border-bottom: 2px solid transparent;
        white-space: nowrap; transition: color 0.2s, border-color 0.2s;
      }
      .snav-a:hover { color: rgba(255,255,255,0.82); border-bottom-color: rgba(200,162,82,0.45); }

      /* ── SECTION LAYOUT (shared by Aims, Guidelines, Ethics) ── */
      .sec-layout {
        max-width: 1120px; margin: 0 auto;
        display: grid; grid-template-columns: 280px 1fr; gap: 5rem; align-items: start;
      }
      .sec-label-col { position: sticky; top: 5rem; }
      .sec-label-col h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 30px; font-weight: 600; color: var(--navy);
        line-height: 1.1; margin-top: 0.4rem;
      }
      .sec-label-col p {
        font-size: 16px; color: var(--muted); line-height: 1.78;
        font-weight: 300; margin-top: 0.85rem;
      }

      /* ── AIMS & SCOPE ──────────────────────────────────── */
      .s-aims { padding: 5.5rem 2rem; background: var(--cream); }
      .scope-body p {
        font-size: 18px; color: var(--charcoal);
        line-height: 1.88; font-weight: 300; margin-bottom: 1.4rem;
      }
      .scope-body p:last-child { margin-bottom: 0; }
      .pull-quote {
        border-left: 3px solid var(--gold);
        padding: 1.25rem 1.75rem; margin: 2rem 0;
        background: var(--cream-dark);
      }
      .pull-quote p {
        font-family: 'Cormorant Garamond', serif;
        font-size: 22px; font-weight: 500; font-style: italic;
        color: var(--navy); line-height: 1.52; margin: 0;
      }

      /* ── THEMATIC PILLARS ──────────────────────────────── */
      .s-pillars { padding: 5.5rem 2rem; background: var(--cream-dark); }
      .pillars-hdr {
        max-width: 1120px; margin: 0 auto 3rem;
        display: grid; grid-template-columns: 280px 1fr; gap: 5rem; align-items: start;
      }
      .pillars-hdr-left { position: sticky; top: 5rem; }
      .pillars-hdr-left h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 30px; font-weight: 600; color: var(--navy);
        line-height: 1.1; margin-top: 0.4rem;
      }
      .pillars-hdr-left p {
        font-size: 16px; color: var(--muted); line-height: 1.78;
        font-weight: 300; margin-top: 0.85rem;
      }
      .pillars-accordion { max-width: 1120px; margin: 0 auto; }

      /* Pillar accordion — inviting, obvious expand affordance */
      .pillar-item {
        background: var(--cream);
        border: 1px solid rgba(0,0,0,0.07);
        margin-bottom: 3px;
        overflow: hidden;
        transition: box-shadow 0.2s;
      }
      .pillar-item:hover { box-shadow: 0 2px 12px rgba(12,27,46,0.08); }

      .pillar-trigger {
        width: 100%; background: none; border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.6rem 2rem; text-align: left; gap: 1.5rem;
        font-family: inherit;
        transition: background 0.18s;
      }
      .pillar-trigger:hover { background: rgba(200,162,82,0.06); }
      .pillar-trigger[aria-expanded="true"] { background: var(--white); border-bottom: 1px solid var(--cream-dark); }

      .pillar-trigger-left { flex: 1; min-width: 0; }
      .pillar-num {
        font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--gold);
        display: block; margin-bottom: 0.3rem;
        font-family: 'Crimson Pro', serif;
      }
      .pillar-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 22px; font-weight: 600; color: var(--navy);
        line-height: 1.2;
      }
      .pillar-summary {
        font-size: 15px; color: var(--muted);
        margin-top: 0.3rem; font-weight: 300;
      }

      /* The expand indicator — large, gold, obvious */
      .pillar-icon {
        width: 40px; height: 40px;
        border: 1px solid var(--gold);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        font-size: 22px; font-weight: 300; color: var(--gold);
        transition: background 0.18s, transform 0.25s;
        line-height: 1;
      }
      .pillar-trigger[aria-expanded="true"] .pillar-icon {
        background: var(--gold); color: var(--white);
        transform: rotate(45deg);
      }

      /* Collapsible body */
      .pillar-body {
        display: none;
        padding: 1.75rem 2rem 2rem;
        background: var(--white);
      }
      .pillar-body.open { display: block; }
      .pillar-desc {
        font-size: 17px; color: var(--charcoal);
        line-height: 1.85; font-weight: 300; margin-bottom: 1.25rem;
      }
      .pillar-list { list-style: none; padding: 0; border-top: 1px solid var(--cream-dark); padding-top: 1rem; }
      .pillar-list li {
        font-size: 16px; color: var(--charcoal);
        padding: 0.28rem 0 0.28rem 1.2rem;
        position: relative; line-height: 1.65;
      }
      .pillar-list li::before {
        content: '';
        width: 5px; height: 5px; border-radius: 50%;
        background: rgba(200,162,82,0.55);
        position: absolute; left: 0; top: 0.68rem;
      }

      /* ── EDITORIAL BOARD ───────────────────────────────── */
      .s-gov { background: var(--navy); padding: 5.5rem 2rem; position: relative; overflow: hidden; }
      .s-gov::before {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(ellipse 55% 80% at 80% 40%, rgba(27,94,111,0.28) 0%, transparent 65%);
        pointer-events: none;
      }
      .gov-inner { max-width: 1120px; margin: 0 auto; position: relative; z-index: 1; }
      .gov-top {
        display: grid; grid-template-columns: 1fr 1fr; gap: 5rem;
        align-items: start; margin-bottom: 4rem;
      }
      .gov-top h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 30px; font-weight: 600; color: var(--white);
        margin-top: 0.4rem; line-height: 1.1;
      }
      .gov-top p {
        font-size: 17px; color: rgba(255,255,255,0.62);
        font-weight: 300; line-height: 1.82; margin-top: 0.85rem;
      }
      .gov-roles { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0; }
      .gr { padding: 1.5rem 1.75rem; border: 1px solid rgba(255,255,255,0.06); transition: background 0.2s; }
      .gr:hover { background: rgba(255,255,255,0.03); }
      .gr-label {
        font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--gold);
        display: block; margin-bottom: 0.5rem; font-family: 'Crimson Pro', serif;
      }
      .gr-name { font-size: 17px; font-weight: 600; color: var(--white); margin-bottom: 0.2rem; font-family: 'Crimson Pro', serif; }
      .gr-affil { font-size: 14px; color: rgba(255,255,255,0.38); line-height: 1.45; }
      .gov-note { margin-top: 2.5rem; font-size: 15px; color: rgba(255,255,255,0.28); font-style: italic; font-weight: 300; }

      /* ── AUTHOR GUIDELINES ─────────────────────────────── */
      .s-guidelines { padding: 5.5rem 2rem; background: var(--cream); }

      /* Details/summary accordion — matches pillar visual language */
      details { border-bottom: 1px solid var(--cream-dark); }
      details:first-of-type { border-top: 1px solid var(--cream-dark); }
      summary {
        font-family: 'Cormorant Garamond', serif;
        font-size: 20px; font-weight: 600; color: var(--navy);
        padding: 1.15rem 0; cursor: pointer;
        display: flex; justify-content: space-between; align-items: center;
        list-style: none; transition: color 0.2s; gap: 1rem;
      }
      summary::-webkit-details-marker { display: none; }
      summary:hover { color: var(--teal); }
      summary::after {
        content: '+';
        font-size: 24px; font-weight: 300; color: var(--gold);
        flex-shrink: 0; transition: transform 0.22s;
        width: 32px; height: 32px;
        border: 1px solid rgba(200,162,82,0.35);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        line-height: 1;
      }
      details[open] summary::after { transform: rotate(45deg); background: var(--gold); color: var(--white); }
      .details-body { padding-bottom: 1.5rem; padding-top: 0.25rem; }
      .details-body p {
        font-size: 17px; color: var(--charcoal);
        line-height: 1.85; font-weight: 300; margin-bottom: 0.9rem;
      }
      .details-body p:last-child { margin-bottom: 0; }
      .details-body ul { list-style: none; padding: 0; }
      .details-body ul li {
        font-size: 17px; color: var(--charcoal);
        padding: 0.28rem 0 0.28rem 1.3rem;
        position: relative; line-height: 1.65;
      }
      .details-body ul li::before {
        content: '';
        width: 5px; height: 5px; border-radius: 50%;
        background: rgba(107,107,107,0.38);
        position: absolute; left: 0; top: 0.7rem;
      }

      /* ── PUBLICATION ETHICS ────────────────────────────── */
      .s-ethics { background: var(--cream-dark); padding: 5.5rem 2rem; }
      .ethics-list { display: flex; flex-direction: column; border-top: 1px solid rgba(0,0,0,0.07); }
      .ep {
        padding: 1.5rem 0; border-bottom: 1px solid rgba(0,0,0,0.07);
        display: grid; grid-template-columns: 3rem 1fr; gap: 1rem; align-items: start;
      }
      .ep-num {
        font-size: 12px; font-weight: 700; letter-spacing: 0.15em;
        color: var(--gold); padding-top: 0.2rem; text-transform: uppercase;
        font-family: 'Crimson Pro', serif;
      }
      .ep-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 20px; font-weight: 600; color: var(--navy); margin-bottom: 0.4rem;
      }
      .ep-body { font-size: 17px; color: var(--charcoal); line-height: 1.85; font-weight: 300; }

      /* ── OPEN ROLES ────────────────────────────────────── */
      .s-roles { background: var(--navy); padding: 5.5rem 2rem; position: relative; overflow: hidden; }
      .s-roles::before {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 70% at 15% 60%, rgba(27,94,111,0.25) 0%, transparent 65%);
        pointer-events: none;
      }
      .roles-inner { max-width: 1120px; margin: 0 auto; position: relative; z-index: 1; }
      .roles-hdr { text-align: center; margin-bottom: 3.5rem; }
      .roles-hdr h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(26px, 3.5vw, 38px); font-weight: 600;
        color: var(--white); margin-top: 0.4rem; line-height: 1.08;
      }
      .roles-hdr p { font-size: 17px; color: rgba(255,255,255,0.55); font-weight: 300; max-width: 620px; margin: 0.85rem auto 0; line-height: 1.82; }
      .roles-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; background: rgba(255,255,255,0.04); }
      .role-card {
        background: var(--navy); padding: 2.5rem 2.25rem;
        display: flex; flex-direction: column;
        border: 1px solid rgba(255,255,255,0.055);
        transition: background 0.2s, border-color 0.2s;
      }
      .role-card:hover { background: rgba(255,255,255,0.03); border-color: rgba(200,162,82,0.2); }
      .role-label {
        font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--gold);
        display: block; margin-bottom: 0.6rem; font-family: 'Crimson Pro', serif;
      }
      .role-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 24px; font-weight: 600; color: var(--white); margin-bottom: 0.85rem; line-height: 1.15;
      }
      .role-desc { font-size: 17px; color: rgba(255,255,255,0.60); line-height: 1.82; font-weight: 300; flex: 1; margin-bottom: 1.75rem; }
      .role-reqs { list-style: none; padding: 0; margin-bottom: 1.75rem; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1rem; }
      .role-reqs li {
        font-size: 16px; color: rgba(255,255,255,0.50);
        padding: 0.25rem 0 0.25rem 1.1rem; position: relative; line-height: 1.65;
      }
      .role-reqs li::before {
        content: ''; width: 4px; height: 4px; border-radius: 50%;
        background: rgba(200,162,82,0.5);
        position: absolute; left: 0; top: 0.72rem;
      }
      .role-cta { margin-top: auto; }

      /* ── SUBMIT CTA ────────────────────────────────────── */
      .s-submit { padding: 6rem 2rem; background: var(--cream); text-align: center; border-top: 1px solid var(--cream-dark); }
      .s-submit h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(24px, 3vw, 34px); font-weight: 600;
        color: var(--navy); margin-top: 0.4rem; margin-bottom: 1rem; line-height: 1.1;
      }
      .s-submit p { font-size: 17px; color: var(--muted); max-width: 540px; margin: 0 auto 2.25rem; font-weight: 300; line-height: 1.82; }
      .submit-btns { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }

      /* ── RESPONSIVE ────────────────────────────────────── */
      @media (max-width: 960px) {
        .hero-inner, .sec-layout, .gov-top, .pillars-hdr { grid-template-columns: 1fr; gap: 2.5rem; }
        .roles-grid { grid-template-columns: 1fr; }
        .sec-label-col, .pillars-hdr-left { position: static; }
        .snav-inner { padding: 0 1.5rem; }
      }
      @media (max-width: 768px) {
        .hero { padding: 4.5rem 1.5rem 3.5rem; }
        .ep { grid-template-columns: 2rem 1fr; }
        .pillar-trigger { padding: 1.25rem 1.25rem; }
        .pillar-body { padding: 1.25rem 1.25rem 1.5rem; }
      }
    </style>
  </head>
  <body>
    <Header />

    <div class="cs-banner">
      <p>Inaugural Issue Open for Submissions. Volume I, Spring 2026</p>
    </div>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <div>
          <nav class="bc">
            <a href={`${base}/`}>Home</a>
            <span>/</span>
            <span style="color:rgba(255,255,255,0.58)">Nahj Journal</span>
          </nav>
          <div class="journal-mark">
            <span class="jm-pre">A Publication of Nahj Institute</span>
            <h1><em>NAHJ</em></h1>
            <span class="jm-full">The Journal of Transdisciplinary Theory</span>
            <div class="jm-tags">
              <span class="jtag">Peer-Reviewed</span>
              <span class="jtag">Diamond Open Access</span>
              <span class="jtag">Twice Yearly</span>
              <span class="jtag">Double-Blind Review</span>
            </div>
          </div>
        </div>

        <div>
          <p class="hero-desc">NAHJ is an international, peer-reviewed journal providing a global platform where traditional wisdom, critical social theory, and modern scientific inquiry intersect. All content is freely and permanently available online at no cost to authors or readers.</p>
          <div class="spec-list">
            <div class="spec-item"><span class="sk">Full Title</span><span class="sv">NAHJ: Journal of Transdisciplinary Theory</span></div>
            <div class="spec-item"><span class="sk">ISSN</span><span class="sv">Forthcoming on registration</span></div>
            <div class="spec-item"><span class="sk">Frequency</span><span class="sv">Spring and Autumn annually</span></div>
            <div class="spec-item"><span class="sk">Access Model</span><span class="sv">Diamond Open Access. No APCs.</span></div>
            <div class="spec-item"><span class="sk">Review Process</span><span class="sv">Double-blind peer review</span></div>
            <div class="spec-item"><span class="sk">Licence</span><span class="sv">CC BY 4.0 International</span></div>
            <div class="spec-item"><span class="sk">Inaugural Issue</span><span class="sv">Spring 2026</span></div>
          </div>
          <div class="hero-btns">
            <a href={`${base}/journal/submit`} class="btn-gold">Submit a Manuscript</a>
            <a href="#aims" class="btn-outline-lt">Aims &amp; Scope</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION NAV -->
    <nav class="snav">
      <div class="snav-inner">
        <a href="#aims"      class="snav-a">Aims &amp; Scope</a>
        <a href="#pillars"   class="snav-a">Thematic Pillars</a>
        <a href="#board"     class="snav-a">Editorial Board</a>
        <a href="#guidelines" class="snav-a">Author Guidelines</a>
        <a href="#ethics"    class="snav-a">Publication Ethics</a>
        <a href="#roles"     class="snav-a">Open Roles</a>
        <a href={`${base}/journal/submit`} class="snav-a" style="color:var(--gold);border-bottom-color:var(--gold)">Submit →</a>
      </div>
    </nav>

    <main>

      <!-- 01 AIMS & SCOPE -->
      <section class="s-aims" id="aims">
        <div class="sec-layout container">
          <div class="sec-label-col">
            <span class="section-label">01</span>
            <div class="gold-rule"></div>
            <h2>Aims &amp; Scope</h2>
          </div>
          <div class="scope-body">
            <p>NAHJ is an international, peer-reviewed, Diamond Open Access journal dedicated to the rigorous investigation of the human condition through transdisciplinary theory. We provide a global platform where traditional wisdom, critical social theory, and modern scientific inquiry intersect. The journal is defined not by a single discipline or methodology, but by a set of shared questions: about the human person, about the character of knowledge and its limits, about the relationship between classical intellectual traditions and modernity, and about the obligations of scholarship to the societies it addresses.</p>

            <div class="pull-quote">
              <p>NAHJ welcomes original research that is distinguished by analytical rigour, depth of engagement with primary sources, and the capacity to speak across disciplinary boundaries.</p>
            </div>

            <p>The journal publishes original research articles, review essays, and critical responses. It does not publish polemical writing, institutional advocacy, or work whose primary purpose is the promotion of a particular ideological position. The standard applied to all submissions is that of a serious international peer-reviewed journal in the humanities and social sciences. Authors are expected to engage with the relevant secondary literature, to ground their arguments in evidence, and to write for an audience beyond their own specialism.</p>

            <p>NAHJ is committed to the principle that knowledge does not respect disciplinary boundaries. The most significant questions about human life (questions of consciousness, authority, justice, meaning, and social organisation) require the resources of multiple traditions of inquiry. The journal therefore solicits work that crosses the boundaries between the humanities, the social sciences, the natural sciences, and classical scholarship, subject always to the requirement that the scholarship is rigorous and the argument is clear.</p>

            <p>The journal operates on a Diamond Open Access model. No article processing charges are levied at any stage. All published content is freely available in perpetuity under a Creative Commons Attribution 4.0 International licence. Authors retain full copyright. NAHJ regards open access not as a concession but as an ethical obligation of scholarly publication.</p>
          </div>
        </div>
      </section>

      <!-- 02 THEMATIC PILLARS -->
      <section class="s-pillars" id="pillars">
        <div class="pillars-hdr container">
          <div class="pillars-hdr-left">
            <span class="section-label">02</span>
            <div class="gold-rule"></div>
            <h2>Thematic Pillars</h2>
            <p>NAHJ is organised around three broad thematic areas. Submissions may fall within one pillar or engage productively across two or more.</p>
          </div>
          <div style="padding-top:0.25rem; color: var(--muted); font-size:15px; font-weight:300; line-height:1.75;">
            The pillars are defined by the questions they address, not by method or discipline. Select a pillar to see its scope and representative topics.
          </div>
        </div>
        <div class="pillars-accordion container">

          <div class="pillar-item">
            <button class="pillar-trigger" aria-expanded="false" data-target="pillar-1">
              <div class="pillar-trigger-left">
                <span class="pillar-num">Pillar 01</span>
                <div class="pillar-title">Cultural &amp; Historical Studies</div>
                <div class="pillar-summary">Intellectual movements, historical formations, and civilisational artefacts</div>
              </div>
              <div class="pillar-icon">+</div>
            </button>
            <div class="pillar-body" id="pillar-1">
              <p class="pillar-desc">Research examining the artefacts, intellectual movements, and historical formations that have constituted global civilisations. The pillar gives equal standing to historians, literary scholars, art historians, and philologists as it does to political theorists and social scientists.</p>
              <ul class="pillar-list">
                <li>Intellectual history: genealogy of ideas across traditions and borders</li>
                <li>Material culture: manuscripts, architecture, and art as intellectual sources</li>
                <li>Literature and narrative theory: classical texts and the formation of identity</li>
                <li>Comparative civilisational studies and cross-cultural transmission</li>
                <li>Historiography, memory, and the ethics of historical interpretation</li>
              </ul>
            </div>
          </div>

          <div class="pillar-item">
            <button class="pillar-trigger" aria-expanded="false" data-target="pillar-2">
              <div class="pillar-trigger-left">
                <span class="pillar-num">Pillar 02</span>
                <div class="pillar-title">Neuro-Humanities &amp; Cognitive Theory</div>
                <div class="pillar-summary">Mind, consciousness, selfhood, and the boundaries of biological and cultural inquiry</div>
              </div>
              <div class="pillar-icon">+</div>
            </button>
            <div class="pillar-body" id="pillar-2">
              <p class="pillar-desc">Scholarship that bridges biological inquiry and philosophical reflection on the nature of mind, selfhood, and moral agency. The pillar resists the reduction of the human person to either purely biological or purely cultural terms.</p>
              <ul class="pillar-list">
                <li>Philosophy of mind and consciousness: classical and contemporary accounts</li>
                <li>Neuroscience and the humanities: methodological and interpretive questions</li>
                <li>The ethics of cognitive and neurological enhancement</li>
                <li>Mental health, social environment, and the phenomenology of wellbeing</li>
                <li>Embodied cognition and its implications for social and moral theory</li>
              </ul>
            </div>
          </div>

          <div class="pillar-item">
            <button class="pillar-trigger" aria-expanded="false" data-target="pillar-3">
              <div class="pillar-trigger-left">
                <span class="pillar-num">Pillar 03</span>
                <div class="pillar-title">Critical Modernity &amp; Social Dynamics</div>
                <div class="pillar-summary">Contemporary global structures through decolonial and non-secular frameworks</div>
              </div>
              <div class="pillar-icon">+</div>
            </button>
            <div class="pillar-body" id="pillar-3">
              <p class="pillar-desc">Critical investigation of contemporary global structures using theoretical resources drawn from both Western and non-Western intellectual traditions. The pillar foregrounds decolonial and non-secular epistemologies as primary analytical frameworks rather than objects of study.</p>
              <ul class="pillar-list">
                <li>Ethical governance and the resources of classical political theory</li>
                <li>Technology, artificial intelligence, and post-humanist critique</li>
                <li>Decolonial epistemology and the recovery of non-Western intellectual heritage</li>
                <li>Religion, secularism, and the contested boundaries of the public sphere</li>
                <li>Global justice, migration, and the political philosophy of belonging</li>
              </ul>
            </div>
          </div>

        </div>
      </section>

      <!-- 03 EDITORIAL BOARD -->
      <section class="s-gov" id="board">
        <div class="gov-inner">
          <div class="gov-top">
            <div>
              <span class="section-label" style="color:var(--gold)">03</span>
              <div class="gold-rule"></div>
              <h2>Editorial Board</h2>
              <p>The journal is governed by an international editorial board drawn from academic institutions across disciplines and regions. Board appointments are in progress ahead of the inaugural issue. Scholars interested in joining the editorial or international advisory board are welcome to apply through the Open Roles section below.</p>
            </div>
            <div>
              <div class="spec-list">
                <div class="spec-item"><span class="sk">Review Model</span><span class="sv">Double-blind</span></div>
                <div class="spec-item"><span class="sk">Decision Timeline</span><span class="sv">10–14 weeks from submission</span></div>
                <div class="spec-item"><span class="sk">Ethics Framework</span><span class="sv">COPE compliant</span></div>
                <div class="spec-item"><span class="sk">Indexing Target</span><span class="sv">DOAJ, Scopus, Google Scholar</span></div>
              </div>
            </div>
          </div>
          <div class="gov-roles">
            <div class="gr"><span class="gr-label">Editor-in-Chief</span><div class="gr-name">Appointment in progress</div><div class="gr-affil">Nahj Institute</div></div>
            <div class="gr"><span class="gr-label">Managing Editor</span><div class="gr-name">Appointment in progress</div><div class="gr-affil">Nahj Institute</div></div>
            <div class="gr"><span class="gr-label">Associate Editor, Cultural Studies</span><div class="gr-name">Appointment in progress</div><div class="gr-affil">Nahj Institute</div></div>
            <div class="gr"><span class="gr-label">Associate Editor, Cognitive Theory</span><div class="gr-name">Appointment in progress</div><div class="gr-affil">Nahj Institute</div></div>
            <div class="gr"><span class="gr-label">Associate Editor, Critical Modernity</span><div class="gr-name">Appointment in progress</div><div class="gr-affil">Nahj Institute</div></div>
            <div class="gr"><span class="gr-label">International Advisory Board</span><div class="gr-name">Multiple appointments in progress</div><div class="gr-affil">Global institutions</div></div>
          </div>
          <p class="gov-note">NAHJ is committed to a geographically and institutionally diverse editorial board that reflects the international scope of the journal's intellectual programme.</p>
        </div>
      </section>

      <!-- 04 AUTHOR GUIDELINES -->
      <section class="s-guidelines" id="guidelines">
        <div class="sec-layout container">
          <div class="sec-label-col">
            <span class="section-label">04</span>
            <div class="gold-rule"></div>
            <h2>Author Guidelines</h2>
            <p>Authors are advised to read the full guidelines before preparing a submission. Papers that do not conform to these requirements will be returned without review.</p>
            <div style="margin-top:2rem;">
              <a href={`${base}/journal/submit`} class="btn-navy">Submit a Manuscript</a>
            </div>
          </div>
          <div>
            <details open>
              <summary>Manuscript Specifications</summary>
              <div class="details-body">
                <ul>
                  <li>Research articles: 6,000 to 10,000 words inclusive of notes and bibliography</li>
                  <li>Review essays: 3,000 to 6,000 words</li>
                  <li>Abstract: 150 to 200 words; no citations; no discipline-specific abbreviations</li>
                  <li>Keywords: 5 to 8 terms selected for indexing purposes</li>
                  <li>File format: Microsoft Word (.docx); do not submit PDF</li>
                  <li>Typography: 12pt Times New Roman, double-spaced, 2.5cm margins throughout</li>
                  <li>Line and page numbering must be activated for reviewer reference</li>
                </ul>
              </div>
            </details>
            <details>
              <summary>Anonymisation for Peer Review</summary>
              <div class="details-body">
                <p>The journal operates a strictly double-blind peer review process. Authors must remove all identifying information from the manuscript file before submission. This includes: name, affiliation, and acknowledgements in the document text and file metadata; self-citations that would identify the author; grant references that name the author or institution. The author's biographical note and affiliation are submitted separately through the submission form and are withheld from reviewers.</p>
              </div>
            </details>
            <details>
              <summary>Referencing and Style</summary>
              <div class="details-body">
                <ul>
                  <li>Chicago author-date throughout; footnotes for discursive notes only, not citations</li>
                  <li>Arabic transliteration following IJMES conventions; diacritical marks required</li>
                  <li>Persian, Urdu, and other scripts: authors should consult the relevant transliteration conventions and note their choice in a covering letter</li>
                  <li>Foreign-language terms in italics on first use; not subsequently</li>
                  <li>Qur'anic references: surah and verse number, with translation acknowledged</li>
                  <li>Full bibliography in Chicago format at end of manuscript</li>
                </ul>
              </div>
            </details>
            <details>
              <summary>Peer Review Process and Timeline</summary>
              <div class="details-body">
                <p>All submissions undergo an initial editorial assessment for scope, methodological rigour, and basic compliance with the guidelines. Manuscripts that pass initial assessment are sent to two independent expert referees. The review is double-blind. Authors receive one of four decisions: accept, minor revisions, major revisions, or reject. Authors typically receive a decision within ten to fourteen weeks of submission acknowledgement. Revise-and-resubmit decisions include detailed editorial guidance and referee reports.</p>
              </div>
            </details>
            <details>
              <summary>Copyright, Licensing, and Proofs</summary>
              <div class="details-body">
                <p>Authors retain copyright of their work. NAHJ publishes all content under a Creative Commons Attribution 4.0 International licence (CC BY 4.0), which permits reproduction, distribution, and adaptation provided the original source is credited. No article processing charges are levied at any stage, from submission to publication. Accepted articles are assigned a DOI through Crossref. Authors receive a PDF proof for approval before publication. Substantial changes to the text at proof stage are not permitted.</p>
              </div>
            </details>
            <details>
              <summary>Indexing and Discoverability</summary>
              <div class="details-body">
                <p>NAHJ is preparing applications to DOAJ, Google Scholar, Scopus, and EBSCO from the inaugural issue. All published articles are assigned DOIs and prepared in JATS XML format by the editorial team to support metadata harvesting and indexing. Authors who have ORCID identifiers are invited to include them in their submission.</p>
              </div>
            </details>
          </div>
        </div>
      </section>

      <!-- 05 PUBLICATION ETHICS -->
      <section class="s-ethics" id="ethics">
        <div class="sec-layout container">
          <div class="sec-label-col">
            <span class="section-label">05</span>
            <div class="gold-rule"></div>
            <h2>Publication Ethics</h2>
            <p>NAHJ adheres fully to the guidelines established by the Committee on Publication Ethics (COPE). The principles below govern the obligations of authors, reviewers, and editors at every stage of the publication process.</p>
          </div>
          <div class="ethics-list">
            <div class="ep"><span class="ep-num">01</span><div><div class="ep-title">Originality and Prior Publication</div><p class="ep-body">Submitted manuscripts must be original work not previously published in any form, including as a working paper, thesis chapter, or conference proceedings, and must not be under consideration elsewhere. All submissions are screened using similarity-detection software. Redundant or duplicate publication is grounds for immediate rejection and, where applicable, notification of the author's institution.</p></div></div>
            <div class="ep"><span class="ep-num">02</span><div><div class="ep-title">Authorship and Contributorship</div><p class="ep-body">All named authors must have made a substantive and verifiable intellectual contribution to the conception, execution, or critical revision of the work. The corresponding author is responsible for ensuring the accuracy of the authorship list and for obtaining the agreement of all listed authors to the submission. Honorary authorship and the omission of contributing authors are equally contrary to these guidelines.</p></div></div>
            <div class="ep"><span class="ep-num">03</span><div><div class="ep-title">Disclosure of Funding and Conflicts of Interest</div><p class="ep-body">Authors must disclose, in a covering letter withheld from reviewers, all sources of funding for the research presented and any financial or personal relationship that could reasonably be understood to influence the objectivity of the analysis. Reviewers and editors must declare conflicts of interest before accepting review or editorial responsibilities.</p></div></div>
            <div class="ep"><span class="ep-num">04</span><div><div class="ep-title">Accuracy of Data and Sources</div><p class="ep-body">Authors bear sole responsibility for the accuracy of all empirical data, citations, and attributions in their manuscripts. The fabrication, falsification, or selective reporting of evidence constitutes research misconduct and will be reported to the author's institution where the editor concludes, on the balance of evidence, that misconduct has occurred.</p></div></div>
            <div class="ep"><span class="ep-num">05</span><div><div class="ep-title">Reviewer Responsibilities</div><p class="ep-body">Reviewers are expected to deliver expert, objective, and constructive assessments within the agreed timeline. Reviewers must maintain the strict confidentiality of all manuscripts under review and must not use unpublished material for their own purposes without the explicit written consent of the author.</p></div></div>
            <div class="ep"><span class="ep-num">06</span><div><div class="ep-title">Corrections, Retractions, and Appeals</div><p class="ep-body">Errors identified after publication are corrected promptly and with full transparency. In cases of serious ethical breach, the editorial board will issue a formal retraction in accordance with COPE's retraction guidelines. Authors who believe an editorial decision has been reached without adequate consideration may submit a formal written appeal to the editor-in-chief.</p></div></div>
          </div>
        </div>
      </section>

      <!-- 06 OPEN ROLES -->
      <section class="s-roles" id="roles">
        <div class="roles-inner">
          <div class="roles-hdr">
            <span class="section-label" style="color:var(--gold);text-align:center;display:block;">06</span>
            <div class="gold-rule c"></div>
            <h2>Open Roles &amp; Opportunities</h2>
            <p>NAHJ is building its editorial infrastructure ahead of the inaugural issue. We invite applications from qualified scholars for the following positions and opportunities.</p>
          </div>
          <div class="roles-grid">
            <div class="role-card">
              <span class="role-label">Volunteer Role</span>
              <h3 class="role-title">Peer Reviewer</h3>
              <p class="role-desc">Peer reviewers are the foundation of scholarly quality assurance. NAHJ seeks reviewers with active research profiles across all three thematic pillars. Reviewers are invited on a per-submission basis and are not expected to commit to a fixed volume of reviews.</p>
              <ul class="role-reqs">
                <li>Doctoral qualification in a relevant field</li>
                <li>Active publication record at peer-reviewed level</li>
                <li>Capacity to deliver a substantive review within four weeks</li>
                <li>Familiarity with double-blind review conventions</li>
              </ul>
              <div class="role-cta"><a href={`${base}/journal/submit`} class="btn-outline-lt">Apply as Reviewer</a></div>
            </div>
            <div class="role-card">
              <span class="role-label">Board Position</span>
              <h3 class="role-title">Editorial Board Member</h3>
              <p class="role-desc">Editorial board members provide strategic scholarly guidance, assist with reviewer identification, and contribute to the intellectual direction of the journal. The board is international in composition and reflects the full disciplinary scope of the journal's three pillars.</p>
              <ul class="role-reqs">
                <li>Established academic at post-doctoral level</li>
                <li>Recognised publication record in a relevant field</li>
                <li>Commitment to the journal's open access mission</li>
                <li>Availability to review two to four submissions annually</li>
              </ul>
              <div class="role-cta"><a href={`${base}/journal/submit`} class="btn-outline-lt">Apply for Board Membership</a></div>
            </div>
            <div class="role-card">
              <span class="role-label">Editorial Opportunity</span>
              <h3 class="role-title">Guest Editor: Special Issue</h3>
              <p class="role-desc">NAHJ publishes one special issue per volume, thematically focused and guest-edited by specialists in the relevant area. Guest editors are responsible for developing the call for papers, managing the review process, and writing an editorial introduction to the issue.</p>
              <ul class="role-reqs">
                <li>A clearly defined and academically significant theme within the journal's scope</li>
                <li>An established network of potential contributors</li>
                <li>Capacity to manage a complete review cycle over 12 months</li>
                <li>Prior experience of peer review as author or reviewer</li>
              </ul>
              <div class="role-cta"><a href={`${base}/journal/submit`} class="btn-outline-lt">Propose a Special Issue</a></div>
            </div>
            <div class="role-card">
              <span class="role-label">Collaboration</span>
              <h3 class="role-title">Institutional Partnership</h3>
              <p class="role-desc">NAHJ welcomes enquiries from research centres, university departments, and learned societies interested in formal scholarly partnership, co-sponsorship of special issues, or the joint organisation of academic events connected to the journal's thematic programme.</p>
              <ul class="role-reqs">
                <li>Established academic or research institution</li>
                <li>Clear scholarly alignment with the journal's thematic pillars</li>
                <li>Commitment to the journal's Diamond Open Access model</li>
              </ul>
              <div class="role-cta"><a href={`${base}/contact`} class="btn-outline-lt">Enquire About Partnership</a></div>
            </div>
          </div>
        </div>
      </section>

      <!-- SUBMIT CTA -->
      <section class="s-submit">
        <div class="container">
          <span class="section-label" style="display:block;text-align:center;">Submit Your Work</span>
          <div class="gold-rule c"></div>
          <h2>Manuscript Submission Now Open</h2>
          <p>NAHJ is accepting submissions for Volume I. We welcome original research articles and review essays across all three thematic pillars. There are no submission or publication fees.</p>
          <div class="submit-btns">
            <a href={`${base}/journal/submit`} class="btn-navy">Submit a Manuscript</a>
            <a href={`${base}/journal/submit`} class="btn-outline">Apply as Reviewer</a>
          </div>
        </div>
      </section>

    </main>

    <Footer />

    <script>
      // Pillar accordion — JS-controlled for full flexibility (not native <details>)
      document.querySelectorAll('.pillar-trigger').forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          const body     = document.getElementById(targetId);
          const isOpen   = btn.getAttribute('aria-expanded') === 'true';

          // Close all others
          document.querySelectorAll('.pillar-trigger').forEach(b => {
            b.setAttribute('aria-expanded', 'false');
            const id = b.getAttribute('data-target');
            document.getElementById(id)?.classList.remove('open');
          });

          // Toggle this one
          if (!isOpen) {
            btn.setAttribute('aria-expanded', 'true');
            body?.classList.add('open');
          }
        });
      });
    </script>
  </body>
</html>