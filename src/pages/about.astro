---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About — Nahj Institute</title>
    <meta name="description" content="Learn about Nahj Institute — our mission, values, intellectual foundations, and the team behind one of the Muslim world's emerging independent research centres." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <style is:global>
      /* ─── DESIGN TOKENS (identical to index.astro) ────────── */
      :root {
        --navy:        #0C1B2E;
        --teal:        #1B5E6F;
        --teal-light:  #246E82;
        --gold:        #C8A252;
        --gold-light:  #E2BC75;
        --cream:       #F7F2E8;
        --cream-dark:  #EDE6D5;
        --charcoal:    #2B2B2B;
        --muted:       #6B6B6B;
        --white:       #FFFFFF;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: var(--cream);
        color: var(--charcoal);
        font-family: 'Crimson Pro', Georgia, serif;
        font-size: 22px;
        line-height: 1.88;
        -webkit-font-smoothing: antialiased;
      }

      /* ─── UTILITY ─────────────────────────────────────────── */
      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .container--narrow {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .section-label {
        font-family: 'Crimson Pro', serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
      }

      .divider-gold {
        width: 3.5rem;
        height: 2px;
        background: var(--gold);
        margin: 0.9rem 0 1.5rem;
      }

      .divider-gold.center { margin: 0.9rem auto 1.5rem; }

      /* ─── PAGE HERO ───────────────────────────────────────── */
      .page-hero {
        background-color: var(--navy);
        color: var(--white);
        padding: 5.5rem 2rem 4.5rem;
        position: relative;
        overflow: hidden;
      }

      .page-hero::before {
        content: 'نهج';
        font-family: 'Amiri', serif;
        font-size: clamp(12rem, 24vw, 22rem);
        font-weight: 700;
        color: rgba(255,255,255,0.032);
        position: absolute;
        right: -1.5rem;
        top: 50%;
        transform: translateY(-50%);
        line-height: 1;
        pointer-events: none;
        user-select: none;
      }

      .page-hero-inner {
        max-width: 1120px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .breadcrumb {
        font-size: 0.82rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.4);
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .breadcrumb a {
        color: rgba(255,255,255,0.4);
        text-decoration: none;
        transition: color 0.2s;
      }

      .breadcrumb a:hover { color: var(--gold); }
      .breadcrumb span { color: rgba(255,255,255,0.2); }

      .page-hero h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.6rem, 5.5vw, 4.8rem);
        font-weight: 600;
        line-height: 1.07;
        color: var(--white);
        max-width: 780px;
        margin-bottom: 1.5rem;
      }

      .page-hero h1 em {
        font-style: italic;
        color: var(--gold-light);
      }

      .page-hero-sub {
        font-size: 1.24rem;
        color: rgba(255,255,255,0.62);
        max-width: 560px;
        font-weight: 300;
        line-height: 1.92;
      }

      /* ─── MISSION STATEMENT ───────────────────────────────── */
      .section-mission {
        padding: 5.5rem 2rem;
        background: var(--cream);
      }

      .mission-layout {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 5rem;
        align-items: start;
        max-width: 1120px;
        margin: 0 auto;
      }

      .mission-label-col {
        padding-top: 0.3rem;
        position: sticky;
        top: 4rem;
      }

      .mission-label-col h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.6rem;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.1;
        margin-top: 0.5rem;
      }

      .mission-body p {
        font-size: 1.26rem;
        color: var(--charcoal);
        line-height: 1.9;
        margin-bottom: 1.5rem;
        font-weight: 300;
      }

      .mission-body p strong {
        font-weight: 600;
        color: var(--navy);
      }

      .mission-pullquote {
        border-left: 3px solid var(--gold);
        padding: 1rem 0 1rem 2rem;
        margin: 2.5rem 0;
      }

      .mission-pullquote p {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.55rem;
        font-style: italic;
        font-weight: 400;
        color: var(--navy);
        line-height: 1.45;
        margin: 0;
      }

      .mission-pullquote cite {
        display: block;
        margin-top: 0.75rem;
        font-size: 0.82rem;
        font-style: normal;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        font-family: 'Crimson Pro', serif;
      }

      /* ─── OUR STORY ───────────────────────────────────────── */
      .section-story {
        background: var(--navy);
        padding: 5.5rem 2rem;
        position: relative;
        overflow: hidden;
      }

      .section-story::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 80% at 90% 50%, rgba(27,94,111,0.25) 0%, transparent 70%),
          radial-gradient(ellipse 40% 60% at 10% 80%, rgba(200,162,82,0.06) 0%, transparent 70%);
        pointer-events: none;
      }

      .story-inner {
        max-width: 1120px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .story-header {
        margin-bottom: 3.5rem;
      }

      .story-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 600;
        color: var(--white);
        margin-top: 0.5rem;
        max-width: 680px;
        line-height: 1.12;
      }

      .story-header h2 em {
        color: var(--gold-light);
        font-style: italic;
      }

      .story-columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
      }

      .story-columns p {
        font-size: 1.20rem;
        color: rgba(255,255,255,0.7);
        line-height: 1.9;
        font-weight: 300;
        margin-bottom: 1.25rem;
      }

      .story-columns p:last-child { margin-bottom: 0; }

      .story-columns strong {
        color: rgba(255,255,255,0.92);
        font-weight: 500;
      }

      /* ─── VALUES ──────────────────────────────────────────── */
      .section-values {
        padding: 5.5rem 2rem;
        background: var(--cream-dark);
      }

      .values-header {
        text-align: center;
        margin-bottom: 3.5rem;
      }

      .values-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.9rem, 3.8vw, 3rem);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
      }

      .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 2.5rem;
        max-width: 1120px;
        margin: 0 auto;
      }

      .value-item {
        padding: 0;
      }

      .value-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3.5rem;
        font-weight: 300;
        color: var(--cream-dark);
        line-height: 1;
        margin-bottom: -0.5rem;
        /* outline effect */
        -webkit-text-stroke: 1px var(--gold);
        color: transparent;
      }

      .value-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.6rem;
        padding-bottom: 0.6rem;
        border-bottom: 1px solid var(--cream-dark);
      }

      .value-body {
        font-size: 1.12rem;
        color: var(--muted);
        line-height: 1.72;
      }

      /* ─── FOCUS AREAS ─────────────────────────────────────── */
      .section-focus {
        padding: 5.5rem 2rem;
        background: var(--cream);
      }

      .focus-header {
        max-width: 1120px;
        margin: 0 auto 3.5rem;
      }

      .focus-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.9rem, 3.8vw, 3rem);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
        max-width: 520px;
      }

      .focus-list {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 0;
      }

      .focus-item {
        padding: 2rem 1.75rem;
        border: 1px solid var(--cream-dark);
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
        transition: background 0.2s ease;
      }

      .focus-item:hover {
        background: var(--white);
      }

      .focus-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.20rem;
        font-weight: 600;
        color: var(--gold);
        flex-shrink: 0;
        padding-top: 0.1rem;
      }

      .focus-text h4 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.35rem;
      }

      .focus-text p {
        font-size: 1.26rem;
        color: var(--muted);
        line-height: 1.80;
      }

      /* ─── TEAM ────────────────────────────────────────────── */
      .section-team {
        background: var(--cream-dark);
        padding: 5.5rem 2rem;
      }

      .team-header {
        text-align: center;
        margin-bottom: 3.5rem;
      }

      .team-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.9rem, 3.8vw, 3rem);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
      }

      .team-header p {
        font-size: 1.16rem;
        color: var(--muted);
        max-width: 500px;
        margin: 0 auto;
        font-weight: 300;
      }

      .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 2rem;
        max-width: 1120px;
        margin: 0 auto;
      }

      .team-card {
        background: var(--white);
        padding: 2rem 1.75rem;
        border-top: 3px solid var(--cream-dark);
        transition: border-color 0.25s ease;
      }

      .team-card:hover {
        border-color: var(--gold);
      }

      .team-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: var(--navy);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--gold);
        flex-shrink: 0;
      }

      .team-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.25rem;
      }

      .team-role {
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--teal);
        margin-bottom: 0.75rem;
      }

      .team-bio {
        font-size: 1.26rem;
        color: var(--muted);
        line-height: 1.80;
      }

      /* ─── VISITOR GUIDE ───────────────────────────────────── */
      .section-guide {
        background: var(--navy);
        padding: 5.5rem 2rem;
        position: relative;
        overflow: hidden;
      }

      .section-guide::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 50% 70% at 80% 40%, rgba(200,162,82,0.07) 0%, transparent 70%);
        pointer-events: none;
      }

      .guide-inner {
        max-width: 1120px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .guide-header {
        margin-bottom: 3.5rem;
      }

      .guide-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.9rem, 3.8vw, 3rem);
        font-weight: 600;
        color: var(--white);
        margin-top: 0.5rem;
        max-width: 600px;
        line-height: 1.1;
      }

      .guide-header h2 em {
        color: var(--gold-light);
        font-style: italic;
      }

      .guide-steps {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 0;
      }

      .guide-step {
        padding: 2.25rem 2rem;
        border: 1px solid rgba(255,255,255,0.07);
        position: relative;
      }

      .guide-step:hover {
        background: rgba(255,255,255,0.03);
      }

      .guide-step-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        color: var(--gold);
        margin-bottom: 1rem;
        text-transform: uppercase;
      }

      .guide-step h4 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--white);
        margin-bottom: 0.6rem;
        line-height: 1.2;
      }

      .guide-step p {
        font-size: 1.10rem;
        color: rgba(255,255,255,0.58);
        line-height: 1.92;
        margin-bottom: 1rem;
      }

      .guide-step a {
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--gold);
        text-decoration: none;
        transition: color 0.2s;
      }

      .guide-step a:hover { color: var(--gold-light); }

      /* ─── CLOSING CTA ─────────────────────────────────────── */
      .section-cta {
        background: var(--cream);
        padding: 5rem 2rem;
        text-align: center;
        border-top: 1px solid var(--cream-dark);
      }

      .section-cta h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.8rem, 3.5vw, 2.8rem);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
        margin-bottom: 1rem;
        line-height: 1.15;
      }

      .section-cta p {
        font-size: 1.20rem;
        color: var(--muted);
        max-width: 520px;
        margin: 0 auto 2.25rem;
        font-weight: 300;
        line-height: 1.90;
      }

      .cta-buttons {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .btn-primary {
        display: inline-block;
        background: var(--gold);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: background 0.2s ease, transform 0.15s ease;
      }

      .btn-primary:hover {
        background: var(--gold-light);
        transform: translateY(-1px);
      }

      .btn-outline-dark {
        display: inline-block;
        border: 1px solid var(--navy);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: background 0.2s, color 0.2s, transform 0.15s ease;
      }

      .btn-outline-dark:hover {
        background: var(--navy);
        color: var(--gold);
        transform: translateY(-1px);
      }

      /* ─── RESPONSIVE ──────────────────────────────────────── */
      @media (max-width: 768px) {
        .mission-layout { grid-template-columns: 1fr; gap: 2rem; }
        .mission-label-col { position: static; }
        .story-columns { grid-template-columns: 1fr; gap: 2rem; }
        .page-hero { padding: 4rem 1.5rem 3rem; }
        .page-hero::before { font-size: 8rem; }
      }
    </style>
  </head>

  <body>
    <Header />

    <!-- ═══════════════════════════════════════════════ PAGE HERO -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <nav class="breadcrumb">
          <a href="/Nahj-Institute/">Home</a>
          <span>/</span>
          <span style="color: rgba(255,255,255,0.65);">About the Institute</span>
        </nav>
        <h1>
          An Institute Built on the <em>Conviction</em><br />
          That Ideas Have Consequences
        </h1>
        <p class="page-hero-sub">
          Nahj Institute is an independent research centre and think tank dedicated to rigorous scholarship at the crossroads of Islamic intellectual tradition, contemporary politics, social ethics, and the questions that define our age.
        </p>
      </div>
    </section>

    <main>

      <!-- ══════════════════════════════════════════ MISSION -->
      <section class="section-mission">
        <div class="mission-layout">
          <div class="mission-label-col">
            <span class="section-label">Our Mission</span>
            <div class="divider-gold"></div>
            <h2>Why We Exist</h2>
          </div>

          <div class="mission-body">
            <p>
              The Muslim world faces an extraordinary confluence of crises — intellectual, political, and civilisational. Old certainties are dissolving. New questions are pressing. And too often, the discourse that ought to address them is either shallow, partisan, or locked behind the walls of institutions too cautious to ask the hardest things.
            </p>
            <p>
              <strong>Nahj Institute was founded to do something different.</strong> We believe that genuine scholarship — fearless, grounded, and honest — is not a luxury but a necessity. That the Islamic intellectual tradition, at its best, was never afraid of difficult questions. That thinkers like Imam Ali, al-Farabi, Ibn Rushd, and Allama Iqbal did not inherit answers — they forged them through discipline, courage, and deep engagement with the world as it actually was.
            </p>

            <div class="mission-pullquote">
              <p>"Knowledge is a light that God casts into the heart of whomever He wills."</p>
              <cite>— Imam Ja'far al-Sadiq (AS)</cite>
            </div>

            <p>
              Our mission is to cultivate that tradition anew. To produce research that is academically rigorous and publicly legible. To host conversations that are substantive rather than performative. To nurture the next generation of Muslim scholars, writers, and public thinkers — not by handing them conclusions, but by honing their capacity to reason well.
            </p>
            <p>
              We are not a seminary, though we take theology seriously. We are not a political party, though we engage politics unflinchingly. We are not a social media presence, though ideas must travel. <strong>We are a place of inquiry</strong> — and we hold that the examined life, rigorously and honestly pursued, remains the most important work there is.
            </p>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════ OUR STORY -->
      <section class="section-story">
        <div class="story-inner">
          <div class="story-header">
            <span class="section-label">Our Story</span>
            <div class="divider-gold"></div>
            <h2>Born from <em>Frustration.</em><br />Built with Purpose.</h2>
          </div>

          <div class="story-columns">
            <div>
              <p>
                Nahj Institute grew out of a simple frustration shared by a small group of students, scholars, and practitioners: that the Muslim intellectual community in the English-speaking world lacked a serious, independent forum. A place that could hold together rigour and relevance. That could speak across disciplines — theology and political science, philosophy and sociology, history and contemporary affairs — without losing depth in any of them.
              </p>
              <p>
                The name <strong>Nahj</strong> — Arabic for <em>path</em>, <em>method</em>, or <em>way</em> — was chosen deliberately. It evokes Nahj al-Balagha, the collected sermons and letters of Imam Ali ibn Abi Talib: perhaps the most intellectually demanding and spiritually profound text in the Arabic literary canon. It reminds us that the path of knowledge is not a destination but a discipline. Not a position but a practice.
              </p>
            </div>
            <div>
              <p>
                What began as a reading circle and a handful of published essays has grown into a full research programme: with commissioned papers, an annual writing competition, a lecture series that has hosted scholars from across the Muslim world, and a student development programme now serving hundreds of young people seeking mentorship and intellectual formation.
              </p>
              <p>
                We remain independent, self-funded, and governed by our founding principles rather than by donors with agendas or states with interests. <strong>That independence is our most valuable asset.</strong> It is what allows us to say what needs to be said — with care, with evidence, and without apology.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════ VALUES -->
      <section class="section-values">
        <div class="container">
          <div class="values-header">
            <span class="section-label">What We Stand For</span>
            <div class="divider-gold center"></div>
            <h2>Our Founding Principles</h2>
          </div>

          <div class="values-grid">
            <div class="value-item">
              <div class="value-number">01</div>
              <h3 class="value-title">Intellectual Rigour</h3>
              <p class="value-body">We hold our work to the standards of serious academic scholarship. Claims require evidence. Arguments require logic. Conclusions must remain open to revision. We have no patience for polemic dressed as analysis.</p>
            </div>

            <div class="value-item">
              <div class="value-number">02</div>
              <h3 class="value-title">Moral Courage</h3>
              <p class="value-body">Some questions are uncomfortable. Some conclusions are unpopular. Nahj will not shy from either. The duty to speak truthfully — to one's community, to power, and to oneself — is an obligation we take with full seriousness.</p>
            </div>

            <div class="value-item">
              <div class="value-number">03</div>
              <h3 class="value-title">Civilisational Rootedness</h3>
              <p class="value-body">We are heirs to one of history's great intellectual traditions. We engage modernity not as supplicants but as inheritors — drawing on classical Islamic thought not as a relic, but as a living resource for contemporary questions.</p>
            </div>

            <div class="value-item">
              <div class="value-number">04</div>
              <h3 class="value-title">Genuine Pluralism</h3>
              <p class="value-body">We welcome contributors across legal schools, political perspectives, and academic disciplines. Disagreement, conducted honestly and respectfully, is among the most productive forces in intellectual life. We cultivate it deliberately.</p>
            </div>

            <div class="value-item">
              <div class="value-number">05</div>
              <h3 class="value-title">Accessibility</h3>
              <p class="value-body">Depth need not mean obscurity. We write for the educated general reader as much as the specialist, believing that the most important ideas must be capable of reaching the most people without sacrificing their complexity.</p>
            </div>

            <div class="value-item">
              <div class="value-number">06</div>
              <h3 class="value-title">Service</h3>
              <p class="value-body">Knowledge divorced from service is incomplete. Our scholarship is grounded in genuine concern for the communities we serve — Muslim and otherwise — and expressed not only in publication, but in education, mentorship, and charitable action.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════ FOCUS AREAS -->
      <section class="section-focus">
        <div class="focus-header container">
          <span class="section-label">Areas of Inquiry</span>
          <div class="divider-gold"></div>
          <h2>The Questions That Drive Our Work</h2>
        </div>
        <div class="focus-list container">
          <div class="focus-item">
            <span class="focus-num">01</span>
            <div class="focus-text">
              <h4>Islamic Theology & Philosophy</h4>
              <p>Kalam, ethics, eschatology, and the enduring questions of divine justice, human agency, and the nature of revelation — engaged with classical rigour and contemporary awareness.</p>
            </div>
          </div>

          <div class="focus-item">
            <span class="focus-num">02</span>
            <div class="focus-text">
              <h4>Politics & Governance</h4>
              <p>Islamic political theory, the crisis of legitimacy in Muslim-majority states, democracy, constitutionalism, and the contested relationship between religion and public life.</p>
            </div>
          </div>

          <div class="focus-item">
            <span class="focus-num">03</span>
            <div class="focus-text">
              <h4>Geopolitics & International Affairs</h4>
              <p>The Muslim world in the global order: from the Gulf to South Asia, from the Sahel to Southeast Asia. Strategic analysis grounded in historical depth and ethical seriousness.</p>
            </div>
          </div>

          <div class="focus-item">
            <span class="focus-num">04</span>
            <div class="focus-text">
              <h4>Religious Harmony & Interfaith Ethics</h4>
              <p>The theory and practice of coexistence: comparative theology, the ethics of dialogue, sectarian conflict, and the civilisational project of living well with difference.</p>
            </div>
          </div>

          <div class="focus-item">
            <span class="focus-num">05</span>
            <div class="focus-text">
              <h4>Social Issues & Contemporary Culture</h4>
              <p>Family, identity, gender, technology, and the pressures bearing down on Muslim communities in the modern world — examined with rigour rather than reactivity.</p>
            </div>
          </div>

          <div class="focus-item">
            <span class="focus-num">06</span>
            <div class="focus-text">
              <h4>Science, Ethics & the Human Condition</h4>
              <p>Bioethics, artificial intelligence, environmental thought, and the enduring question of what it means to be human — read through the lens of Islamic intellectual tradition.</p>
            </div>
          </div>
        </div>
      </section>

