---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Page Not Found — Nahj Institute"
  description="The page you are looking for does not exist or has been moved."
>
  <main id="main-content">
    <section class="error-hero">
      <div class="error-inner">
        <span class="error-code">404</span>
        <h1>Page Not Found</h1>
        <p class="error-desc">
          The page you are looking for does not exist, has been moved, or is temporarily unavailable.
          If you reached this page from a link on our website, please let us know.
        </p>
        <div class="error-ctas">
          <a href={`${base}/`} class="btn-primary">Return to Homepage</a>
          <a href={`${base}/research`} class="btn-outline-dark">Browse Research</a>
          <a href={`${base}/contact`} class="btn-outline-dark">Contact Us</a>
        </div>
      </div>
    </section>
  </main>

  <style>
    .error-hero {
      background: var(--cream);
      padding: 6rem 2rem 8rem;
      text-align: center;
      min-height: 60vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .error-inner {
      max-width: 580px;
    }

    .error-code {
      font-family: 'Cormorant Garamond', serif;
      font-size: 96px;
      font-weight: 300;
      color: var(--cream-dark);
      line-height: 1;
      display: block;
      margin-bottom: 1rem;
    }

    .error-hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(26px, 3vw, 36px);
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 1.25rem;
    }

    .error-desc {
      font-size: 18px;
      color: var(--muted);
      line-height: 1.78;
      font-weight: 300;
      margin-bottom: 2.5rem;
    }

    .error-ctas {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
  </style>
</BaseLayout>
