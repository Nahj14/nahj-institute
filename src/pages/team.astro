---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Replace these with real people when available.
// Photo: place headshots in /public/team/ and update the src fields.
// Until photos are available, the initials placeholder is shown instead.
const leadership = [
  {
    name: "Founder and Director",
    role: "Executive Leadership",
    initials: "F",
    bio: "Leads the Institute's strategic direction, editorial standards, and external relations. Founded Nahj Institute with the conviction that serious independent scholarship on the Muslim world requires an institutional home free of state and commercial influence.",
    placeholder: true,
  },
  {
    name: "Research Lead",
    role: "Academic Affairs",
    initials: "R",
    bio: "Oversees the Institute's research programme, peer-review processes, and publication standards. Specialist in Islamic political thought and the intellectual history of South Asia.",
    placeholder: true,
  },
  {
    name: "Editor-in-Chief",
    role: "Publications",
    initials: "E",
    bio: "Responsible for all editorial output: commissioning, editing, and shaping the voice of Nahj Institute across essays, policy briefs, and long-form pieces.",
    placeholder: true,
  },
  {
    name: "Programmes Director",
    role: "Events and Student Programmes",
    initials: "P",
    bio: "Manages the lecture series, writing competitions, workshops, and the student mentorship programme. Brings extensive experience in academic event management and youth intellectual development across the Muslim world.",
    placeholder: true,
  },
];

const advisors = [
  {
    name: "Academic Advisor",
    role: "Theology and Philosophy",
    initials: "A",
    placeholder: true,
  },
  {
    name: "Academic Advisor",
    role: "Political Science",
    initials: "A",
    placeholder: true,
  },
  {
    name: "Academic Advisor",
    role: "International Relations",
    initials: "A",
    placeholder: true,
  },
  {
    name: "Academic Advisor",
    role: "Islamic History",
    initials: "A",
    placeholder: true,
  },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Our Team | Nahj Institute</title>
  <meta name="description" content="The scholars, researchers, and practitioners who lead Nahj Institute." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --navy:       #0C1B2E;
      --teal:       #1B5E6F;
      --gold:       #C8A252;
      --gold-light: #E2BC75;
      --cream:      #F7F2E8;
      --cream-dark: #EDE6D5;
      --charcoal:   #2B2B2B;
      --muted:      #6B6B6B;
      --white:      #FFFFFF;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--cream);
      color: var(--charcoal);
      font-family: 'Crimson Pro', Georgia, serif;
      font-size: 18px;
      line-height: 1.78;
      -webkit-font-smoothing: antialiased;
    }

    main { width: 100% !important; max-width: 100% !important; padding: 0 !important; margin: 0 !important; }

    /* ── UTILITIES ──────────────────────────────────────── */
    .container { max-width: 1120px; margin: 0 auto; padding: 0 2rem; }

    .slabel {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      display: block;
    }

    .gold-rule { width: 3rem; height: 2px; background: var(--gold); margin: 0.75rem 0 1.4rem; }

    /* ── HERO ───────────────────────────────────────────── */
    .page-hero {
      background: var(--navy);
      padding: 5rem 2rem 4.5rem;
      position: relative;
      overflow: hidden;
    }
    .page-hero::before {
      content: 'نهج';
      font-family: 'Amiri', serif;
      font-size: clamp(120px, 22vw, 220px);
      font-weight: 700;
      color: rgba(255,255,255,0.03);
      position: absolute;
      right: -1rem;
      top: 50%;
      transform: translateY(-50%);
      line-height: 1;
      pointer-events: none;
      user-select: none;
    }
    .hero-inner { max-width: 1120px; margin: 0 auto; position: relative; z-index: 1; }

    .breadcrumb {
      font-size: 14px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.42);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .breadcrumb a { color: rgba(255,255,255,0.42); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--gold); }
    .breadcrumb span { color: rgba(255,255,255,0.18); }

    .page-hero h1 em { font-style: italic; color: #E2BC75; }
    .page-hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(26px, 2.8vw, 36px);
      font-weight: 600;
      line-height: 1.12;
      color: var(--white);
      margin-bottom: 1.25rem;
    }
    .hero-sub {
      font-size: 21px;
      color: rgba(255,255,255,0.58);
      max-width: 560px;
      font-weight: 300;
      line-height: 1.80;
    }

    /* ── SUB-NAV (like Carnegie) ────────────────────────── */
    .sub-nav {
      background: var(--white);
      border-bottom: 1px solid var(--cream-dark);
      padding: 0 2rem;
    }
    .sub-nav-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: flex;
      gap: 0;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .sub-nav-inner::-webkit-scrollbar { display: none; }
    .sub-nav a {
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      padding: 1.1rem 1.5rem;
      border-bottom: 2px solid transparent;
      white-space: nowrap;
      transition: color 0.2s, border-color 0.2s;
      display: block;
    }
    .sub-nav a:hover { color: var(--navy); }
    .sub-nav a.active { color: var(--navy); border-bottom-color: var(--gold); }

    /* ── LEADERSHIP LIST (Carnegie-style) ───────────────── */
    .section-leadership {
      background: var(--cream);
      padding: 5rem 2rem;
    }

    .leadership-header {
      max-width: 1120px;
      margin: 0 auto 3.5rem;
    }
    .leadership-header h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(26px, 3vw, 38px);
      font-weight: 600;
      color: var(--navy);
      margin-top: 0.5rem;
    }
    .leadership-header p {
      font-size: 20px;
      color: var(--muted);
      max-width: 640px;
      font-weight: 300;
      line-height: 1.80;
      margin-top: 0.75rem;
    }

    /* Each person: horizontal layout (photo left, text right) */
    .person-list { max-width: 1120px; margin: 0 auto; }

    .person {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 2.5rem;
      padding: 3rem 0;
      border-bottom: 1px solid var(--cream-dark);
      align-items: start;
    }
    .person:first-child { padding-top: 0; }
    .person:last-child { border-bottom: none; }

    /* Photo: shows real photo or initials placeholder */
    .person-photo {
      width: 160px;
      height: 200px;
      background: var(--navy);
      position: relative;
      overflow: hidden;
      flex-shrink: 0;
    }
    .person-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }
    .person-photo .initials {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-size: 48px;
      font-weight: 600;
      color: rgba(255,255,255,0.20);
      background: linear-gradient(135deg, var(--navy) 0%, rgba(27,94,111,0.8) 100%);
    }
    .person-photo .placeholder-text {
      position: absolute;
      bottom: 0.75rem;
      left: 0;
      right: 0;
      text-align: center;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      font-family: 'Crimson Pro', serif;
    }

    .person-info {}

    .person-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 0.3rem;
      line-height: 1.18;
    }

    .person-role {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 1rem;
    }

    .person-bio {
      font-size: 20px;
      color: var(--charcoal);
      line-height: 1.75;
      font-weight: 300;
      max-width: 640px;
    }

    /* ── ADVISORS GRID ──────────────────────────────────── */
    .section-advisors {
      background: var(--cream-dark);
      padding: 5rem 2rem;
    }

    .advisors-header {
      max-width: 1120px;
      margin: 0 auto 3rem;
    }
    .advisors-header h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(22px, 2.2vw, 28px);
      font-weight: 600;
      color: var(--navy);
      margin-top: 0.5rem;
    }
    .advisors-header p {
      font-size: 20px;
      color: var(--muted);
      max-width: 600px;
      font-weight: 300;
      line-height: 1.80;
      margin-top: 0.75rem;
    }

    .advisors-grid {
      max-width: 1120px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 2px;
    }

    .advisor-card {
      background: var(--white);
      padding: 1.75rem;
      transition: border-color 0.2s;
      border-top: 3px solid transparent;
    }
    .advisor-card:hover { border-color: var(--gold); }

    .advisor-photo {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.1rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 24px;
      font-weight: 600;
      color: rgba(255,255,255,0.18);
    }
    .advisor-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 0.25rem;
    }
    .advisor-role {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--teal);
    }

    /* ── JOIN SECTION ───────────────────────────────────── */
    .section-join {
      background: var(--navy);
      padding: 4.5rem 2rem;
      text-align: center;
    }
    .join-inner { max-width: 640px; margin: 0 auto; }
    .section-join h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(26px, 3vw, 38px);
      font-weight: 600;
      color: var(--white);
      margin-bottom: 1rem;
    }
    .section-join p {
      font-size: 20px;
      color: rgba(255,255,255,0.60);
      font-weight: 300;
      line-height: 1.80;
      margin-bottom: 2rem;
    }
    .btn-gold {
      display: inline-block;
      background: var(--gold);
      color: var(--navy);
      font-family: 'Crimson Pro', serif;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.9rem 2.25rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-gold:hover { background: var(--gold-light); }

    /* ── BACK BREADCRUMB ────────────────────────────────── */
    .back-strip {
      background: var(--cream);
      padding: 1.5rem 2rem;
      border-top: 1px solid var(--cream-dark);
    }
    .back-strip a {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--teal);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-strip a:hover { color: var(--gold); }

    /* ── RESPONSIVE ─────────────────────────────────────── */
    @media (max-width: 640px) {
      .page-hero { padding: 3.5rem 1.25rem 3rem; }
      .person { grid-template-columns: 1fr; }
      .person-photo { width: 120px; height: 150px; }
    }
  </style>
</head>

<body>
  <Header />

  <!-- HERO -->
  <section class="page-hero">
    <div class="hero-inner">
      <nav class="breadcrumb">
        <a href={`${base}/`}>Home</a>
        <span>/</span>
        <a href={`${base}/about`}>About</a>
        <span>/</span>
        <span style="color:rgba(255,255,255,0.65)">Our Team</span>
      </nav>
      <h1>Our <em>Team</em></h1>
      <p class="hero-sub">
        The scholars, researchers, and practitioners who lead Nahj Institute.
      </p>
    </div>
  </section>

  <!-- SUB-NAV (mirrors Carnegie's About section navigation) -->
  <nav class="sub-nav" aria-label="About section navigation">
    <div class="sub-nav-inner">
      <a href={`${base}/about`}>Overview</a>
      <a href={`${base}/about#mission`}>Our Mission</a>
      <a href={`${base}/team`} class="active">Our Team</a>
      <a href={`${base}/research`}>Our Research</a>
      <a href={`${base}/contact`}>Opportunities</a>
    </div>
  </nav>

  <main>

    <!-- LEADERSHIP -->
    <section class="section-leadership">
      <div class="leadership-header container">
        <span class="slabel">Senior Leadership</span>
        <div class="gold-rule"></div>
        <h2>Leadership and Core Staff</h2>
        <p>
          Nahj Institute is led by a small team of full-time researchers and editors committed to producing scholarship of the highest standard.
        </p>
      </div>

      <div class="person-list container">
        {leadership.map(person => (
          <div class="person">
            <div class="person-photo">
              {person.placeholder ? (
                <>
                  <div class="initials">{person.initials}</div>
                  <span class="placeholder-text">Photo coming</span>
                </>
              ) : (
                <img src={`${base}/team/${person.name.toLowerCase().replace(/\s+/g, '-')}.jpg`} alt={person.name} />
              )}
            </div>
            <div class="person-info">
              <div class="person-name">{person.name}</div>
              <div class="person-role">{person.role}</div>
              <p class="person-bio">{person.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ADVISORS -->
    <section class="section-advisors">
      <div class="advisors-header container">
        <span class="slabel">Academic Advisory Board</span>
        <div class="gold-rule"></div>
        <h2>Our Advisors</h2>
        <p>
          Nahj Institute is supported by an advisory board of senior academics who guide our research programme and editorial standards.
        </p>
      </div>

      <div class="advisors-grid container">
        {advisors.map(advisor => (
          <div class="advisor-card">
            <div class="advisor-photo">{advisor.initials}</div>
            <div class="advisor-name">{advisor.name}</div>
            <div class="advisor-role">{advisor.role}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- JOIN -->
    <section class="section-join">
      <div class="join-inner">
        <span class="slabel" style="color:var(--gold)">Work With Us</span>
        <div class="gold-rule" style="margin:0.75rem auto 1.4rem;background:var(--gold)"></div>
        <h2>Interested in Joining Our Team?</h2>
        <p>
          We work with associate researchers, contributing writers, and academic advisors from across the Muslim world and the Global South. If you share our commitment to serious intellectual inquiry, we would like to hear from you.
        </p>
        <a href={`${base}/contact`} class="btn-gold">Get in Touch →</a>
      </div>
    </section>

    <!-- BACK BREADCRUMB -->
    <div class="back-strip">
      <div class="container">
        <a href={`${base}/about`}>← Back to About</a>
      </div>
    </div>

  </main>

  <Footer />
</body>
</html>