---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Use id (filename without extension, lowercased) as URL slug
function toSlug(id: string) {
  return id.replace(/\.mdx?$/, '').toLowerCase();
}

const featuredArticle = allArticles.find(a => a.data.featured) || allArticles[0];
const remainingArticles = allArticles.filter(a => a.id !== featuredArticle?.id);

const categories = [
  'All',
  'Theology & Politics',
  'Geopolitics',
  'Society',
  'Science & Ethics',
  'Religious Harmony',
  'Philosophy',
  'Cultural History',
];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Research & Publications | Nahj Institute"
  description="Essays, policy briefs, commentary and peer-reviewed research from Nahj Institute across Islamic thought, politics, society, science and ethics."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <div>
        <nav class="breadcrumb">
          <a href={`${base}/`}>Home</a>
          <span>/</span>
          <span style="color:rgba(255,255,255,0.65)">Research</span>
        </nav>
        <h1>Research &<br /><em>Publications</em></h1>
        <p class="page-hero-sub">Essays, policy briefs, commentary, and peer-reviewed research across Islamic thought, politics, society, science, and ethics.</p>
      </div>
      <div class="hero-cta">
        <a href={`${base}/research/submit`} class="btn-gold">Submit Writing</a>
        <a href={"https://journal.nahjinstitute.com"} class="btn-outline-light" target="_blank" rel="noopener noreferrer">Nahj Journal →</a>
      </div>
    </div>
  </section>

  <div class="filter-bar">
    <div class="filter-inner">
      {categories.map((cat, i) => (
        <button class={`filter-btn ${i === 0 ? 'active' : ''}`} data-category={cat}>{cat}</button>
      ))}
    </div>
  </div>

  <main id="main-content">
    {allArticles.length === 0 ? (
      <div class="empty-state container">
        <span class="section-label" style="display:block;text-align:center">Publications</span>
        <p>Articles are being prepared for publication. Check back soon.</p>
      </div>
    ) : (
      <>
        {featuredArticle && (
          <section class="section-featured">
            <div class="container">
              <a href={`${base}/articles/${toSlug(featuredArticle.id)}`} class="featured-card" data-article-category={featuredArticle.data.category}>
                <div class="featured-label-col">
                  <span class="featured-tag">{featuredArticle.data.category}</span>
                  <h2 class="featured-title">{featuredArticle.data.title}</h2>
                  <p class="featured-excerpt">{featuredArticle.data.excerpt}</p>
                  <div class="featured-meta">{featuredArticle.data.author} · {formatDate(featuredArticle.data.date)}</div>
                </div>
                <div class="featured-type-col">
                  <span class="featured-type-badge">{featuredArticle.data.type}</span>
                  <span class="featured-read">Read Article →</span>
                </div>
              </a>
            </div>
          </section>
        )}
        <section class="section-articles">
          <div class="container">
            <div class="articles-grid" id="articles-grid">
              {remainingArticles.map(article => (
                <a href={`${base}/articles/${toSlug(article.id)}`} class="article-card" data-article-category={article.data.category}>
                  <div class="article-card-body">
                    <span class="article-tag">{article.data.category}</span>
                    <h3 class="article-title">{article.data.title}</h3>
                    <p class="article-excerpt">{article.data.excerpt}</p>
                    <div class="article-meta">
                      <span>{article.data.author} · {formatDate(article.data.date)}</span>
                      <span class="article-type">{article.data.type}</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      </>
    )}

    <section class="section-invite">
      <div class="invite-inner">
        <span class="section-label" style="display:block;text-align:center;color:var(--gold)">Contribute</span>
        <div style="width:3.5rem;height:2px;background:var(--gold);margin:0.9rem auto 1.5rem;"></div>
        <h2>Submit an Essay or Commentary</h2>
        <p>Nahj Institute publishes work from researchers, academics, practitioners, and informed writers at all career stages. We welcome essays of 3,000 to 8,000 words and commentary of 1,200 to 2,500 words.</p>
        <div class="invite-btns">
          <a href={`${base}/research/submit`} class="btn-gold">Submission Guidelines</a>
        </div>
      </div>
    </section>
  </main>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('[data-article-category]');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const selected = (btn as HTMLElement).dataset.category;
        cards.forEach(card => {
          const el = card as HTMLElement;
          el.style.display = (selected === 'All' || el.dataset.articleCategory === selected) ? '' : 'none';
        });
      });
    });
  </script>

  <style>
    /* Research page-hero grid override (global .page-hero-inner has no grid) */
    .page-hero-inner {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: end;
      gap: 3rem;
    }

    .page-hero h1 {
      margin-bottom: 1.25rem;
    }

    .hero-cta {
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-end;
    }

    .btn-gold {
      display: inline-block;
      background: var(--gold);
      color: var(--navy);
      font-family: 'Crimson Pro', serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.8rem 1.75rem;
      text-decoration: none;
      transition: background 0.2s;
      white-space: nowrap;
    }
    .btn-gold:hover { background: var(--gold-light); }

    /* FILTER BAR */
    .filter-bar {
      background: var(--cream-dark);
      border-bottom: 1px solid rgba(0,0,0,0.06);
      position: sticky;
      top: 68px;
      z-index: 50;
    }
    .filter-inner {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      gap: 0;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .filter-inner::-webkit-scrollbar { display: none; }
    .filter-btn {
      font-family: 'Crimson Pro', serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 1rem 1.25rem;
      border: none;
      background: none;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      white-space: nowrap;
      transition: color 0.2s, border-color 0.2s;
    }
    .filter-btn:hover { color: var(--navy); }
    .filter-btn.active { color: var(--navy); border-bottom-color: var(--gold); }

    /* FEATURED */
    .section-featured { padding: 4rem 2rem 0; background: var(--cream); }
    .featured-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      background: var(--navy);
      text-decoration: none;
      color: inherit;
      transition: opacity 0.2s;
    }
    .featured-card:hover { opacity: 0.92; }
    .featured-label-col {
      padding: 3rem 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-right: 1px solid rgba(255,255,255,0.07);
    }
    .featured-tag {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      display: block;
      margin-bottom: 1rem;
    }
    .featured-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(22px, 2.2vw, 28px);
      font-weight: 600;
      color: var(--white);
      line-height: 1.15;
      margin-bottom: 1rem;
    }
    .featured-excerpt {
      font-size: 18px;
      color: rgba(255,255,255,0.62);
      line-height: 1.8;
      font-weight: 300;
      margin-bottom: 1.5rem;
    }
    .featured-meta { font-size: 13px; color: rgba(255,255,255,0.50); }
    .featured-type-col {
      padding: 3rem 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 1rem;
    }
    .featured-type-badge {
      display: inline-block;
      border: 1px solid var(--gold);
      color: var(--gold);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 0.4rem 0.9rem;
      width: fit-content;
    }
    .featured-read {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.50);
    }

    /* ARTICLES GRID */
    .section-articles { padding: 3rem 2rem 4rem; background: var(--cream); }
    .articles-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2px;
      background: var(--cream-dark);
    }
    .article-card {
      background: var(--cream);
      display: flex;
      flex-direction: column;
      border-top: 3px solid transparent;
      transition: border-color 0.25s, background 0.2s;
      text-decoration: none;
      color: inherit;
    }
    .article-card:hover { border-color: var(--gold); background: var(--white); }
    .article-card-body {
      padding: 1.75rem 1.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .article-tag {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 0.5rem;
      display: block;
    }
    .article-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--navy);
      line-height: 1.22;
      margin-bottom: 0.6rem;
      flex: 1;
    }
    .article-excerpt {
      font-size: 18px;
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 1.25rem;
      font-weight: 300;
    }
    .article-meta {
      font-size: 13px;
      color: var(--muted);
      padding-top: 0.9rem;
      border-top: 1px solid var(--cream-dark);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .article-type {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--teal);
    }

    /* SUBMIT INVITATION */
    .section-invite {
      background: var(--navy);
      padding: 5rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .section-invite::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(27,94,111,0.3) 0%, transparent 70%);
      pointer-events: none;
    }
    .invite-inner {
      max-width: 640px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .section-invite h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(22px, 2.2vw, 28px);
      font-weight: 600;
      color: var(--white);
      line-height: 1.1;
      margin-top: 0.5rem;
      margin-bottom: 1rem;
    }
    .section-invite p {
      font-size: 18px;
      color: rgba(255,255,255,0.58);
      font-weight: 300;
      line-height: 1.85;
      margin-bottom: 2rem;
    }
    .invite-btns {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    /* EMPTY STATE */
    .empty-state { padding: 6rem 2rem; text-align: center; }
    .empty-state p { font-size: 18px; color: var(--muted); font-weight: 300; margin-top: 1rem; }

    @media (max-width: 768px) {
      .featured-card { grid-template-columns: 1fr; }
      .page-hero-inner { grid-template-columns: 1fr; }
      .hero-cta { align-items: flex-start; }
    }
  </style>
</BaseLayout>
