---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const all = await getCollection('articles', ({ data }) => !data.draft);
  all.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  return all.map((entry, i) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '').toLowerCase() },
    props: {
      entry,
      prevArticle:  all[i + 1] ?? null,
      nextArticle:  all[i - 1] ?? null,
      moreArticles: all.filter((_, j) => j !== i).slice(0, 4),
    },
  }));
}

const { entry, prevArticle, nextArticle, moreArticles } = Astro.props;
const { Content } = await entry.render();

const wordCount   = Math.round((entry.body?.length ?? 0) / 5);
const readingTime = Math.max(1, Math.round(wordCount / 220));

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
function shortDate(date: Date) {
  return date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{entry.data.title} — Nahj Institute</title>
  <meta name="description" content={entry.data.excerpt} />
  <meta property="og:title"       content={`${entry.data.title} — Nahj Institute`} />
  <meta property="og:description" content={entry.data.excerpt} />
  <meta property="og:type"        content="article" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

  <style is:global>
    /* ════════════════════════════════ VARIABLES */
    :root {
      --navy:       #0C1B2E;
      --teal:       #1B5E6F;
      --gold:       #C8A252;
      --gold-light: #E2BC75;
      --cream:      #F7F2E8;
      --cream-dark: #EDE6D5;
      --charcoal:   #2B2B2B;
      --muted:      #6B6B6B;
      --white:      #FFFFFF;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    /*
      FONT TARGET: politicaltheology.com uses Georgia ~18px optical.
      Crimson Pro is a condensed face — it renders visually ~25% smaller
      than Georgia at the same px size. So to match the comfort of that
      reference site, we use body: 24px, prose: 1.15rem = 27.6px.
    */
    body {
      background: var(--cream);
      color: var(--charcoal);
      font-family: 'Crimson Pro', Georgia, serif;
      font-size: 18px;
      line-height: 1.78;
      -webkit-font-smoothing: antialiased;
    }

    /* ════════════════════════════════ PROGRESS BAR */
    #progress-bar {
      position: fixed; top: 0; left: 0;
      height: 3px; width: 0%;
      background: linear-gradient(90deg, var(--teal), var(--gold));
      z-index: 9999; pointer-events: none;
      transition: width 0.1s linear;
    }

    /* ════════════════════════════════ HERO */
    .article-hero {
      background: var(--navy);
      padding: 5.5rem 2rem 4.5rem;
      position: relative; overflow: hidden;
    }
    .article-hero::before {
      content: 'نهج'; font-family: 'Amiri', serif;
      font-size: clamp(10rem, 20vw, 20rem); font-weight: 700;
      color: rgba(255,255,255,0.03);
      position: absolute; right: -1rem; top: 50%;
      transform: translateY(-50%);
      pointer-events: none; user-select: none; line-height: 1;
    }
    .hero-inner {
      max-width: 1360px; margin: 0 auto;
      position: relative; z-index: 1;
    }
    .breadcrumb {
      font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(255,255,255,0.32); margin-bottom: 1.75rem;
      display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
    }
    .breadcrumb a { color: rgba(255,255,255,0.32); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--gold); }
    .breadcrumb .sep { color: rgba(255,255,255,0.12); }
    .article-cat {
      font-size: 12px; font-weight: 600; letter-spacing: 0.24em;
      text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.85rem;
    }
    .article-hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 4.5vw, 3.8rem);
      font-weight: 600; line-height: 1.06; color: var(--white);
      margin-bottom: 1.75rem; max-width: 820px;
    }
    .article-byline {
      display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
      padding-top: 1.4rem; border-top: 1px solid rgba(255,255,255,0.1);
    }
    .byline-author { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 500; color: var(--gold-light); }
    .byline-dot    { color: rgba(255,255,255,0.15); font-size: 8px; }
    .byline-date   { font-size: 19px; color: rgba(255,255,255,0.42); }
    .byline-read   { font-size: 19px; color: rgba(255,255,255,0.34); font-style: italic; }
    .byline-type   {
      margin-left: auto; font-size: 1rem; font-weight: 600; letter-spacing: 0.16em;
      text-transform: uppercase; border: 1px solid rgba(255,255,255,0.16);
      color: rgba(255,255,255,0.48); padding: 0.2rem 0.65rem;
    }

    /* ════════════════════════════════ THREE-COLUMN GRID */
    .page-grid {
      display: grid;
      grid-template-columns: 210px 1fr 260px;
      max-width: 1360px;
      margin: 0 auto;
      align-items: start;
      padding-bottom: 5rem;
    }

    /* ════════════════════════════════ LEFT COLUMN */
    .left-col {
      position: sticky; top: 4.5rem;
      padding: 3rem 1.25rem 3rem 1.5rem;
      align-self: start;
      max-height: calc(100vh - 5.5rem);
      overflow-y: auto; scrollbar-width: none;
      border-right: 1px solid var(--cream-dark);
    }
    .left-col::-webkit-scrollbar { display: none; }

    /* ════════════════════════════════ ARTICLE COLUMN */
    .article-col {
      padding: 3.5rem 3.5rem 4rem 3.5rem;
      border-right: 1px solid var(--cream-dark);
      min-width: 0; min-height: 70vh;
    }
    .back-link {
      font-size: 12px; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--teal); text-decoration: none;
      display: block; margin-bottom: 2rem; transition: color 0.2s;
    }
    .back-link:hover { color: var(--gold); }

    /* ════════════════════════════════ ARTICLE DETAILS — TOP OF ARTICLE
       Moved here from the right sidebar so readers see it immediately.
       Horizontal strip of metadata before the prose begins.
    */
    .article-details-top {
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      border: 1px solid var(--cream-dark);
      background: var(--white);
      margin-bottom: 2.75rem;
      border-left: 4px solid var(--gold);
    }
    .adt-item {
      flex: 1 1 auto;
      padding: 0.5rem 1rem;
      border-right: 1px solid var(--cream-dark);
      min-width: 85px;
    }
    .adt-item:last-child { border-right: none; }
    .adt-key {
      font-size: 12px; font-weight: 600; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--gold);
      display: block; margin-bottom: 0.15rem;
    }
    .adt-val {
      font-size: 1rem;
      color: var(--charcoal);
      line-height: 0.7
      font-family: 'Crimson Pro', serif;
    }

    /* Reading progress strip — sits below the article details top bar */
    .adt-progress-wrap {
      height: 3px;
      background: var(--cream-dark);
      overflow: hidden;
      width: 100%;
    }
    .adt-progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--teal), var(--gold));
      width: 0%;
      transition: width 0.12s linear;
    }

    /* ════════════════════════════════ PROSE
       Reference: politicaltheology.com Georgia 18px → Crimson Pro 24px body
       prose at 1.15rem = 27.6px, line-height 1.95 for comfortable tracking
    */
    .prose {
      font-size: 18px;      /* 27.6px on 24px body */
      line-height: 1.95;
      color: var(--charcoal);
      max-width: 68ch;
    }

    /* Drop cap */
    .prose :global(p:first-of-type::first-letter) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 4.5em; font-weight: 600; color: var(--navy);
      float: left; line-height: 0.76;
      margin-right: 0.09em; margin-top: 0.15em;
      padding-bottom: 0.075em;
    }

    .prose :global(h2) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.65em; font-weight: 600; color: var(--navy);
      margin: 3.75rem 0 1.1rem; line-height: 1.12;
      padding-top: 1.5rem; border-top: 1px solid var(--cream-dark);
      scroll-margin-top: 5rem;
    }
    .prose :global(h2:first-child) { margin-top: 0; padding-top: 0; border-top: none; }

    .prose :global(h3) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.32em; font-weight: 600; color: var(--navy);
      margin: 2.75rem 0 0.85rem; line-height: 1.2; scroll-margin-top: 5rem;
    }
    .prose :global(h4) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.12em; font-weight: 600; color: var(--navy);
      margin: 2rem 0 0.6rem; scroll-margin-top: 5rem;
    }
    .prose :global(p)  { margin-bottom: 2rem; }
    .prose :global(ul), .prose :global(ol) { padding-left: 1.75rem; margin-bottom: 1.75rem; }
    .prose :global(li) { margin-bottom: 0.55rem; line-height: 1.75; }
    .prose :global(hr) { display: none; }
    .prose :global(strong) { font-weight: 600; color: var(--navy); }
    .prose :global(em)     { font-style: italic; }

    .prose :global(a) {
      color: var(--teal);
      text-decoration: underline; text-underline-offset: 3px;
      text-decoration-color: rgba(27,94,111,0.35);
      transition: color 0.2s, text-decoration-color 0.2s;
    }
    .prose :global(a:hover) { color: var(--gold); text-decoration-color: rgba(200,162,82,0.4); }

    .prose :global(blockquote) {
      border-left: 3px solid var(--gold);
      padding: 1.15rem 1.75rem; margin: 2.5rem 0;
      background: var(--cream-dark);
      cursor: pointer; position: relative;
      transition: background 0.25s, transform 0.2s;
    }
    .prose :global(blockquote p) {
      margin: 0; font-style: italic; color: var(--muted);
      font-size: 1.05em; line-height: 1.75;
    }
    .prose :global(blockquote.highlighted) {
      background: rgba(200,162,82,0.1); transform: translateX(6px);
    }
    .prose :global(blockquote.highlighted p) { color: var(--charcoal); }

    .prose :global(.takeaways) {
      background: var(--navy); padding: 1.5rem 1.75rem; margin: 2.5rem 0;
      border-left: 4px solid var(--gold);
    }
    .prose :global(.takeaways h4) {
      font-size: 12px !important; font-weight: 600; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--gold) !important;
      margin: 0 0 0.85rem !important; padding: 0 !important; border: none !important;
    }
    .prose :global(.takeaways ul) { padding-left: 1.25rem; margin: 0; }
    .prose :global(.takeaways li) { color: rgba(255,255,255,0.78); font-size: 0.92em; margin-bottom: 0.45rem; }

    .prose :global(.section-ornament) {
      display: flex; align-items: center; justify-content: center;
      gap: 0.75rem; margin: 3rem 0; opacity: 0.42;
    }
    .prose :global(.section-ornament span) { display: block; height: 1px; flex: 1; background: var(--charcoal); }
    .prose :global(.section-ornament em)   { font-style: normal; font-size: 10px; color: var(--gold); letter-spacing: 0.65em; }

    .prose :global(.table-wrap) { overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 2.5rem 0; }
    .prose :global(table) {
      width: 100%; border-collapse: collapse;
      font-size: 15px; line-height: 1.55; margin: 0;
      font-family: 'Crimson Pro', Georgia, serif;
      border: 1px solid #d0cfc8;
    }
    .prose :global(thead tr) { background: #f0ede6; border-bottom: 2px solid #bbb9b0; }
    .prose :global(thead th) {
      padding: 0.65rem 1.1rem; text-align: left;
      font-weight: 600; font-size: 13px; color: var(--charcoal);
      border-right: 1px solid #d0cfc8;
    }
    .prose :global(thead th:last-child) { border-right: none; }
    .prose :global(tbody tr)                 { border-bottom: 1px solid #d0cfc8; }
    .prose :global(tbody tr:nth-child(even)) { background: #f8f6f1; }
    .prose :global(tbody tr:hover)           { background: #f2efe8; }
    .prose :global(tbody td) {
      padding: 0.65rem 1.1rem; font-size: 18px;
      color: var(--charcoal); line-height: 1.55; vertical-align: top;
      border-right: 1px solid #d0cfc8;
    }
    .prose :global(tbody td:last-child) { border-right: none; }

    /* Footnotes */
    .prose :global([data-footnote-ref]) {
      font-size: 0.68em; vertical-align: super; line-height: 0;
      font-weight: 600; color: var(--teal) !important;
      text-decoration: none !important; padding: 0 0.1em;
    }
    .prose :global([data-footnote-ref]:hover) { color: var(--gold) !important; }
    .prose :global([data-footnotes]) { border-top: 2px solid var(--cream-dark); margin-top: 3.5rem; padding-top: 2rem; }
    .prose :global([data-footnotes] .sr-only) { display: none; }
    .prose :global([data-footnotes] ol) { list-style: none; padding: 0; counter-reset: fn; }
    .prose :global([data-footnotes] li) {
      display: flex; gap: 0.75rem; align-items: baseline;
      margin-bottom: 0.85rem; font-size: 15px; line-height: 1.65;
      color: var(--muted); counter-increment: fn;
    }
    .prose :global([data-footnotes] li::before) {
      content: counter(fn) '.';
      font-size: 12px; font-weight: 600; color: var(--gold);
      min-width: 1.5rem; flex-shrink: 0;
    }
    .prose :global([data-footnotes] li p) { margin: 0; }
    .prose :global([data-footnote-backref]) {
      color: var(--teal) !important; text-decoration: none !important;
      opacity: 0.5; margin-left: 0.3rem; font-size: 0.75em;
    }
    .prose :global([data-footnote-backref]:hover) { opacity: 1; }

    /* ════════════════════════════════ AUTHOR BIO */
    .author-bio {
      border-top: 2px solid var(--gold);
      padding-top: 1.75rem; margin-top: 2.5rem; max-width: 68ch;
    }
    .bio-label { font-size: 12px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.5rem; }
    .bio-name  { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--navy); margin-bottom: 0.45rem; }
    .bio-text  { font-size: 19px; color: var(--muted); line-height: 1.82; }

    /* ════════════════════════════════ PREV / NEXT NAV */
    .article-nav {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
      max-width: 68ch; margin-top: 3.5rem;
      border-top: 2px solid var(--cream-dark);
    }
    .nav-card {
      padding: 1.5rem 1.75rem; text-decoration: none; background: var(--white);
      border: 1px solid var(--cream-dark);
      transition: background 0.22s, border-color 0.22s;
      display: flex; flex-direction: column; gap: 0.4rem;
    }
    .nav-card:hover { background: var(--navy); border-color: var(--navy); }
    .nav-card:hover .nav-dir, .nav-card:hover .nav-title { color: var(--gold-light); }
    .nav-card:hover .nav-excerpt { color: rgba(255,255,255,0.42); }
    .nav-card.next { text-align: right; }
    .nav-card.nav-empty { background: transparent; border: 1px dashed rgba(107,107,107,0.2); }
    .nav-dir {
      font-size: 12px; font-weight: 600; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--gold);
      display: flex; align-items: center; gap: 0.4rem; transition: color 0.2s;
    }
    .nav-card.next .nav-dir { justify-content: flex-end; }
    .nav-title   { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; color: var(--navy); line-height: 1.28; transition: color 0.2s; }
    .nav-excerpt { font-size: 15px; color: var(--muted); line-height: 1.52; margin-top: 0.2rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; transition: color 0.2s; }

    /* ════════════════════════════════ RIGHT SIDEBAR */
    .right-col {
      position: sticky; top: 4.5rem;
      padding: 3rem 1.5rem 3rem 1.75rem;
      align-self: start;
      max-height: calc(100vh - 5.5rem);
      overflow-y: auto; scrollbar-width: none;
    }
    .right-col::-webkit-scrollbar { display: none; }

    .sb-block { margin-bottom: 2.25rem; }
    .sb-block:last-child { margin-bottom: 0; }
    .sb-label { font-size: 12px; font-weight: 600; letter-spacing: 0.26em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.4rem; }
    .sb-rule  { width: 1.75rem; height: 2px; background: var(--gold); margin-bottom: 1rem; }

    /* Sidebar reading progress */
    .sb-progress-wrap { background: var(--cream-dark); height: 4px; border-radius: 2px; overflow: hidden; margin-top: 0.5rem; }
    .sb-progress-bar  { height: 100%; background: linear-gradient(90deg, var(--teal), var(--gold)); width: 0%; transition: width 0.12s linear; border-radius: 2px; }
    .sb-progress-pct  { font-size: 13px; color: var(--muted); display: block; margin-top: 0.35rem; }

    /* TOC */
    .toc-list { list-style: none; padding: 0; border-left: 2px solid var(--cream-dark); }
    .toc-list a {
      display: block; font-family: 'Crimson Pro', serif;
      font-size: 1.12em;       /* ← increased from 1rem */
      line-height: 1.42; color: var(--muted);
      text-decoration: none; padding: 0.42rem 0 0.42rem 0.85rem;
      border-left: 2px solid transparent; margin-left: -2px;
      transition: color 0.18s, border-color 0.18s;
    }
    .toc-list a:hover  { color: var(--navy); border-left-color: var(--teal); }
    .toc-list a.active { color: var(--navy); border-left-color: var(--gold); font-weight: 600; }
    .toc-list .h3 a    { font-size: 15px; padding-left: 1.5rem; color: rgba(107,107,107,0.65); }

    /* Share */
    .share-row { display: flex; gap: 0.4rem; }
    .share-btn {
      flex: 1; padding: 0.62rem 0.2rem;
      font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      border: 1px solid var(--cream-dark); color: var(--muted); background: none;
      cursor: pointer; font-family: 'Crimson Pro', serif; text-decoration: none;
      text-align: center; display: flex; align-items: center; justify-content: center;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .share-btn:hover { background: var(--navy); color: var(--gold); border-color: var(--navy); }

    /* Ad */
    .sb-ad { border: 1px dashed rgba(107,107,107,0.28); padding: 1.75rem 0.75rem; text-align: center; }
    .sb-ad-tag  { font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(107,107,107,0.3); display: block; margin-bottom: 0.4rem; }
    .sb-ad-note { font-size: 13px; color: rgba(107,107,107,0.3); line-height: 1.55; }

    /* ════════════════════════════════ LEFT COLUMN */
    .lc-label { font-size: 12px; font-weight: 600; letter-spacing: 0.26em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.4rem; }
    .lc-rule  { width: 1.75rem; height: 2px; background: var(--gold); margin-bottom: 1rem; }

    .more-article-link {
      display: block; text-decoration: none;
      padding: 0.85rem 0; border-bottom: 1px solid var(--cream-dark); transition: opacity 0.18s;
    }
    .more-article-link:first-child { border-top: 1px solid var(--cream-dark); }
    .more-article-link:hover { opacity: 0.68; }
    .ma-cat   { font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--teal); display: block; margin-bottom: 0.22rem; }
    .ma-title { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; color: var(--navy); line-height: 1.28; display: block; margin-bottom: 0.22rem; }
    .ma-date  { font-size: 12px; color: var(--muted); }

    .lc-ad { border: 1px dashed rgba(107,107,107,0.25); padding: 2.5rem 0.5rem; text-align: center; margin-top: 2rem; }
    .lc-ad-tag  { font-size: 0.5rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(107,107,107,0.28); display: block; margin-bottom: 0.4rem; }
    .lc-ad-note { font-size: 12px; color: rgba(107,107,107,0.28); line-height: 1.55; }

    .print-btn {
      display: flex; align-items: center; gap: 0.5rem; margin-top: 1.5rem;
      font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--muted); background: none; border: 1px solid var(--cream-dark);
      padding: 0.62rem 0.75rem; cursor: pointer; width: 100%; justify-content: center;
      font-family: 'Crimson Pro', serif; transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .print-btn:hover { background: var(--navy); color: var(--gold); border-color: var(--navy); }

    /* Quote tooltip */
    #quote-tooltip {
      position: fixed;
      background: var(--navy); color: var(--gold-light);
      font-family: 'Crimson Pro', serif; font-size: 12px; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0.45rem 0.9rem; pointer-events: none;
      opacity: 0; transform: translateY(4px);
      transition: opacity 0.18s, transform 0.18s;
      z-index: 8000; white-space: nowrap;
    }
    #quote-tooltip.visible { opacity: 1; transform: translateY(0); pointer-events: auto; cursor: pointer; }

    /* ════════════════════════════════ RESPONSIVE */
    @media (max-width: 1200px) {
      .page-grid { grid-template-columns: 180px 1fr 240px; }
    }
    @media (max-width: 1000px) {
      .page-grid { grid-template-columns: 1fr 240px; }
      .left-col  { display: none; }
    }
    @media (max-width: 820px) {
      .page-grid { grid-template-columns: 1fr; padding-bottom: 2rem; }
      .article-col { border-right: none; padding: 2rem 1.5rem 3rem; }
      .prose { max-width: 100%; }
      .author-bio { max-width: 100%; }
      .article-nav { max-width: 100%; grid-template-columns: 1fr; }
      .nav-card.next { text-align: left; }
      .nav-card.next .nav-dir { justify-content: flex-start; }
      .right-col {
        position: static; max-height: none; overflow-y: visible;
        border-top: 2px solid var(--cream-dark);
        display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; padding: 2rem;
      }
      .sb-block { margin-bottom: 0; }
      .toc-block { display: none; }
      .article-details-top { flex-direction: column; }
      .adt-item { border-right: none; border-bottom: 1px solid var(--cream-dark); }
      .adt-item:last-child { border-bottom: none; }
    }
    @media (max-width: 560px) {
      .article-hero { padding: 3.5rem 1.25rem 2.75rem; }
      .article-col  { padding: 1.75rem 1.25rem 3rem; }
      .right-col    { grid-template-columns: 1fr; padding: 1.5rem 1.25rem; }
    }
  </style>
</head>

<body>
  <div id="progress-bar"></div>
  <div id="quote-tooltip">Share Quote →</div>
  <Header />

  <!-- HERO -->
  <section class="article-hero">
    <div class="hero-inner">
      <nav class="breadcrumb">
        <a href={`${base}/`}>Home</a><span class="sep">/</span>
        <a href={`${base}/research`}>Research</a>
      </nav>
      {entry.data.category && <span class="article-cat">{entry.data.category}</span>}
      <h1>{entry.data.title}</h1>
      <div class="article-byline">
        <span class="byline-author">{entry.data.author}</span>
        <span class="byline-dot">◆</span>
        <span class="byline-date">{formatDate(entry.data.date)}</span>
        <span class="byline-dot">◆</span>
        <span class="byline-read">{readingTime} min read</span>
        <span class="byline-type">{entry.data.type}</span>
      </div>
    </div>
  </section>

  <!-- THREE-COLUMN GRID -->
  <div class="page-grid">

    <!-- LEFT COLUMN -->
    <aside class="left-col">
      {moreArticles.length > 0 && (
        <div style="margin-bottom:2rem">
          <span class="lc-label">More Articles</span>
          <div class="lc-rule"></div>
          {moreArticles.map(a => (
            <a href={`${base}/articles/${a.id.replace(/\.mdx?$/, '').toLowerCase()}`} class="more-article-link">
              <span class="ma-cat">{a.data.category ?? a.data.type}</span>
              <span class="ma-title">{a.data.title}</span>
              <span class="ma-date">{shortDate(a.data.date)}</span>
            </a>
          ))}
        </div>
      )}
      <button class="print-btn" onclick="window.print()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 6 2 18 2 18 9"></polyline>
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
          <rect x="6" y="14" width="12" height="8"></rect>
        </svg>
        Print / Save PDF
      </button>
      <div class="lc-ad">
        <span class="lc-ad-tag">Advertisement</span>
        <p class="lc-ad-note">Ad space<br />available</p>
      </div>
    </aside>

    <!-- ARTICLE -->
    <div class="article-col">
      <a href={`${base}/research`} class="back-link">← Back to Research</a>

      <!--
        ARTICLE DETAILS — moved to top of article column.
        Previously buried in the right sidebar where readers scrolled past it.
        Now it greets readers immediately before the prose begins.
      -->
      <div class="article-details-top">
        <div class="adt-item">
          <span class="adt-key">Author</span>
          <span class="adt-val">{entry.data.author}</span>
        </div>
        <div class="adt-item">
          <span class="adt-key">Published</span>
          <span class="adt-val">{formatDate(entry.data.date)}</span>
        </div>
        <div class="adt-item">
          <span class="adt-key">Format</span>
          <span class="adt-val">{entry.data.type}</span>
        </div>
        {entry.data.category && (
          <div class="adt-item">
            <span class="adt-key">Topic</span>
            <span class="adt-val">{entry.data.category}</span>
          </div>
        )}
        <div class="adt-item">
          <span class="adt-key">Reading Time</span>
          <span class="adt-val">{readingTime} min</span>
        </div>
        </div>
      <!-- Thin reading progress strip attached to bottom of details card -->
      <div class="adt-progress-wrap">
        <div class="adt-progress-bar" id="adt-progress"></div>
      </div>

      <article class="prose" id="article-content" style="margin-top: 2.5rem;">
        <Content />
      </article>

      {entry.data.authorBio && (
        <div class="author-bio">
          <span class="bio-label">About the Author</span>
          <div class="bio-name">{entry.data.author}</div>
          <p class="bio-text">{entry.data.authorBio}</p>
        </div>
      )}

      <!-- Prev / Next -->
      <nav class="article-nav" aria-label="Article navigation">
        {prevArticle ? (
          <a href={`${base}/articles/${prevArticle.id.replace(/\.mdx?$/, '').toLowerCase()}`} class="nav-card prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-title">{prevArticle.data.title}</span>
            {prevArticle.data.excerpt && <span class="nav-excerpt">{prevArticle.data.excerpt}</span>}
          </a>
        ) : <div class="nav-card nav-empty"></div>}

        {nextArticle ? (
          <a href={`${base}/articles/${nextArticle.id.replace(/\.mdx?$/, '').toLowerCase()}`} class="nav-card next">
            <span class="nav-dir">Next →</span>
            <span class="nav-title">{nextArticle.data.title}</span>
            {nextArticle.data.excerpt && <span class="nav-excerpt">{nextArticle.data.excerpt}</span>}
          </a>
        ) : <div class="nav-card nav-empty"></div>}
      </nav>
    </div>

    <!-- RIGHT SIDEBAR — cleaner now: TOC + reading progress + Share + Ad -->
    <aside class="right-col">

      <!-- Reading Progress -->
      <div class="sb-block">
        <span class="sb-label">Reading Progress</span>
        <div class="sb-rule"></div>
        <div class="sb-progress-wrap">
          <div class="sb-progress-bar" id="sb-progress"></div>
        </div>
        <span class="sb-progress-pct" id="sb-pct">0% read</span>
      </div>

      <!-- TOC -->
      <div class="sb-block toc-block">
        <span class="sb-label">Contents</span>
        <div class="sb-rule"></div>
        <ul class="toc-list" id="toc-list" aria-label="Article sections"></ul>
      </div>

      <!-- Share -->
      <div class="sb-block">
        <span class="sb-label">Share</span>
        <div class="sb-rule"></div>
        <div class="share-row">
          <button class="share-btn" id="share-copy">Copy Link</button>
          <a class="share-btn" id="share-tw" href="#" target="_blank" rel="noopener">Twitter</a>
        </div>
      </div>

      <!-- Ad -->
      <div class="sb-block">
        <div class="sb-ad">
          <span class="sb-ad-tag">Advertisement</span>
          <p class="sb-ad-note">Ad space available.<br />Contact us to enquire.</p>
        </div>
      </div>

    </aside>
  </div>

  <Footer />

  <script>
    // Progress bar (top of page) + sidebar + article details strip
    const bar     = document.getElementById('progress-bar') as HTMLElement | null;
    const sbBar   = document.getElementById('sb-progress') as HTMLElement | null;
    const adtBar  = document.getElementById('adt-progress') as HTMLElement | null;
    const sbPct   = document.getElementById('sb-pct');

    window.addEventListener('scroll', () => {
      const d   = document.documentElement;
      const pct = Math.min((d.scrollTop / (d.scrollHeight - d.clientHeight)) * 100, 100);
      if (bar)    bar.style.width    = `${pct}%`;
      if (sbBar)  sbBar.style.width  = `${pct}%`;
      if (adtBar) adtBar.style.width = `${pct}%`;
      if (sbPct)  sbPct.textContent  = `${Math.round(pct)}% read`;
    }, { passive: true });

    // Wrap tables
    document.querySelectorAll('.prose table').forEach(t => {
      const w = document.createElement('div');
      w.className = 'table-wrap';
      (t as HTMLElement).style.margin = '0';
      t.parentNode?.insertBefore(w, t);
      w.appendChild(t);
    });

    // Replace <hr> with ornament
    document.querySelectorAll('.prose hr').forEach(hr => {
      const o = document.createElement('div');
      o.className = 'section-ornament';
      o.innerHTML = '<span></span><em>◆ ◆ ◆</em><span></span>';
      hr.parentNode?.replaceChild(o, hr);
    });

    // Blockquote click highlight
    document.querySelectorAll('.prose blockquote').forEach(bq => {
      bq.addEventListener('click', () => bq.classList.toggle('highlighted'));
    });

    // Build TOC — retry if DOM not ready
    function buildTOC() {
      const article = document.getElementById('article-content');
      const toc     = document.getElementById('toc-list');
      if (!article || !toc) return;
      const heads = Array.from(article.querySelectorAll('h2, h3'));
      if (heads.length === 0) { setTimeout(buildTOC, 250); return; }

      toc.innerHTML = '';
      heads.forEach((h, i) => {
        h.id = `sec-${i}`;
        const li = document.createElement('li');
        if (h.tagName === 'H3') li.className = 'h3';
        const a = document.createElement('a');
        a.href        = `#sec-${i}`;
        a.textContent = (h.textContent ?? '').replace(/^\d+\.\s*/, '').trim();
        li.appendChild(a);
        toc.appendChild(li);
      });

      const links = Array.from(toc.querySelectorAll('a'));
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            links.forEach(l => l.classList.remove('active'));
            toc.querySelector(`a[href="#${e.target.id}"]`)?.classList.add('active');
          }
        });
      }, { rootMargin: '-8% 0px -78% 0px', threshold: 0 });
      heads.forEach(h => obs.observe(h));
    }
    requestAnimationFrame(() => setTimeout(buildTOC, 0));

    // Text selection share tooltip
    const tooltip = document.getElementById('quote-tooltip');
    const prose   = document.getElementById('article-content');
    let lastSel   = '';
    if (tooltip && prose) {
      document.addEventListener('selectionchange', () => {
        const sel  = window.getSelection();
        const text = sel?.toString().trim() ?? '';
        if (text.length > 30 && sel && prose.contains(sel.anchorNode)) {
          const rect = sel.getRangeAt(0).getBoundingClientRect();
          tooltip.style.left = `${rect.left + rect.width / 2 - 70}px`;
          tooltip.style.top  = `${rect.top + window.scrollY - 46}px`;
          tooltip.classList.add('visible');
          lastSel = text;
        } else { tooltip.classList.remove('visible'); lastSel = ''; }
      });
      tooltip.addEventListener('click', () => {
        if (!lastSel) return;
        const ex = lastSel.length > 180 ? lastSel.substring(0, 180) + '…' : lastSel;
        window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(`"${ex}" — Nahj Institute`)}&url=${encodeURIComponent(location.href)}`, '_blank', 'noopener');
        tooltip.classList.remove('visible');
        window.getSelection()?.removeAllRanges();
      });
      window.addEventListener('scroll', () => tooltip.classList.remove('visible'), { passive: true });
    }

    // Share buttons
    document.getElementById('share-copy')?.addEventListener('click', function() {
      navigator.clipboard.writeText(location.href).then(() => {
        this.textContent = 'Copied!';
        setTimeout(() => { this.textContent = 'Copy Link'; }, 2200);
      });
    });
    const tw = document.getElementById('share-tw');
    if (tw) tw.setAttribute('href', `https://twitter.com/intent/tweet?text=${encodeURIComponent(document.title)}&url=${encodeURIComponent(location.href)}`);
  </script>
</body>
</html>
