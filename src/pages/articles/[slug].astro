---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const all = await getCollection('articles', ({ data }) => !data.draft);
  all.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  return all.map((entry, i) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '').toLowerCase() },
    props: {
      entry,
      prevArticle:  all[i + 1] ?? null,
      nextArticle:  all[i - 1] ?? null,
      moreArticles: all.filter((_, j) => j !== i).slice(0, 4),
    },
  }));
}

const { entry, prevArticle, nextArticle, moreArticles } = Astro.props;
const { Content } = await entry.render();

const wordCount   = Math.round((entry.body?.length ?? 0) / 5);
const readingTime = Math.max(1, Math.round(wordCount / 220));

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
function shortDate(date: Date) {
  return date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{entry.data.title} | Nahj Institute</title>
  <meta name="description" content={entry.data.excerpt} />
  <meta property="og:title"       content={`${entry.data.title} | Nahj Institute`} />
  <meta property="og:description" content={entry.data.excerpt} />
  <meta property="og:type"        content="article" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --navy:       #0C1B2E;
      --teal:       #1B5E6F;
      --gold:       #C8A252;
      --gold-light: #E2BC75;
      --cream:      #F7F2E8;
      --cream-dark: #EDE6D5;
      --charcoal:   #2B2B2B;
      --muted:      #6B6B6B;
      --white:      #FFFFFF;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; scroll-behavior: smooth; }

    body {
      background: var(--cream);
      color: var(--charcoal);
      font-family: 'Crimson Pro', Georgia, serif;
      font-size: 18px;
      line-height: 1.78;
      -webkit-font-smoothing: antialiased;
    }

    /* ══ READING PROGRESS BAR (top of page) */
    #progress-bar {
      position: fixed; top: 0; left: 0; height: 3px; width: 0%;
      background: linear-gradient(90deg, var(--teal), var(--gold));
      z-index: 9999; pointer-events: none; transition: width 0.1s linear;
    }

    /* ══ ARTICLE HERO — streamlined
       Removed the redundant byline. The hero now shows:
       breadcrumb / category tag / title / author + date only.
       The full metadata is in the details strip below.
    */
    .article-hero {
      background: var(--navy);
      padding: 4.5rem 2rem 3.5rem;
      position: relative; overflow: hidden;
    }
    .article-hero::before {
      content: 'نهج'; font-family: 'Amiri', serif;
      font-size: clamp(120px, 20vw, 220px); font-weight: 700;
      color: rgba(255,255,255,0.025);
      position: absolute; right: -1rem; top: 50%;
      transform: translateY(-50%);
      pointer-events: none; user-select: none; line-height: 1;
    }
    .hero-inner { max-width: 1360px; margin: 0 auto; position: relative; z-index: 1; }

    .breadcrumb {
      font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(255,255,255,0.30); margin-bottom: 1.5rem;
      display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap;
    }
    .breadcrumb a { color: rgba(255,255,255,0.30); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--gold); }
    .breadcrumb .sep { color: rgba(255,255,255,0.12); }

    .article-cat {
      font-size: 11px; font-weight: 700; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--gold);
      display: inline-block; margin-bottom: 0.75rem;
      border: 1px solid rgba(200,162,82,0.3); padding: 0.2rem 0.6rem;
    }

    .article-hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(26px, 2.8vw, 36px);
      font-weight: 600; line-height: 1.08; color: var(--white);
      margin-bottom: 1.5rem; max-width: 820px;
    }

    /* Hero excerpt — replaces the duplicate byline
       Shows the article excerpt/abstract as a pull teaser.
       Inspired by Foreign Affairs and The Atlantic.
    */
    .hero-excerpt {
      font-size: 17px;
      color: rgba(255,255,255,0.58);
      max-width: 640px;
      font-weight: 300;
      line-height: 1.72;
      margin-bottom: 1.5rem;
      font-style: italic;
    }

    /* Minimal author/date strip — just enough to credit, not repeat everything */

    /* ══ THREE-COLUMN GRID */
    .page-grid {
      display: grid;
      grid-template-columns: 200px 1fr 252px;
      max-width: 1360px;
      margin: 0 auto;
      align-items: start;
      padding-bottom: 5rem;
    }

    /* ══ LEFT COLUMN */
    .left-col {
      position: sticky; top: 68px;
      padding: 2.5rem 1.25rem 2.5rem 1.5rem;
      align-self: start;
      /* No full-column scroll — More Articles list gets its own max-height */
      border-right: 1px solid var(--cream-dark);
    }
    /* More articles list has its own scroll so Print/Ad are always visible */
    .more-articles-list {
      max-height: 45vh;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--cream-dark) transparent;
    }
    .more-articles-list::-webkit-scrollbar { width: 3px; }
    .more-articles-list::-webkit-scrollbar-thumb { background: var(--cream-dark); border-radius: 2px; }

    /* ══ ARTICLE COLUMN */
    .article-col {
      padding: 3rem 3.5rem 4rem;
      border-right: 1px solid var(--cream-dark);
      min-width: 0; min-height: 70vh;
    }
    .back-link {
      font-size: 12px; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--teal); text-decoration: none;
      display: block; margin-bottom: 1.75rem; transition: color 0.2s;
    }
    .back-link:hover { color: var(--gold); }

    /* ══ ARTICLE DETAILS STRIP
       Compact horizontal bar: Author · Date · Format · Topic · Reading Time
       Uses box-shadow bottom line for clean separation from prose.
    */
    .article-details-top {
      display: flex;
      flex-wrap: wrap;
      border: 1px solid var(--cream-dark);
      background: var(--white);
      margin-bottom: 2.5rem;
      border-left: 3px solid var(--gold);
      box-shadow: 0 1px 3px rgba(12,27,46,0.05);
    }
    .adt-item {
      padding: 0.65rem 1.1rem;
      border-right: 1px solid var(--cream-dark);
      flex: 1 1 auto;
      min-width: 90px;
    }
    .adt-item:last-child { border-right: none; }
    .adt-key {
      font-size: 10px; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--gold);
      display: block; margin-bottom: 0.2rem;
    }
    .adt-val {
      font-size: 14px; color: var(--charcoal);
      line-height: 1.35; font-family: 'Crimson Pro', serif;
    }
    /* Reading progress strip under details */
    .adt-progress-wrap {
      height: 2px; background: var(--cream-dark);
      overflow: hidden; width: 100%;
    }
    .adt-progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--teal), var(--gold));
      width: 0%; transition: width 0.12s linear;
    }

    /* ══ PROSE */
    .prose {
      font-size: 19px;
      line-height: 1.82;
      color: var(--charcoal);
      max-width: 68ch;
    }

    .prose :global(p:first-of-type::first-letter) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 4.5em; font-weight: 600; color: var(--navy);
      float: left; line-height: 0.76;
      margin-right: 0.08em; margin-top: 0.15em;
      padding-bottom: 0.05em;
    }

    .prose :global(h2) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px; font-weight: 600; color: var(--navy);
      margin: 3.5rem 0 1rem; line-height: 1.15;
      padding-top: 1.5rem; border-top: 1px solid var(--cream-dark);
      scroll-margin-top: 5rem;
    }
    .prose :global(h2:first-child) { margin-top: 0; padding-top: 0; border-top: none; }

    .prose :global(h3) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px; font-weight: 600; color: var(--navy);
      margin: 2.5rem 0 0.75rem; line-height: 1.2; scroll-margin-top: 5rem;
    }
    .prose :global(h4) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 19px; font-weight: 600; color: var(--navy);
      margin: 2rem 0 0.5rem; scroll-margin-top: 5rem;
    }

    .prose :global(p)  { margin-bottom: 1.75rem; }
    .prose :global(ul), .prose :global(ol) { padding-left: 1.75rem; margin-bottom: 1.5rem; }
    .prose :global(li) { margin-bottom: 0.5rem; line-height: 1.78; }
    .prose :global(hr) { display: none; }
    .prose :global(strong) { font-weight: 700; color: var(--navy); }
    .prose :global(em)     { font-style: italic; }

    .prose :global(a) {
      color: var(--teal); text-decoration: underline;
      text-underline-offset: 2px;
      text-decoration-color: rgba(27,94,111,0.3);
      transition: color 0.2s;
    }
    .prose :global(a:hover) { color: var(--gold); }

    .prose :global(blockquote) {
      border-left: 3px solid var(--gold);
      padding: 1rem 1.5rem; margin: 2rem 0;
      background: var(--cream-dark);
      cursor: pointer; transition: background 0.25s, transform 0.2s;
    }
    .prose :global(blockquote p) {
      margin: 0; font-style: italic; color: var(--muted);
      font-size: 1.05em; line-height: 1.72;
    }
    .prose :global(blockquote.highlighted) {
      background: rgba(200,162,82,0.1); transform: translateX(5px);
    }

    .prose :global(.takeaways) {
      background: var(--navy); padding: 1.5rem 1.75rem; margin: 2rem 0;
      border-left: 4px solid var(--gold);
    }
    .prose :global(.takeaways h4) {
      font-size: 11px !important; font-weight: 700; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--gold) !important;
      margin: 0 0 0.75rem !important; padding: 0 !important; border: none !important;
    }
    .prose :global(.takeaways ul) { padding-left: 1.25rem; margin: 0; }
    .prose :global(.takeaways li) { color: rgba(255,255,255,0.78); font-size: 17px; margin-bottom: 0.4rem; }

    .prose :global(.section-ornament) {
      display: flex; align-items: center; justify-content: center;
      gap: 0.75rem; margin: 2.5rem 0; opacity: 0.35;
    }
    .prose :global(.section-ornament span) { display: block; height: 1px; flex: 1; background: var(--muted); }
    .prose :global(.section-ornament em)   { font-style: normal; font-size: 8px; color: var(--gold); letter-spacing: 0.6em; }

    .prose :global(.table-wrap) { overflow-x: auto; margin: 2rem 0; }
    .prose :global(table) {
      width: 100%; border-collapse: collapse;
      font-size: 15px; line-height: 1.5; margin: 0;
      border: 1px solid #d0cfc8;
    }
    .prose :global(thead tr) { background: #f0ede6; border-bottom: 2px solid #bbb9b0; }
    .prose :global(thead th) {
      padding: 0.6rem 1rem; text-align: left;
      font-weight: 700; font-size: 13px; color: var(--charcoal);
      border-right: 1px solid #d0cfc8; letter-spacing: 0.04em;
    }
    .prose :global(thead th:last-child) { border-right: none; }
    .prose :global(tbody tr) { border-bottom: 1px solid #d0cfc8; }
    .prose :global(tbody tr:nth-child(even)) { background: #f8f6f1; }
    .prose :global(tbody tr:hover) { background: #f2efe8; }
    .prose :global(tbody td) {
      padding: 0.6rem 1rem; font-size: 15px;
      color: var(--charcoal); line-height: 1.5; vertical-align: top;
      border-right: 1px solid #d0cfc8;
    }
    .prose :global(tbody td:last-child) { border-right: none; }

    /* Footnotes */
    .prose :global([data-footnote-ref]) {
      font-size: 0.68em; vertical-align: super; line-height: 0;
      font-weight: 700; color: var(--teal) !important; text-decoration: none !important;
    }
    .prose :global([data-footnote-ref]:hover) { color: var(--gold) !important; }
    .prose :global([data-footnotes]) { border-top: 1px solid var(--cream-dark); margin-top: 3rem; padding-top: 1.5rem; }
    .prose :global([data-footnotes] .sr-only) { display: none; }
    .prose :global([data-footnotes] ol) { list-style: none; padding: 0; counter-reset: fn; }
    .prose :global([data-footnotes] li) {
      display: flex; gap: 0.6rem; align-items: baseline;
      margin-bottom: 0.65rem; font-size: 14px; line-height: 1.6;
      color: var(--muted); counter-increment: fn;
    }
    .prose :global([data-footnotes] li::before) {
      content: counter(fn) '.';
      font-size: 12px; font-weight: 700; color: var(--gold);
      min-width: 1.25rem; flex-shrink: 0;
    }
    .prose :global([data-footnotes] li p) { margin: 0; }
    .prose :global([data-footnote-backref]) {
      color: var(--teal) !important; text-decoration: none !important;
      opacity: 0.45; margin-left: 0.25rem;
    }

    /* ══ AUTHOR BIO */
    .author-bio {
      border-top: 2px solid var(--gold);
      padding-top: 1.5rem; margin-top: 2.5rem; max-width: 68ch;
    }
    .bio-label { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.4rem; }
    .bio-name  { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 600; color: var(--navy); margin-bottom: 0.4rem; }
    .bio-text  { font-size: 16px; color: var(--muted); line-height: 1.72; }

    /* ══ PREV / NEXT NAV */
    .article-nav {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
      max-width: 68ch; margin-top: 3rem;
      border-top: 1px solid var(--cream-dark);
      padding-top: 1.5rem;
    }
    .nav-card {
      padding: 1.25rem 1.5rem; text-decoration: none; background: var(--white);
      border: 1px solid var(--cream-dark);
      transition: background 0.2s, border-color 0.2s;
      display: flex; flex-direction: column; gap: 0.35rem;
    }
    .nav-card:hover { background: var(--navy); border-color: var(--navy); }
    .nav-card:hover .nav-dir, .nav-card:hover .nav-title { color: var(--gold-light); }
    .nav-card:hover .nav-excerpt { color: rgba(255,255,255,0.38); }
    .nav-card.next { text-align: right; }
    .nav-card.nav-empty { background: transparent; border: 1px dashed rgba(107,107,107,0.18); }
    .nav-dir {
      font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--gold);
      display: flex; align-items: center; gap: 0.35rem; transition: color 0.2s;
    }
    .nav-card.next .nav-dir { justify-content: flex-end; }
    .nav-title   { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 600; color: var(--navy); line-height: 1.28; transition: color 0.2s; }
    .nav-excerpt { font-size: 14px; color: var(--muted); line-height: 1.5; margin-top: 0.15rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; transition: color 0.2s; }

    /* ══ RIGHT SIDEBAR
       Thin scrollbar is SHOWN (was hidden) so users know it is scrollable.
    */
    .right-col {
      position: sticky; top: 68px;
      padding: 2.5rem 1.5rem 2.5rem 1.75rem;
      align-self: start;
      /* NO height or overflow-y here — sidebar does NOT scroll as a whole.
         Only the TOC list itself scrolls. This keeps Share + Ad always visible. */
    }

    .sb-block { margin-bottom: 2rem; }
    .sb-block:last-child { margin-bottom: 0; }

    .sb-label {
      font-size: 11px; font-weight: 700; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--gold);
      display: block; margin-bottom: 0.4rem;
    }
    .sb-rule { width: 1.5rem; height: 2px; background: var(--gold); margin-bottom: 0.85rem; }

    /* Reading progress in sidebar */
    .sb-progress-wrap { background: var(--cream-dark); height: 3px; border-radius: 2px; overflow: hidden; }
    .sb-progress-bar  { height: 100%; background: linear-gradient(90deg, var(--teal), var(--gold)); width: 0%; transition: width 0.12s linear; border-radius: 2px; }
    .sb-progress-pct  { font-size: 13px; color: var(--muted); display: block; margin-top: 0.3rem; }


    /* TOC scroll-to-active: the toc container scrolls to keep active item visible */
    .toc-block { position: relative; }
    .toc-scroll-top {
      display: none;
      position: sticky;
      bottom: 0;
      left: 0; right: 0;
      background: linear-gradient(to top, var(--cream) 40%, transparent);
      padding: 1rem 0 0.25rem;
      text-align: center;
    }
    .toc-scroll-top button {
      font-family: 'Crimson Pro', serif;
      font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--teal);
      background: var(--white); border: 1px solid var(--cream-dark);
      padding: 0.35rem 0.75rem; cursor: pointer;
      transition: background 0.18s, color 0.18s;
    }
    .toc-scroll-top button:hover { background: var(--navy); color: var(--gold); border-color: var(--navy); }
    .toc-scroll-top.visible { display: block; }

    /* TOC — CONSISTENT 13px for all articles, no em units.
       max-height ensures TOC never pushes Share/Ad out of view. */
    .toc-list {
      list-style: none; padding: 0;
      border-left: 2px solid var(--cream-dark);
      max-height: 26vh;        /* 4 items visible — forces enough overflow for small thumb */
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(200,162,82,0.35) transparent;
    }
    .toc-list::-webkit-scrollbar { width: 3px; }
    .toc-list::-webkit-scrollbar-track { background: transparent; }
    .toc-list::-webkit-scrollbar-thumb {
      background: rgba(200,162,82,0.4);
      border-radius: 2px;
      min-height: 20px;   /* prevents thumb from being comically large on short lists */
    }
    .toc-list a {
      display: block;
      font-family: 'Crimson Pro', serif;
      font-size: 13px;
      line-height: 1.45;
      color: var(--muted);
      text-decoration: none;
      padding: 0.38rem 0 0.38rem 0.85rem;
      border-left: 2px solid transparent;
      margin-left: -2px;
      transition: color 0.18s, border-color 0.18s;
    }
    .toc-list a:hover  { color: var(--navy); border-left-color: var(--teal); }
    .toc-list a.active { color: var(--navy); border-left-color: var(--gold); font-weight: 700; }
    .toc-list .h3 a {
      font-size: 12px;
      padding-left: 1.5rem;
      color: rgba(107,107,107,0.6);
    }

    /* ══ SHARE — expanded with platform icons */
    .share-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5px;
    }
    .share-btn {
      display: flex; align-items: center; justify-content: center; gap: 5px;
      padding: 0.55rem 0.4rem;
      font-size: 12px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
      border: 1px solid var(--cream-dark); color: var(--muted); background: none;
      cursor: pointer; font-family: 'Crimson Pro', serif; text-decoration: none;
      transition: background 0.18s, color 0.18s, border-color 0.18s;
      white-space: nowrap;
    }
    .share-btn:hover { background: var(--navy); color: var(--gold); border-color: var(--navy); }
    .share-btn svg { width: 13px; height: 13px; flex-shrink: 0; }
    .share-btn.full-width { grid-column: span 2; }

    /* ══ LEFT COLUMN */
    .lc-label { font-size: 11px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.4rem; }
    .lc-rule  { width: 1.5rem; height: 2px; background: var(--gold); margin-bottom: 0.85rem; }

    .more-article-link {
      display: block; text-decoration: none;
      padding: 0.75rem 0; border-bottom: 1px solid var(--cream-dark); transition: opacity 0.18s;
    }
    .more-article-link:first-child { border-top: 1px solid var(--cream-dark); }
    .more-article-link:hover { opacity: 0.65; }
    .ma-cat   { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--teal); display: block; margin-bottom: 0.18rem; }
    .ma-title { font-family: 'Cormorant Garamond', serif; font-size: 14px; font-weight: 600; color: var(--navy); line-height: 1.28; display: block; margin-bottom: 0.18rem; }
    .ma-date  { font-size: 12px; color: var(--muted); }

    .print-btn {
      display: flex; align-items: center; gap: 0.45rem; margin-top: 1.25rem;
      font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--muted); background: none; border: 1px solid var(--cream-dark);
      padding: 0.55rem 0.75rem; cursor: pointer; width: 100%; justify-content: center;
      font-family: 'Crimson Pro', serif; transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .print-btn:hover { background: var(--navy); color: var(--gold); border-color: var(--navy); }


    /* Ad placeholders */
    .lc-ad { border: 1px dashed rgba(107,107,107,0.22); padding: 2rem 0.5rem; text-align: center; margin-top: 1.5rem; }
    .lc-ad-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(107,107,107,0.28); display: block; margin-bottom: 0.35rem; }
    .lc-ad-note { font-size: 13px; color: rgba(107,107,107,0.28); line-height: 1.5; }
    .sb-ad { border: 1px dashed rgba(107,107,107,0.22); padding: 1.5rem 0.75rem; text-align: center; }
    .sb-ad-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(107,107,107,0.28); display: block; margin-bottom: 0.35rem; }
    .sb-ad-note { font-size: 13px; color: rgba(107,107,107,0.28); line-height: 1.5; }

    /* Quote tooltip */
    #quote-tooltip {
      position: fixed;
      background: var(--navy); color: var(--gold-light);
      font-family: 'Crimson Pro', serif; font-size: 12px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0.4rem 0.85rem; pointer-events: none;
      opacity: 0; transform: translateY(4px);
      transition: opacity 0.18s, transform 0.18s;
      z-index: 8000; white-space: nowrap;
      border: 1px solid rgba(200,162,82,0.3);
    }
    #quote-tooltip.visible { opacity: 1; transform: translateY(0); pointer-events: auto; cursor: pointer; }

    /* ══ RESPONSIVE */
    @media (max-width: 1200px) {
      .page-grid { grid-template-columns: 170px 1fr 230px; }
    }
    @media (max-width: 1000px) {
      .page-grid { grid-template-columns: 1fr 230px; }
      .left-col  { display: none; }
    }
    @media (max-width: 820px) {
      .page-grid { grid-template-columns: 1fr; padding-bottom: 2rem; }
      .article-col { border-right: none; padding: 2rem 1.5rem 3rem; }
      .prose { max-width: 100%; font-size: 18px; }
      .author-bio { max-width: 100%; }
      .article-nav { max-width: 100%; grid-template-columns: 1fr; }
      .nav-card.next { text-align: left; }
      .nav-card.next .nav-dir { justify-content: flex-start; }
      .right-col {
        position: static; height: auto; overflow-y: visible;
        border-top: 2px solid var(--cream-dark);
        display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; padding: 2rem;
      }
      .sb-block { margin-bottom: 0; }
      .toc-block { display: none; }
      .article-details-top { flex-direction: column; }
      .adt-item { border-right: none; border-bottom: 1px solid var(--cream-dark); }
      .adt-item:last-child { border-bottom: none; }
    }
    @media (max-width: 560px) {
      .article-hero { padding: 3rem 1.25rem 2.5rem; }
      .article-col  { padding: 1.5rem 1.25rem 2.5rem; }
      .right-col    { grid-template-columns: 1fr; padding: 1.5rem 1.25rem; }
      .share-grid   { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>

<body>
  <div id="progress-bar"></div>
  <div id="quote-tooltip">Share Quote</div>
  <Header />

  <!-- ARTICLE HERO — cleaner, no duplicate metadata -->
  <section class="article-hero">
    <div class="hero-inner">
      <nav class="breadcrumb">
        <a href={`${base}/`}>Home</a>
        <span class="sep">/</span>
        <a href={`${base}/research`}>Research</a>
        {entry.data.category && (
          <>
            <span class="sep">/</span>
            <span>{entry.data.category}</span>
          </>
        )}
      </nav>

      {entry.data.category && <span class="article-cat">{entry.data.category}</span>}
      <h1>{entry.data.title}</h1>

      {/* Excerpt as pull teaser — the hero now shows only title + excerpt.
           All metadata is in the details strip directly below the hero.
           This eliminates the duplication shown in the screenshot. */}
      {entry.data.excerpt && (
        <p class="hero-excerpt">{entry.data.excerpt}</p>
      )}
    </div>
  </section>

  <!-- THREE-COLUMN GRID -->
  <div class="page-grid">

    <!-- LEFT COLUMN: More Articles + Print -->
    <aside class="left-col">
      {moreArticles.length > 0 && (
        <div style="margin-bottom:1.75rem">
          <span class="lc-label">More Articles</span>
          <div class="lc-rule"></div>
          <div class="more-articles-list">
            {moreArticles.map(a => (
              <a href={`${base}/articles/${a.id.replace(/\.mdx?$/, '').toLowerCase()}`} class="more-article-link">
                <span class="ma-cat">{a.data.category ?? a.data.type}</span>
                <span class="ma-title">{a.data.title}</span>
                <span class="ma-date">{shortDate(a.data.date)}</span>
              </a>
            ))}
          </div>
        </div>
      )}
      <button class="print-btn" onclick="window.print()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="6 9 6 2 18 2 18 9"></polyline>
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
          <rect x="6" y="14" width="12" height="8"></rect>
        </svg>
        Print / PDF
      </button>
      <div class="lc-ad">
        <span class="lc-ad-tag">Advertisement</span>
        <p class="lc-ad-note">Ad space<br/>available</p>
      </div>
    </aside>

    <!-- ARTICLE COLUMN -->
    <div class="article-col">
      <a href={`${base}/research`} class="back-link">← Back to Research</a>

      <!-- Article details strip — compact, not duplicated in hero -->
      <div class="article-details-top">
        <div class="adt-item">
          <span class="adt-key">Author</span>
          <span class="adt-val">{entry.data.author}</span>
        </div>
        <div class="adt-item">
          <span class="adt-key">Published</span>
          <span class="adt-val">{formatDate(entry.data.date)}</span>
        </div>
        <div class="adt-item">
          <span class="adt-key">Format</span>
          <span class="adt-val">{entry.data.type}</span>
        </div>
        {entry.data.category && (
          <div class="adt-item">
            <span class="adt-key">Topic</span>
            <span class="adt-val">{entry.data.category}</span>
          </div>
        )}
        <div class="adt-item">
          <span class="adt-key">Reading Time</span>
          <span class="adt-val">{readingTime} min</span>
        </div>
      </div>
      <div class="adt-progress-wrap">
        <div class="adt-progress-bar" id="adt-progress"></div>
      </div>

      <article class="prose" id="article-content" style="margin-top: 2.25rem;">
        <Content />
      </article>

      {entry.data.authorBio && (
        <div class="author-bio">
          <span class="bio-label">About the Author</span>
          <div class="bio-name">{entry.data.author}</div>
          <p class="bio-text">{entry.data.authorBio}</p>
        </div>
      )}

      <nav class="article-nav" aria-label="Article navigation">
        {prevArticle ? (
          <a href={`${base}/articles/${prevArticle.id.replace(/\.mdx?$/, '').toLowerCase()}`} class="nav-card prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-title">{prevArticle.data.title}</span>
            {prevArticle.data.excerpt && <span class="nav-excerpt">{prevArticle.data.excerpt}</span>}
          </a>
        ) : <div class="nav-card nav-empty"></div>}

        {nextArticle ? (
          <a href={`${base}/articles/${nextArticle.id.replace(/\.mdx?$/, '').toLowerCase()}`} class="nav-card next">
            <span class="nav-dir">Next →</span>
            <span class="nav-title">{nextArticle.data.title}</span>
            {nextArticle.data.excerpt && <span class="nav-excerpt">{nextArticle.data.excerpt}</span>}
          </a>
        ) : <div class="nav-card nav-empty"></div>}
      </nav>
    </div>

    <!-- RIGHT SIDEBAR -->
    <aside class="right-col">

      <!-- Reading Progress -->
      <div class="sb-block">
        <span class="sb-label">Progress</span>
        <div class="sb-rule"></div>
        <div class="sb-progress-wrap">
          <div class="sb-progress-bar" id="sb-progress"></div>
        </div>
        <span class="sb-progress-pct" id="sb-pct">0% read</span>
      </div>

      <!-- Table of Contents -->
      <div class="sb-block toc-block">
        <span class="sb-label">Contents</span>
        <div class="sb-rule"></div>
        <ul class="toc-list" id="toc-list" aria-label="Article sections"></ul>
        <div class="toc-scroll-top" id="toc-scroll-top">
          <button id="toc-back-top">↑ Top of Contents</button>
        </div>
      </div>

      <!-- Share — Twitter, Facebook, WhatsApp, Copy Link -->
      <div class="sb-block">
        <span class="sb-label">Share</span>
        <div class="sb-rule"></div>
        <div class="share-grid">
          <!-- Twitter / X -->
          <a class="share-btn" id="share-tw" href="#" target="_blank" rel="noopener noreferrer" title="Share on X / Twitter">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.737l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <!-- Facebook -->
          <a class="share-btn" id="share-fb" href="#" target="_blank" rel="noopener noreferrer" title="Share on Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            FB
          </a>
          <!-- WhatsApp -->
          <a class="share-btn" id="share-wa" href="#" target="_blank" rel="noopener noreferrer" title="Share on WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WA
          </a>
          <!-- Copy Link -->
          <button class="share-btn" id="share-copy" title="Copy link to clipboard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            Copy
          </button>
        </div>
      </div>

      <!-- Ad -->
      <div class="sb-block">
        <div class="sb-ad">
          <span class="sb-ad-tag">Advertisement</span>
          <p class="sb-ad-note">Ad space available.<br/>Contact us to enquire.</p>
        </div>
      </div>

    </aside>
  </div>

  <Footer />

  <script>
    /* ── PROGRESS BARS */
    const bar     = document.getElementById('progress-bar') as HTMLElement | null;
    const sbBar   = document.getElementById('sb-progress')  as HTMLElement | null;
    const adtBar  = document.getElementById('adt-progress')  as HTMLElement | null;
    const sbPct   = document.getElementById('sb-pct');

    window.addEventListener('scroll', () => {
      const d   = document.documentElement;
      const pct = Math.min((d.scrollTop / (d.scrollHeight - d.clientHeight)) * 100, 100);
      if (bar)    bar.style.width    = `${pct}%`;
      if (sbBar)  sbBar.style.width  = `${pct}%`;
      if (adtBar) adtBar.style.width = `${pct}%`;
      if (sbPct)  sbPct.textContent  = `${Math.round(pct)}% read`;
    }, { passive: true });

    /* ── TABLE WRAPPING */
    document.querySelectorAll('.prose table').forEach(t => {
      const w = document.createElement('div');
      w.className = 'table-wrap';
      (t as HTMLElement).style.margin = '0';
      t.parentNode?.insertBefore(w, t);
      w.appendChild(t);
    });

    /* ── HR → ORNAMENT */
    document.querySelectorAll('.prose hr').forEach(hr => {
      const o = document.createElement('div');
      o.className = 'section-ornament';
      o.innerHTML = '<span></span><em>◆ ◆ ◆</em><span></span>';
      hr.parentNode?.replaceChild(o, hr);
    });

    /* ── BLOCKQUOTE HIGHLIGHT */
    document.querySelectorAll('.prose blockquote').forEach(bq => {
      bq.addEventListener('click', () => bq.classList.toggle('highlighted'));
    });

    /* ── BUILD TOC */
    function buildTOC() {
      const article = document.getElementById('article-content');
      const toc     = document.getElementById('toc-list');
      if (!article || !toc) return;
      // Query h2 and h3 first; if none found (article uses h4 structure), fall back to h4
      let heads = Array.from(article.querySelectorAll('h2, h3'));
      if (heads.length === 0) {
        heads = Array.from(article.querySelectorAll('h4'));
      }
      if (heads.length === 0) { setTimeout(buildTOC, 250); return; }

      toc.innerHTML = '';
      heads.forEach((h, i) => {
        h.id = `sec-${i}`;
        const li = document.createElement('li');
        if (h.tagName === 'H3') li.className = 'h3';
        const a = document.createElement('a');
        a.href        = `#sec-${i}`;
        a.textContent = (h.textContent ?? '').replace(/^\d+[\.\)]\s*/, '').trim();
        li.appendChild(a);
        toc.appendChild(li);
      });

      const links = Array.from(toc.querySelectorAll('a'));
      const tocScrollTop = document.getElementById('toc-scroll-top');

      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            links.forEach(l => l.classList.remove('active'));
            const activeLink = toc.querySelector(`a[href="#${e.target.id}"]`);
            activeLink?.classList.add('active');

            // Auto-scroll the TOC LIST (not the whole sidebar) to keep active item visible.
            // toc is the <ul> element which now has its own max-height + overflow-y scroll.
            if (activeLink && toc) {
              const listRect = toc.getBoundingClientRect();
              const linkRect = activeLink.getBoundingClientRect();

              if (linkRect.bottom > listRect.bottom - 8) {
                // Active link below visible area — scroll down
                toc.scrollBy({ top: linkRect.bottom - listRect.bottom + 16, behavior: 'smooth' });
                if (tocScrollTop) tocScrollTop.classList.add('visible');
              } else if (linkRect.top < listRect.top + 8) {
                // Active link above visible area — scroll up
                toc.scrollBy({ top: linkRect.top - listRect.top - 16, behavior: 'smooth' });
                if (tocScrollTop && toc.scrollTop < 8) tocScrollTop.classList.remove('visible');
              }
            }
          }
        });
      }, { rootMargin: '-10% 0px -75% 0px', threshold: 0 });
      heads.forEach(h => obs.observe(h));
    }
    requestAnimationFrame(() => setTimeout(buildTOC, 0));

    /* ── TEXT SELECTION SHARE TOOLTIP */
    const tooltip = document.getElementById('quote-tooltip');
    const prose   = document.getElementById('article-content');
    let lastSel   = '';
    if (tooltip && prose) {
      document.addEventListener('selectionchange', () => {
        const sel  = window.getSelection();
        const text = sel?.toString().trim() ?? '';
        if (text.length > 30 && sel && prose.contains(sel.anchorNode)) {
          const rect = sel.getRangeAt(0).getBoundingClientRect();
          tooltip.style.left = `${rect.left + rect.width / 2 - 60}px`;
          tooltip.style.top  = `${rect.top + window.scrollY - 44}px`;
          tooltip.classList.add('visible');
          lastSel = text;
        } else {
          tooltip.classList.remove('visible');
          lastSel = '';
        }
      });
      tooltip.addEventListener('click', () => {
        if (!lastSel) return;
        const ex  = lastSel.length > 180 ? lastSel.substring(0, 180) + '\u2026' : lastSel;
        const url = encodeURIComponent(location.href);
        const txt = encodeURIComponent(`"${ex}" — Nahj Institute`);
        window.open(`https://twitter.com/intent/tweet?text=${txt}&url=${url}`, '_blank', 'noopener');
        tooltip.classList.remove('visible');
        window.getSelection()?.removeAllRanges();
      });
      window.addEventListener('scroll', () => tooltip.classList.remove('visible'), { passive: true });
    }

    /* ── SHARE BUTTONS */
    const pageUrl   = encodeURIComponent(location.href);
    const pageTitle = encodeURIComponent(document.title);

    // Twitter / X
    const tw = document.getElementById('share-tw');
    if (tw) tw.setAttribute('href', `https://twitter.com/intent/tweet?text=${pageTitle}&url=${pageUrl}`);

    // Facebook
    const fb = document.getElementById('share-fb');
    if (fb) fb.setAttribute('href', `https://www.facebook.com/sharer/sharer.php?u=${pageUrl}`);

    // WhatsApp
    const wa = document.getElementById('share-wa');
    if (wa) wa.setAttribute('href', `https://wa.me/?text=${pageTitle}%20${pageUrl}`);

    // TOC back-to-top button
    document.getElementById('toc-back-top')?.addEventListener('click', () => {
      document.getElementById('toc-list')?.scrollTo({ top: 0, behavior: 'smooth' });
      document.getElementById('toc-scroll-top')?.classList.remove('visible');
    });

    // Copy link
    document.getElementById('share-copy')?.addEventListener('click', function() {
      navigator.clipboard.writeText(location.href).then(() => {
        this.innerHTML = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg> Done`;
        setTimeout(() => {
          this.innerHTML = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Copy`;
        }, 2000);
      });
    });
  </script>
</body>
</html>