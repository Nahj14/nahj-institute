---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map(entry => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '').toLowerCase() },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{entry.data.title} — Nahj Institute</title>
    <meta name="description" content={entry.data.excerpt} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      :root {
        --navy:#0C1B2E;--teal:#1B5E6F;--gold:#C8A252;--gold-light:#E2BC75;
        --cream:#F7F2E8;--cream-dark:#EDE6D5;--charcoal:#2B2B2B;--muted:#6B6B6B;--white:#FFFFFF;
      }
      *{box-sizing:border-box;margin:0;padding:0;}
      body{background:var(--cream);color:var(--charcoal);font-family:'Crimson Pro',Georgia,serif;font-size:18px;line-height:1.75;-webkit-font-smoothing:antialiased;}

      .article-hero{background:var(--navy);padding:5rem 2rem 4rem;position:relative;overflow:hidden;}
      .article-hero::before{content:'نهج';font-family:'Amiri',serif;font-size:clamp(10rem,20vw,20rem);font-weight:700;color:rgba(255,255,255,0.032);position:absolute;right:-1rem;top:50%;transform:translateY(-50%);line-height:1;pointer-events:none;user-select:none;}
      .article-hero-inner{max-width:760px;margin:0 auto;position:relative;z-index:1;}
      .breadcrumb{font-size:0.78rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:2rem;display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;}
      .breadcrumb a{color:rgba(255,255,255,0.35);text-decoration:none;transition:color 0.2s;}
      .breadcrumb a:hover{color:var(--gold);}
      .breadcrumb span{color:rgba(255,255,255,0.15);}
      .article-tag{font-size:0.72rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:1rem;}
      .article-hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,4.5vw,3.8rem);font-weight:600;line-height:1.1;color:var(--white);margin-bottom:1.5rem;}
      .article-byline{display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;}
      .byline-author{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:500;color:var(--gold-light);}
      .byline-date{font-size:0.85rem;color:rgba(255,255,255,0.38);}
      .byline-type{font-size:0.7rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.55);padding:0.25rem 0.65rem;}

      .back-row{max-width:760px;margin:0 auto;padding:2rem 2rem 0;}
      .back-link{font-size:0.82rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--teal);text-decoration:none;transition:color 0.2s;}
      .back-link:hover{color:var(--gold);}

      .article-body{max-width:760px;margin:0 auto;padding:4rem 2rem 5rem;}
      .article-body :global(h2){font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:600;color:var(--navy);margin:3rem 0 1rem;line-height:1.15;}
      .article-body :global(h3){font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;color:var(--navy);margin:2rem 0 0.75rem;}
      .article-body :global(p){margin-bottom:1.5rem;font-size:1.08rem;line-height:1.88;color:var(--charcoal);}
      .article-body :global(blockquote){border-left:3px solid var(--gold);padding:1rem 1.5rem;margin:2rem 0;background:var(--cream-dark);}
      .article-body :global(blockquote p){margin:0;font-style:italic;color:var(--muted);}
      .article-body :global(ul),.article-body :global(ol){padding-left:2rem;margin-bottom:1.5rem;}
      .article-body :global(li){margin-bottom:0.5rem;font-size:1.05rem;line-height:1.75;}
      .article-body :global(a){color:var(--teal);text-decoration:underline;text-underline-offset:3px;}
      .article-body :global(a:hover){color:var(--gold);}
      .article-body :global(hr){border:none;border-top:1px solid var(--cream-dark);margin:3rem 0;}
      .article-body :global(strong){font-weight:600;color:var(--navy);}
      .article-body :global(em){font-style:italic;}

      .author-bio{max-width:760px;margin:0 auto;padding:0 2rem 5rem;}
      .author-bio-inner{border-top:2px solid var(--gold);padding-top:1.5rem;}
      .author-bio-label{font-size:0.72rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:0.75rem;}
      .author-bio-name{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:var(--navy);margin-bottom:0.5rem;}
      .author-bio-text{font-size:0.95rem;color:var(--muted);line-height:1.75;font-weight:300;}
    </style>
  </head>
  <body>
    <Header />
    <section class="article-hero">
      <div class="article-hero-inner">
        <nav class="breadcrumb">
          <a href={`${base}/`}>Home</a>
          <span>/</span>
          <a href={`${base}/research`}>Research</a>
          <span>/</span>
          <span style="color:rgba(255,255,255,0.55)">{entry.data.type}</span>
        </nav>
        <span class="article-tag">{entry.data.category}</span>
        <h1>{entry.data.title}</h1>
        <div class="article-byline">
          <span class="byline-author">{entry.data.author}</span>
          <span class="byline-date">{formatDate(entry.data.date)}</span>
          <span class="byline-type">{entry.data.type}</span>
        </div>
      </div>
    </section>
    <main>
      <div class="back-row">
        <a href={`${base}/research`} class="back-link">← Back to Research</a>
      </div>
      <article class="article-body">
        <Content />
      </article>
      {entry.data.authorBio && (
        <div class="author-bio">
          <div class="author-bio-inner">
            <span class="author-bio-label">About the Author</span>
            <div class="author-bio-name">{entry.data.author}</div>
            <p class="author-bio-text">{entry.data.authorBio}</p>
          </div>
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>