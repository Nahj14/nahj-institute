---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Community — Nahj Institute</title>
    <meta name="description" content="Nahj Institute's community programmes: writing competitions, student mentorship and development, workshops, and charitable initiatives." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <style is:global>
      :root {
        --navy:       #0C1B2E;
        --teal:       #1B5E6F;
        --gold:       #C8A252;
        --gold-light: #E2BC75;
        --cream:      #F7F2E8;
        --cream-dark: #EDE6D5;
        --charcoal:   #2B2B2B;
        --muted:      #6B6B6B;
        --white:      #FFFFFF;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: var(--cream);
        color: var(--charcoal);
        font-family: 'Crimson Pro', Georgia, serif;
        font-size: 18px;
        line-height: 1.78;
        -webkit-font-smoothing: antialiased;
      }

      .container { max-width: 1120px; margin: 0 auto; padding: 0 2rem; }

      .section-label {
        font-family: 'Crimson Pro', serif;
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
      }

      .divider-gold { width: 5rem; height: 2px; background: var(--gold); margin: 0.9rem 0 1.5rem; }
      .divider-gold.center { margin: 0.9rem auto 1.5rem; }

      .btn-primary {
        display: inline-block;
        background: var(--gold);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 19px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: background 0.2s, transform 0.15s;
      }

      .btn-primary:hover { background: var(--gold-light); transform: translateY(-1px); }

      .btn-outline-dark {
        display: inline-block;
        border: 1px solid var(--navy);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 19px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: background 0.2s, color 0.2s, transform 0.15s;
      }

      .btn-outline-dark:hover { background: var(--navy); color: var(--gold); transform: translateY(-1px); }

      .btn-outline-light {
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.28);
        color: rgba(255,255,255,0.78);
        font-family: 'Crimson Pro', serif;
        font-size: 19px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: border-color 0.2s, color 0.2s;
      }

      .btn-outline-light:hover { border-color: var(--gold); color: var(--gold-light); }

      /* ─── PAGE HERO ───────────────────────────────────────── */
      .page-hero {
        background: var(--navy);
        padding: 5.5rem 2rem 4.5rem;
        position: relative;
        overflow: hidden;
      }

      .page-hero::before {
        content: 'نهج';
        font-family: 'Amiri', serif;
        font-size: clamp(12rem, 24vw, 22rem);
        font-weight: 700;
        color: rgba(255,255,255,0.032);
        position: absolute;
        right: -1.5rem;
        top: 50%;
        transform: translateY(-50%);
        line-height: 1;
        pointer-events: none;
        user-select: none;
      }

      .page-hero-inner {
        max-width: 1120px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .breadcrumb {
        font-size: 13px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.35);
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .breadcrumb a { color: rgba(255,255,255,0.35); text-decoration: none; transition: color 0.2s; }
      .breadcrumb a:hover { color: var(--gold); }
      .breadcrumb span { color: rgba(255,255,255,0.15); }

      .page-hero h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(26px, 2.8vw, 36px);
        font-weight: 600;
        line-height: 1.07;
        color: var(--white);
        max-width: 780px;
        margin-bottom: 1.5rem;
      }

      .page-hero h1 em { font-style: italic; color: var(--gold-light); }

      .page-hero-sub {
        font-size: 21px;
        color: rgba(255,255,255,0.62);
        max-width: 600px;
        font-weight: 300;
        line-height: 1.75;
      }

      /* ─── OVERVIEW STRIP ──────────────────────────────────── */
      .section-overview {
        background: var(--cream-dark);
        padding: 0;
      }

      .overview-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-bottom: 1px solid var(--cream-dark);
      }

      .overview-item {
        padding: 2.75rem 2rem;
        border-right: 1px solid var(--cream-dark);
        text-decoration: none;
        color: inherit;
        display: block;
        transition: background 0.2s;
      }

      .overview-item:last-child { border-right: none; }
      .overview-item:hover { background: var(--cream); }

      .overview-icon {
        font-size: 22px;
        color: var(--teal);
        display: block;
        margin-bottom: 1rem;
      }

      .overview-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 22px;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.5rem;
      }

      .overview-desc {
        font-size: 21px;
        color: var(--muted);
        line-height: 1.78;
      }

      /* ─── WRITING COMPETITION ─────────────────────────────── */
      .section-competition {
        padding: 5.5rem 2rem;
        background: var(--cream);
      }

      .two-col {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: start;
      }

      .two-col h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(22px, 2.2vw, 28px);
        font-weight: 600;
        color: var(--navy);
        line-height: 1.1;
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
      }

      .two-col p {
        font-size: 20px;
        color: var(--charcoal);
        line-height: 1.78;
        font-weight: 300;
        margin-bottom: 1.25rem;
      }

      .two-col p:last-of-type { margin-bottom: 1.75rem; }

      .detail-panel {
        border: 1px solid var(--cream-dark);
      }

      .detail-row {
        display: flex;
        gap: 1.5rem;
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--cream-dark);
        align-items: baseline;
      }

      .detail-row:last-child { border-bottom: none; }

      .detail-key {
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--gold);
        width: 120px;
        flex-shrink: 0;
      }

      .detail-val {
        font-size: 19px;
        color: var(--charcoal);
        line-height: 1.6;
      }

      /* ─── STUDENT PROGRAMMES ──────────────────────────────── */
      .section-student {
        background: var(--navy);
        padding: 5.5rem 2rem;
        position: relative;
        overflow: hidden;
      }

      .section-student::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 55% 70% at 85% 50%, rgba(27,94,111,0.3) 0%, transparent 65%);
        pointer-events: none;
      }

      .student-inner {
        max-width: 1120px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .student-header {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        margin-bottom: 4rem;
        align-items: start;
      }

      .student-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(22px, 2.2vw, 28px);
        font-weight: 600;
        color: var(--white);
        line-height: 1.1;
        margin-top: 0.5rem;
      }

      .student-header p {
        font-size: 20px;
        color: rgba(255,255,255,0.62);
        line-height: 1.78;
        font-weight: 300;
        margin-top: 0.5rem;
      }

      .programme-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 0;
      }

      .programme-card {
        padding: 2.25rem 2rem;
        border: 1px solid rgba(255,255,255,0.07);
        transition: background 0.2s;
      }

      .programme-card:hover { background: rgba(255,255,255,0.04); }

      .programme-icon {
        font-size: 22px;
        color: var(--gold);
        display: block;
        margin-bottom: 1rem;
      }

      .programme-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 22px;
        font-weight: 600;
        color: var(--white);
        margin-bottom: 0.6rem;
      }

      .programme-body {
        font-size: 18px;
        color: rgba(255,255,255,0.52);
        line-height: 1.78;
        margin-bottom: 1.25rem;
      }

      .programme-link {
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--gold);
        text-decoration: none;
        transition: color 0.2s;
      }

      .programme-link:hover { color: var(--gold-light); }

      /* ─── CHARITY ─────────────────────────────────────────── */
      .section-charity {
        padding: 5.5rem 2rem;
        background: var(--cream-dark);
      }

      .charity-layout {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: start;
      }

      .charity-layout h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(22px, 2.2vw, 28px);
        font-weight: 600;
        color: var(--navy);
        line-height: 1.1;
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
      }

      .charity-layout p {
        font-size: 20px;
        color: var(--charcoal);
        line-height: 1.78;
        font-weight: 300;
        margin-bottom: 1.25rem;
      }

      .charity-initiatives {
        display: flex;
        flex-direction: column;
        gap: 0;
        border-top: 1px solid var(--cream-dark);
      }

      .initiative-row {
        padding: 1.5rem 0;
        border-bottom: 1px solid var(--cream-dark);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1.25rem;
        align-items: start;
      }

      .initiative-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 14px;
        font-weight: 600;
        color: var(--gold);
        padding-top: 0.15rem;
      }

      .initiative-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 21px;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.35rem;
      }

      .initiative-body {
        font-size: 18px;
        color: var(--muted);
        line-height: 1.82;
      }

      /* ─── GET INVOLVED CTA ────────────────────────────────── */
      .section-involved {
        background: var(--cream);
        padding: 5rem 2rem;
        text-align: center;
        border-top: 1px solid var(--cream-dark);
      }

      .section-involved h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.8rem, 3.5vw, 2.6rem);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
        margin-bottom: 1rem;
      }

      .section-involved p {
        font-size: 20px;
        color: var(--muted);
        max-width: 500px;
        margin: 0 auto 2.25rem;
        font-weight: 300;
        line-height: 1.78;
      }

      .cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }

      /* ─── RESPONSIVE ──────────────────────────────────────── */
      @media (max-width: 900px) {
        .overview-grid { grid-template-columns: 1fr; }
        .overview-item { border-right: none; border-bottom: 1px solid var(--cream-dark); }
        .two-col,
        .student-header,
        .charity-layout { grid-template-columns: 1fr; gap: 2.5rem; }
      }

      @media (max-width: 768px) {
        .page-hero { padding: 4rem 1.5rem 3rem; }
        .page-hero::before { font-size: 8rem; }
      }
    </style>
  </head>

  <body>
    <Header />

    <!-- ══════════════════════════════════════════════ PAGE HERO -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <nav class="breadcrumb">
          <a href="/Nahj-Institute/">Home</a>
          <span>/</span>
          <span style="color: rgba(255,255,255,0.65);">Community</span>
        </nav>
        <h1>Programmes, Competitions,<br />and <em>Community Work</em></h1>
        <p class="page-hero-sub">
          Beyond its publications and events, Nahj Institute runs programmes for students and emerging writers, supports charitable work, and maintains a commitment to the communities its scholarship is meant to serve.
        </p>
      </div>
    </section>

    <main>

      <!-- ════════════════════════════════════════ OVERVIEW -->
      <section class="section-overview">
        <div class="overview-grid container" style="padding: 0;">
          <a href="#competitions" class="overview-item">
            <span class="overview-icon">◈</span>
            <div class="overview-title">Writing Competitions</div>
            <p class="overview-desc">Annual prize competitions for students and emerging writers, with rigorous feedback and publication opportunities.</p>
          </a>
          <a href="#student" class="overview-item">
            <span class="overview-icon">◇</span>
            <div class="overview-title">Student Programmes</div>
            <p class="overview-desc">Workshops, mentorship, career guidance, and research skills development for students at all levels.</p>
          </a>
          <a href="#charity" class="overview-item">
            <span class="overview-icon">✧</span>
            <div class="overview-title">Community & Charity</div>
            <p class="overview-desc">Charitable initiatives grounded in the belief that scholarship and service to others are inseparable callings.</p>
          </a>
        </div>
      </section>

      <!-- ═════════════════════════════════ WRITING COMPETITION -->
      <section class="section-competition" id="competitions">
        <div class="two-col">
          <div>
            <span class="section-label">Annual Competition</span>
            <div class="divider-gold"></div>
            <h2>Writing Competition</h2>
            <p>
              Nahj Institute holds an annual writing competition open to students and emerging writers. The competition is designed as a serious intellectual exercise, not a promotional exercise. Entries are judged anonymously, assessed on the quality of argument and evidence, and awarded prizes alongside publication in the Nahj Journal or on the Institute website.
            </p>
            <p>
              All entrants receive editorial feedback. Strong but unplaced entries may be offered publication at the discretion of the editorial team. Previous competition questions have addressed Islamic political thought, the ethics of interreligious relations, and contemporary questions in Muslim social life.
            </p>
            <a href="/Nahj-Institute/contact" class="btn-primary">Register Interest</a>
          </div>

          <div class="detail-panel">
            <div class="detail-row">
              <span class="detail-key">Open To</span>
              <span class="detail-val">Students and writers within ten years of graduating, at any level</span>
            </div>
            <div class="detail-row">
              <span class="detail-key">Format</span>
              <span class="detail-val">Essay responding to a set question, 2,500 to 4,000 words</span>
            </div>
            <div class="detail-row">
              <span class="detail-key">Prizes</span>
              <span class="detail-val">First, second, and third place prizes plus commendations</span>
            </div>
            <div class="detail-row">
              <span class="detail-key">Publication</span>
              <span class="detail-val">Winning and commended entries considered for publication</span>
            </div>
            <div class="detail-row">
              <span class="detail-key">Assessment</span>
              <span class="detail-val">Blind review by panel of academics and Institute researchers</span>
            </div>
            <div class="detail-row">
              <span class="detail-key">Feedback</span>
              <span class="detail-val">Written feedback provided to all entrants</span>
            </div>
            <div class="detail-row">
              <span class="detail-key">Entry Fee</span>
              <span class="detail-val">Free to enter</span>
            </div>
            <div class="detail-row">
              <span class="detail-key">Next Round</span>
              <span class="detail-val">Question announced Spring 2026 · Deadline Autumn 2026</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════ STUDENT PROGRAMMES -->
      <section class="section-student" id="student">
        <div class="student-inner">
          <div class="student-header">
            <div>
              <span class="section-label">Student Development</span>
              <div class="divider-gold"></div>
              <h2>Programmes for Students and Early-Career Researchers</h2>
            </div>
            <p style="margin-top: 2rem;">
              Nahj Institute runs a set of programmes aimed at students and early-career researchers. These are designed to complement formal academic training, not replace it. The focus is on skills and capacities that institutions often underdevelop: writing clearly, arguing rigorously, engaging with difficult material, and finding a path in an academic and professional world that can be opaque and discouraging.
            </p>
          </div>

          <div class="programme-grid">
            <div class="programme-card">
              <span class="programme-icon">✦</span>
              <div class="programme-title">Writing Workshops</div>
              <p class="programme-body">Intensive workshops on academic and public writing. Sessions are small, feedback is direct, and the standard expected is high. Open to postgraduate students and recent graduates.</p>
              <a href="/Nahj-Institute/contact" class="programme-link">Apply or Enquire →</a>
            </div>

            <div class="programme-card">
              <span class="programme-icon">◉</span>
              <div class="programme-title">One-on-One Mentorship</div>
              <p class="programme-body">Paired mentorship with an Institute researcher or associate. The focus is on intellectual development, research direction, and navigating academic and professional decisions.</p>
              <a href="/Nahj-Institute/contact" class="programme-link">Apply or Enquire →</a>
            </div>

            <div class="programme-card">
              <span class="programme-icon">◈</span>
              <div class="programme-title">Career Counselling</div>
              <p class="programme-body">Guidance for students and researchers considering academic, policy, journalism, or civil society paths. Sessions are one-on-one and tailored to the individual's situation and goals.</p>
              <a href="/Nahj-Institute/contact" class="programme-link">Apply or Enquire →</a>
            </div>

            <div class="programme-card">
              <span class="programme-icon">◇</span>
              <div class="programme-title">Research Skills Bootcamp</div>
              <p class="programme-body">A structured short programme covering source evaluation, argumentation, citation practice, and the craft of research writing. Run twice yearly, online and in person.</p>
              <a href="/Nahj-Institute/contact" class="programme-link">Apply or Enquire →</a>
            </div>
          </div>

          <p style="margin-top: 2.5rem; font-size: 17px; color: rgba(255,255,255,0.35); font-style: italic; font-weight: 300;">
            All student programmes are free of charge. Places are limited and allocated on the basis of demonstrated interest and need.
          </p>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════ CHARITY -->
      <section class="section-charity" id="charity">
        <div class="charity-layout">
          <div>
            <span class="section-label">Community & Charity</span>
            <div class="divider-gold"></div>
            <h2>Service as Part of the Work</h2>
            <p>
              Nahj Institute does not regard scholarship as an end in itself. The intellectual tradition it draws on has always understood knowledge as inseparable from responsibility toward others. The Institute therefore maintains a programme of charitable and community work that sits alongside, and is informed by, its research and educational activities.
            </p>
            <p>
              These initiatives are modest in scale and deliberately local in orientation. The aim is not to operate large charitable programmes but to ensure that the Institute is genuinely connected to the communities whose questions it takes seriously.
            </p>
            <a href="/Nahj-Institute/contact" class="btn-outline-dark">Partner with Nahj on a Community Initiative</a>
          </div>

          <div class="charity-initiatives">
            <div class="initiative-row">
              <span class="initiative-num">01</span>
              <div>
                <div class="initiative-title">Educational Access Programme</div>
                <p class="initiative-body">Supporting access to quality educational resources for students from under-resourced backgrounds, including book provision, digital access, and study guidance.</p>
              </div>
            </div>

            <div class="initiative-row">
              <span class="initiative-num">02</span>
              <div>
                <div class="initiative-title">Community Lectures and Reading Groups</div>
                <p class="initiative-body">Free public talks and facilitated reading groups held in community spaces, bringing the Institute's intellectual work into accessible and informal settings.</p>
              </div>
            </div>

            <div class="initiative-row">
              <span class="initiative-num">03</span>
              <div>
                <div class="initiative-title">Partnership with Local Organisations</div>
                <p class="initiative-body">Collaborations with mosques, Islamic centres, and civil society organisations on research questions, policy engagement, and community education projects.</p>
              </div>
            </div>

            <div class="initiative-row">
              <span class="initiative-num">04</span>
              <div>
                <div class="initiative-title">Humanitarian Causes</div>
                <p class="initiative-body">The Institute periodically supports humanitarian appeals and charitable campaigns connected to the crises and communities it covers in its research work.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════ GET INVOLVED -->
      <section class="section-involved">
        <div class="container">
          <span class="section-label">Get Involved</span>
          <div class="divider-gold center"></div>
          <h2>Apply, Propose, or Reach Out</h2>
          <p>
            All community and student programmes are administered through the contact page. Whether you are a student seeking mentorship, an organisation considering a partnership, or an individual who wants to contribute, we would like to hear from you.
          </p>
          <div class="cta-buttons">
            <a href="/Nahj-Institute/contact" class="btn-primary">Contact Us</a>
            <a href="/Nahj-Institute/about" class="btn-outline-dark">About the Institute</a>
          </div>
        </div>
      </section>

    </main>

    <Footer />
  </body>
</html>