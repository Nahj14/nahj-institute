---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Home',         href: `${base}/` },
  { label: 'About',        href: `${base}/about` },
  { label: 'Research',     href: `${base}/research` },
  { label: 'Nahj Journal', href: `${base}/journal` },
  { label: 'Events',       href: `${base}/events` },
  { label: 'Community',    href: `${base}/community` },
  { label: 'Contact',      href: `${base}/contact` },
];
---

<header class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/Nahj-Institute/" class="header-logo" aria-label="Nahj Institute — Home">
      <span class="logo-en">Nahj Institute</span>
      <span class="logo-divider" aria-hidden="true"></span>
      <span class="logo-ar" aria-hidden="true">معهد النهج</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="header-nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile menu toggle -->
    <button class="menu-toggle" aria-label="Open navigation menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>

  <!-- Mobile Nav Drawer -->
  <nav class="mobile-nav" aria-label="Mobile navigation" aria-hidden="true">
    {navLinks.map(link => (
      <a href={link.href} class="mobile-nav-link">{link.label}</a>
    ))}
  </nav>
</header>

<style>
  :root {
    --navy:       #0C1B2E;
    --teal:       #1B5E6F;
    --gold:       #C8A252;
    --gold-light: #E2BC75;
    --cream:      #F7F2E8;
    --cream-dark: #EDE6D5;
    --charcoal:   #2B2B2B;
    --muted:      #6B6B6B;
    --white:      #FFFFFF;
  }

  .site-header {
    background: var(--navy);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* ─── LOGO ──────────────────────────────────────────────── */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-en {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white);
    transition: color 0.2s;
  }

  .header-logo:hover .logo-en { color: var(--gold-light); }

  .logo-divider {
    width: 1px;
    height: 18px;
    background: rgba(255,255,255,0.18);
    display: block;
  }

  .logo-ar {
    font-family: 'Amiri', 'Times New Roman', serif;
    font-size: 1.05rem;
    color: rgba(255,255,255,0.35);
    line-height: 1;
    transition: color 0.2s;
  }

  .header-logo:hover .logo-ar { color: rgba(255,255,255,0.55); }

  /* ─── DESKTOP NAV ───────────────────────────────────────── */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    padding: 0.45rem 0.85rem;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--white);
  }

  .nav-link.active {
    color: var(--gold-light);
    border-bottom-color: var(--gold);
  }

  /* ─── MOBILE TOGGLE ─────────────────────────────────────── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    flex-shrink: 0;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: rgba(255,255,255,0.7);
    transition: transform 0.25s, opacity 0.25s;
  }

  .menu-toggle.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle.open span:nth-child(2) { opacity: 0; }
  .menu-toggle.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ─── MOBILE NAV DRAWER ─────────────────────────────────── */
  .mobile-nav {
    display: none;
    flex-direction: column;
    background: var(--navy);
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 1rem 2rem 1.5rem;
    gap: 0;
  }

  .mobile-nav-link {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.2s;
  }

  .mobile-nav-link:last-child { border-bottom: none; }
  .mobile-nav-link:hover { color: var(--gold-light); }

  /* ─── RESPONSIVE ────────────────────────────────────────── */
  @media (max-width: 860px) {
    .header-nav { display: none; }
    .menu-toggle { display: flex; }
    .mobile-nav.open { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const mobileNav = document.querySelector('.mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('open');
    toggle.classList.toggle('open', isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));
  });
</script>