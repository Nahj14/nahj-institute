---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Home',         href: `${base}/` },
  { label: 'About',        href: `${base}/about` },
  { label: 'Research',     href: `${base}/research` },
  { label: 'Nahj Journal', href: 'https://journal.nahjinstitute.com', external: true },
  { label: 'Events',       href: `${base}/events` },
  { label: 'Community',    href: `${base}/community` },
  { label: 'Contact',      href: `${base}/contact` },
];
---

<header class="site-header">
  <div class="header-inner">

    <a href={`${base}/`} class="header-logo" aria-label="Nahj Institute">
      <span class="logo-en">Nahj Institute</span>
      <span class="logo-divider" aria-hidden="true"></span>
      <span class="logo-ar" aria-hidden="true">معهد النهج</span>
    </a>

    <nav class="header-nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link ${!link.external && (currentPath === link.href || (link.href !== `${base}/` && currentPath.startsWith(link.href))) ? 'active' : ''}`}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button class="menu-toggle" aria-label="Open navigation menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

  </div>

  <nav class="mobile-nav" aria-label="Mobile navigation" aria-hidden="true">
    {navLinks.map(link => (
      <a href={link.href} class="mobile-nav-link">{link.label}</a>
    ))}
  </nav>
</header>

<style>
  /*
    ALL SIZES IN px — never rem — so that page-level body font-size
    declarations cannot affect the header's rendering.
  */
  .site-header {
    background: #0C1B2E;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    position: sticky;
    top: 0;
    z-index: 200;
    font-family: 'Crimson Pro', Georgia, serif;
    -webkit-font-smoothing: antialiased;
  }

  .header-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* LOGO */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-en {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 17px;          /* was 1.1rem — now explicit px */
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #FFFFFF;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .header-logo:hover .logo-en { color: #E2BC75; }

  .logo-divider {
    width: 1px;
    height: 18px;
    background: rgba(255,255,255,0.18);
    display: block;
    flex-shrink: 0;
  }

  .logo-ar {
    font-family: 'Amiri', 'Times New Roman', serif;
    font-size: 16px;          /* was 1.05rem */
    color: rgba(255,255,255,0.35);
    line-height: 1;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .header-logo:hover .logo-ar { color: rgba(255,255,255,0.55); }

  /* DESKTOP NAV */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .nav-link {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 13px;          /* was 1rem = 16px; reduced so 7 links fit */
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    padding: 0.5rem 0.7rem;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
    line-height: 68px;        /* vertically centre within header */
    display: inline-block;
  }

  .nav-link:hover  { color: #FFFFFF; }
  .nav-link.active { color: #E2BC75; border-bottom-color: #C8A252; }

  /* MOBILE TOGGLE */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    flex-shrink: 0;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: rgba(255,255,255,0.7);
    transition: transform 0.25s, opacity 0.25s;
  }

  .menu-toggle.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle.open span:nth-child(2) { opacity: 0; }
  .menu-toggle.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* MOBILE NAV */
  .mobile-nav {
    display: none;
    flex-direction: column;
    background: #0C1B2E;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 1rem 2rem 1.5rem;
  }

  .mobile-nav-link {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 16px;          /* was 1rem */
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.2s;
  }

  .mobile-nav-link:last-child { border-bottom: none; }
  .mobile-nav-link:hover { color: #E2BC75; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .header-nav  { display: none; }
    .menu-toggle { display: flex; }
    .mobile-nav.open { display: flex; }
  }

  /* On very wide screens, slightly increase nav link size */
  @media (min-width: 1200px) {
    .nav-link { font-size: 14px; padding: 0.5rem 0.85rem; }
  }
</style>

<script>
  const toggle    = document.querySelector('.menu-toggle');
  const mobileNav = document.querySelector('.mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('open');
    toggle.classList.toggle('open', isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));
  });
</script>
