---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const footerLinks = {
  'Research': [
    { label: 'All Publications',     href: `${base}/research` },
    { label: 'Nahj Journal',         href: 'https://journal.nahjinstitute.com' },
    { label: 'Submit Writing',       href: `${base}/research/submit` },
    { label: 'Editorial Guidelines', href: `${base}/research/submit` },
  ],
  'Institute': [
    { label: 'About Nahj',           href: `${base}/about` },
    { label: 'Our Team',             href: `${base}/team` },
    { label: 'Focus Areas',          href: `${base}/about` },
    { label: 'Our Mission',          href: `${base}/about` },
  ],
  'Engage': [
    { label: 'Events and Lectures',  href: `${base}/events` },
    { label: 'Community',            href: `${base}/community` },
    { label: 'Writing Competitions', href: `${base}/community#competitions` },
    { label: 'Contact Us',           href: `${base}/contact` },
  ],
};

const year = new Date().getFullYear();
---

<footer class="site-footer">

  <div class="footer-body">
    <div class="footer-inner">

      <div class="footer-brand">
        <a href={`${base}/`} class="footer-logo" aria-label="Nahj Institute">
          <span class="flogo-en">Nahj Institute</span>
        </a>
        <p class="footer-tagline">Charting the Path.<br />Shaping the Discourse.</p>
        <p class="footer-desc">
          An independent research centre working at the intersection of Islamic thought, politics, society, and contemporary global affairs.
        </p>
        <div class="footer-social">
          <a href="https://twitter.com/NahjInstitute" class="social-link" aria-label="X / Twitter" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.737l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://facebook.com/NahjInstitute" class="social-link" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://instagram.com/NahjInstitute" class="social-link" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      {Object.entries(footerLinks).map(([group, links]) => (
        <div class="footer-col">
          <h4 class="footer-col-title">{group}</h4>
          <ul>
            {links.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

    </div>
  </div>

  <div class="footer-notice">
    <div class="footer-notice-inner">
      <div class="notice-heading">
        <span class="notice-rule"></span>
        <span class="notice-title">Editorial Notice</span>
        <span class="notice-rule"></span>
      </div>
      <p class="notice-body">
        The views expressed in all articles, essays, and commentary on this website are those of the individual authors and do not necessarily represent the positions or institutional stance of Nahj Institute. We do not publish content that is hateful, abusive, or derogatory toward any individual, community, or tradition. All submissions are reviewed before publication.
      </p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copy">&copy; {year} Nahj Institute. All rights reserved.</p>
      <div class="footer-legal">
        <a href={`${base}/privacy`}>Privacy Policy</a>
        <a href={`${base}/terms`}>Terms of Use</a>
      </div>
    </div>
  </div>

</footer>

<style>
  /*
    ALL SIZES IN px — never rem — so that no page can accidentally
    change the footer's appearance by overriding the html root font-size.
  */
  .site-footer {
    background: #0C1B2E;
    font-family: 'Crimson Pro', Georgia, serif;
    -webkit-font-smoothing: antialiased;
  }

  .footer-body {
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 5rem 2rem 4rem;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .footer-logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 1.4rem;
  }

  .flogo-en {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 19px;            /* was 1.25rem = 20px — consistent */
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #FFFFFF;
    transition: color 0.2s;
  }

  .footer-logo:hover .flogo-en { color: #E2BC75; }

  .footer-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;            /* was 0.95rem = 15.2px */
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #C8A252;
    line-height: 1.65;
    margin-bottom: 1.2rem;
  }

  .footer-desc {
    font-size: 16px;            /* was 1rem = 16px — keep */
    color: rgba(255,255,255,0.42);
    line-height: 1.75;
    margin-bottom: 2rem;
    font-weight: 300;
    max-width: 300px;
  }

  .footer-social { display: flex; gap: 0.6rem; align-items: center; }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.4);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    text-decoration: none;
  }

  .social-link:hover { border-color: #C8A252; color: #C8A252; background: rgba(200,162,82,0.06); }

  .footer-col-title {
    font-family: 'Crimson Pro', serif;
    font-size: 13px;            /* was 0.85rem = 13.6px — cleaner */
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C8A252;
    margin-bottom: 1.2rem;
  }

  .footer-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }

  .footer-col ul li a {
    font-size: 17px;            /* was 1rem = 16px — slightly larger for readability */
    color: rgba(255,255,255,0.48);
    text-decoration: none;
    padding: 0.32rem 0;
    display: block;
    transition: color 0.2s;
    font-weight: 300;
  }

  .footer-col ul li a:hover { color: rgba(255,255,255,0.88); }

  /* EDITORIAL NOTICE */
  .footer-notice {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 2rem 2rem;
    background: rgba(0,0,0,0.18);
  }

  .footer-notice-inner { max-width: 1120px; margin: 0 auto; }

  .notice-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .notice-rule { flex: 1; height: 1px; background: rgba(200,162,82,0.25); display: block; }

  .notice-title {
    font-size: 11px;            /* was 0.62rem = 9.9px — too small, bumped to 11px */
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #C8A252;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .notice-body {
    font-size: 15px;            /* was 0.88rem = 14.1px — bumped */
    color: rgba(255,255,255,0.40);
    line-height: 1.78;
    font-weight: 300;
    text-align: center;
    max-width: 880px;
    margin: 0 auto;
  }

  /* BOTTOM BAR */
  .footer-bottom {
    padding: 1.1rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .footer-bottom-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 14px;            /* was 0.85rem = 13.6px */
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.04em;
  }

  .footer-legal { display: flex; gap: 1.5rem; }

  .footer-legal a {
    font-size: 14px;
    color: rgba(255,255,255,0.22);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-legal a:hover { color: rgba(255,255,255,0.55); }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .footer-brand { grid-column: span 2; }
  }

  @media (max-width: 520px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-brand { grid-column: span 1; }
    .footer-body  { padding: 3rem 1.25rem 2.5rem; }
  }
</style>
