---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const footerLinks = {
  'Research': [
    { label: 'All Publications',     href: `${base}/research` },
    { label: 'Nahj Journal',         href: `${base}/journal` },
    { label: 'Submit an Article',    href: `${base}/contact` },
    { label: 'Editorial Guidelines', href: `${base}/contact` },
  ],
  'Institute': [
    { label: 'About Nahj',           href: `${base}/about` },
    { label: 'Our Mission',          href: `${base}/about#mission` },
    { label: 'The Team',             href: `${base}/about#team` },
    { label: 'Focus Areas',          href: `${base}/about#focus` },
  ],
  'Engage': [
    { label: 'Events & Lectures',    href: `${base}/events` },
    { label: 'Community',            href: `${base}/community` },
    { label: 'Writing Competitions', href: `${base}/community#competitions` },
    { label: 'Contact Us',           href: `${base}/contact` },
  ],
};

const year = new Date().getFullYear();
---

<footer class="site-footer">

  <!-- Main footer body -->
  <div class="footer-body">
    <div class="footer-inner">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href={`${base}/`} class="footer-logo" aria-label="Nahj Institute">
          <span class="flogo-en">Nahj Institute</span>
        </a>
        <p class="footer-tagline">Charting the Path.<br />Shaping the Discourse.</p>
        <p class="footer-desc">
          An independent research centre and think tank working at the intersection of Islamic thought, politics, society, and contemporary global affairs.
        </p>

        <!-- Social links -->
        <div class="footer-social">

          <!-- Twitter / X -->
          <a href="https://twitter.com/NahjInstitute" class="social-link" aria-label="Follow Nahj Institute on X (Twitter)" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.737l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>

          <!-- Facebook -->
          <a href="https://facebook.com/NahjInstitute" class="social-link" aria-label="Follow Nahj Institute on Facebook" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a href="https://instagram.com/NahjInstitute" class="social-link" aria-label="Follow Nahj Institute on Instagram" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>

          <!-- Substack -->
          <a href="https://nahj.substack.com" class="social-link" aria-label="Read Nahj Institute on Substack" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
            </svg>
          </a>

        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([group, links]) => (
        <div class="footer-col">
          <h4 class="footer-col-title">{group}</h4>
          <ul>
            {links.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

    </div>
  </div>

  <!-- ═══════════════════════════════════ EDITORIAL DISCLAIMER -->
  <div class="footer-disclaimer">
    <div class="footer-disclaimer-inner">
      <span class="disclaimer-label">Editorial Notice</span>
      <p class="disclaimer-text">
        The views expressed in articles, essays, commentary, and other publications are those of the individual authors alone and do not necessarily represent the positions, editorial views, or institutional stance of Nahj Institute. Publication does not constitute endorsement. Nahj Institute is committed to rigorous, evidence-based scholarship and to the standards of respectful intellectual engagement. We do not publish content that is hateful, abusive, or derogatory toward any individual, community, or tradition, nor content that promotes division, incitement, or discrimination on any grounds. Please contact us directly for any concerns regarding any content.
      </p>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copy">
        &copy; {year} Nahj Institute. All rights reserved.
      </p>
      <div class="footer-legal">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Use</a>
      </div>
    </div>
  </div>

</footer>

<style>
  :root {
    --navy:       #0C1B2E;
    --teal:       #1B5E6F;
    --gold:       #C8A252;
    --gold-light: #E2BC75;
    --cream:      #F7F2E8;
    --cream-dark: #EDE6D5;
    --charcoal:   #2B2B2B;
    --muted:      #6B6B6B;
    --white:      #FFFFFF;
  }

  .site-footer {
    background: var(--navy);
    font-family: 'Crimson Pro', Georgia, serif;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── FOOTER BODY ───────────────────────────────────────── */
  .footer-body {
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 5rem 2rem 4rem;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ─── BRAND COLUMN ──────────────────────────────────────── */
  .footer-logo {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
    width: fit-content;
  }

  .flogo-en {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--white);
    transition: color 0.2s;
    line-height: 1;
  }

  .footer-logo:hover .flogo-en { color: var(--gold-light); }

  .footer-tagline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 0.9rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .footer-desc {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.75;
    margin-bottom: 2rem;
    font-weight: 300;
    max-width: 300px;
  }

  /* ─── SOCIAL LINKS ──────────────────────────────────────── */
  .footer-social {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.45);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    text-decoration: none;
  }

  .social-link:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(200,162,82,0.06);
  }

  /* ─── LINK COLUMNS ──────────────────────────────────────── */
  .footer-col-title {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.25rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .footer-col ul li a {
    font-size: 0.93rem;
    color: rgba(255,255,255,0.48);
    text-decoration: none;
    padding: 0.3rem 0;
    display: block;
    transition: color 0.2s;
    font-weight: 300;
  }

  .footer-col ul li a:hover { color: rgba(255,255,255,0.88); }

  /* ─── EDITORIAL DISCLAIMER ──────────────────────────────── */
  .footer-disclaimer {
    border-top: 1px solid rgba(255,255,255,0.07);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 2rem 2rem;
    background: rgba(0,0,0,0.15);
  }

  .footer-disclaimer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: start;
  }

  .disclaimer-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    white-space: nowrap;
    padding-top: 0.2rem;
    border-left: 2px solid var(--gold);
    padding-left: 0.85rem;
  }

  .disclaimer-text {
    font-size: 0.84rem;
    color: rgba(255,255,255,0.32);
    line-height: 1.75;
    font-weight: 300;
    font-style: italic;
  }

  /* ─── BOTTOM BAR ────────────────────────────────────────── */
  .footer-bottom {
    padding: 1.25rem 2rem;
  }

  .footer-bottom-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.04em;
  }

  .footer-legal { display: flex; gap: 1.5rem; }

  .footer-legal a {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.22);
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.04em;
  }

  .footer-legal a:hover { color: rgba(255,255,255,0.55); }

  /* ─── RESPONSIVE ────────────────────────────────────────── */
  @media (max-width: 900px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 3rem; }
    .footer-brand { grid-column: span 2; }
    .footer-disclaimer-inner { grid-template-columns: 1fr; gap: 1rem; }
    .disclaimer-label { border-left: none; padding-left: 0; border-bottom: 1px solid rgba(200,162,82,0.4); padding-bottom: 0.5rem; }
  }

  @media (max-width: 520px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-brand { grid-column: span 1; }
  }
</style>
